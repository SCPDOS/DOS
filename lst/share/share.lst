   220                              <1> checkRegionLock:  
   221                              <1> ;Check file region locked.
   222                              <1> ;Input: rdi -> SFT for current file
   223                              <1> ;       ecx = Length of region from current position in file
   224                              <1> ;       dword [currByteF] set up with current position in file
   225                              <1> ;Get the mft ptr, walk the lock list and check that the range specified
   226                              <1> ; in between current offset and current offset + ecx is not within any range
   227 00000185 E87B020000          <1>     call critEnter
   228 0000018A 53                  <1>     push rbx
   229 0000018B 51                  <1>     push rcx
   230 0000018C 57                  <1>     push rdi
   231 0000018D 55                  <1>     push rbp
   232 0000018E 4150                <1>     push r8
   233 00000190 4C8B05(26000000)    <1>     mov r8, qword [pDosseg]
   234 00000197 48817F4F00000000    <1>     cmp qword [rdi + sft.pMFT], 0   ;If we don't have an MFT, exit immediately
   235 0000019F 742E                <1>     je .exit
   236 000001A1 488B6F4F            <1>     mov rbp, qword [rdi + sft.pMFT] ;Get the MFT ptr
   237 000001A5 48817D0600000000    <1>     cmp qword [rbp + mft.pLock], 0  ;If we have no locks, exit immediately
   238 000001AD 7420                <1>     je .exit
   239 000001AF 418B8098070000      <1>     mov eax, dword [r8 + currByteF] ;Get the current byte count
   240                              <1> ;[DO SUB TO SET CF]
   241 000001B6 81E901000000        <1>     sub ecx, 1 ;dec count to get last byte in range and clear upper dword
   242 000001BC F5                  <1>     cmc     ;If carry clear here, exit (it means ecx was zero)
   243 000001BD 7310                <1>     jnc .exit
   244 000001BF 488D1408            <1>     lea rdx, qword [rax + rcx]  ;Add the read length to curroffset
   245 000001C3 31C9                <1>     xor ecx, ecx    ;Set to ignore locks currentSFT owns (i.e. rdi)
   246                              <1> ;Below needs:  
   247                              <1> ;       rax = Start byte to check
   248                              <1> ;       rdx = End byte to check
   249                              <1> ;       rbp -> MFT to start searching 
   250                              <1> ;       ecx = 0: Do not check locks belonging to currentSFT, dMID, qPID
   251 000001C5 E87A020000          <1>     call checkLockOverlap   ;Trashes rbx and rdi
   252 000001CA B821000000          <1>     mov eax, errLokVio      ;Assume an error occured
   253                              <1> .exit:
