    52                                  %include "./src/share/text/shutils.asm"
     1                              <1> ;All utility functions go here
     2                              <1> ;-----------------------------------------------------------------------------
     3                              <1> ; critEnter -> Enters a DOS 1 critical section
     4                              <1> ; critExit -> Exits a DOS 1 critical section
     5                              <1> ; lockPreamble -> Sets up the registers for set/clear flock
     6                              <1> ; checkLockOverlap -> Checks if a lock with the given bounds exists
     7                              <1> ; getFreeLock -> Removes a free lock from the free lock list
     8                              <1> ; closeByID -> Closses all files according to IDs
     9                              <1> ; closeSFT -> Wrapper for Close SFT
    10                              <1> ; closeHandlesForSFT -> Closes handles referencing an SFT
    11                              <1> ; freeMFT -> Frees an MFT from the MFT arena
    12                              <1> ; removeSFTfromMFT -> Removes an SFT from an MFT's SFT chain
    13                              <1> ; freeLocks -> Frees all file locks associated to a SFT
    14                              <1> ; addSFTtoMFT -> Adds an SFT to its MFT chain.
    15                              <1> ; getMFT -> Gets an MFT for a given filename. Creates if it has to.
    16                              <1> ; defragMFTArena -> Defragments the MFT arena
    17                              <1> ; findFreeMFT -> Finds a free MFT for a given size
    18                              <1> ; findMFT -> Find an MFT for a given filename
    19                              <1> ; getNameMeta -> Computes the length and checksum of a filename
    20                              <1> ; closeJFTentries -> Closes all JFT entries pointing to a 
    21                              <1> ;                       particular SFT for a process.
    22                              <1> ; errPrintAndHalt -> Prints a formatted error message and halts the machine
    23                              <1> ;-----------------------------------------------------------------------------
    24                              <1> 
    25                              <1> 
    26                              <1> critEnter:
    27 000003F5 50                  <1>     push rax
    28 000003F6 B801800000          <1>     mov eax, 8001h  ;Enter DOS Level 1 critical section
    29 000003FB CD2A                <1>     int 2ah
    30 000003FD 58                  <1>     pop rax
    31                              <1>     return
    13                              <2> %%_ret:
    14 000003FE C3                  <2>  ret
    15                              <2> %assign retOff %%_ret-$$
    32                              <1> critExit:
    33 000003FF 50                  <1>     push rax
    34 00000400 B801810000          <1>     mov eax, 8101h  ;Exit DOS Level 1 critical section
    35 00000405 CD2A                <1>     int 2ah
    36 00000407 58                  <1>     pop rax
    37                              <1>     return
    13                              <2> %%_ret:
    14 00000408 C3                  <2>  ret
    15                              <2> %assign retOff %%_ret-$$
    38                              <1> 
    39                              <1> lockPreamble:
    40                              <1> ;Sets up the regs for the lock/unlock operation
    41                              <1> ;Input: rdi -> SFT for file
    42                              <1> ;       ecx:edx = Start offset
    43                              <1> ;       esi:eax = Length of region
    44                              <1> ;Output:    CF=NC: Ok to proceed with locking
    45                              <1> ;               rax = Start byte of lock
    46                              <1> ;               rdx = End byte of lock
    47                              <1> ;               rbp -> MFT we are adding the lock to
    48                              <1> ;           CF=CY: Error!
    49                              <1> ;               ZF=ZE: Lock equals a previous lock
    50                              <1> ;               ZF=NZ: Lock partially overlaps or of 0 length
    51                              <1> ;               rbx -> Lock that we overlap
    52 00000409 85D2                <1>     test edx, edx   ;Ensure the upper 32 bits of edx are zero
    53 0000040B 09C6                <1>     or esi, eax     ;Ditto rax but also check the length is not zero
    54 0000040D 7422                <1>     jz .badExit
    55 0000040F 48C1E11F            <1>     shl rcx, 31     ;Move the argument high
    56 00000413 48C1E61F            <1>     shl rsi, 31     ;Move the argument high
    57 00000417 4809CA              <1>     or rdx, rcx     ;Stick the bits together (no overlap)
    58 0000041A 4809C0              <1>     or rax, rax     ;Stick the bits together (no overlap)
    59 0000041D 4801D0              <1>     add rax, rdx    ;Add the start byte to the length to get first byte free
    60 00000420 48FFC8              <1>     dec rax         ;And now point rax to the last byte in the lock
    61                              <1> ;rdx -> Start byte of lock
    62                              <1> ;rax -> End byte of lock
    63 00000423 488B6F4F            <1>     mov rbp, qword [rdi + sft.pMFT] ;Get the mft ptr
    64 00000427 31C9                <1>     xor ecx, ecx
    65 00000429 FFC1                <1>     inc ecx     ;Check all locks for overlap
    66 0000042B E80A000000          <1>     call checkLockOverlap   ;Preserves everything
    67                              <1>     return
    13                              <2> %%_ret:
    14 00000430 C3                  <2>  ret
    15                              <2> %assign retOff %%_ret-$$
    68                              <1> .badExit:
    69 00000431 B821000000          <1>     mov eax, errLokVio
    70 00000436 85C0                <1>     test eax, eax   ;Clear the ZF flag
    71 00000438 F9                  <1>     stc             ;And set CF
    72                              <1>     return
    13                              <2> %%_ret:
    14 00000439 C3                  <2>  ret
    15                              <2> %assign retOff %%_ret-$$
    73                              <1> 
    74                              <1> checkLockOverlap:
    75                              <1> ;Input: rax = Start byte to check
    76                              <1> ;       rdx = End byte to check
    77                              <1> ;       rbp -> MFT to start searching 
    78                              <1> ;       ecx = 0: Do not check locks belonging to currentSFT, dMID, qPID
    79                              <1> ;           = 1: Check all locks
    80                              <1> ;Output: CF=NC: No overlap!
    81                              <1> ;           rbx = Trashed (Null)
    82                              <1> ;        CF=CY: Overlap!
    83                              <1> ;           ZF=ZE: Lock region matched exactly
    84                              <1> ;           ZF=NZ: Lock region not matched exactly
    85                              <1> ;           rbx -> Lock we matched to
    86 0000043A 56                  <1>     push rsi
    87 0000043B 488B5D06            <1>     mov rbx, qword [rbp + mft.pLock]
    88                              <1> .lockLp:
    89 0000043F 4885DB              <1>     test rbx, rbx
    90 00000442 7452                <1>     jz .exit
    91 00000444 85C9                <1>     test ecx, ecx   ;Check if we may skip this lock?
    92 00000446 752F                <1>     jnz .doLock
    93                              <1> ;Now we check that this lock isnt the same as the current SFT, qPID and dMID.
    94                              <1> ;If any are not equal, we do the lock. If they are all the same, skip.
    95                              <1> ;Check currentSFT
    96 00000448 498BB063070000      <1>     mov rsi, qword [r8 + currentSFT]
    97 0000044F 48397318            <1>     cmp qword [rbx + fileLock.pSFT], rsi
    98 00000453 7522                <1>     jne .doLock
    99                              <1> ;Check qPID
   100 00000455 488B7320            <1>     mov rsi, qword [rbx + fileLock.qPID]    
   101 00000459 493BB06B040000      <1>     cmp rsi, qword [r8 + qPID]
   102 00000460 7515                <1>     jne .doLock
   103                              <1> ;Check dMID
   104 00000462 488B7318            <1>     mov rsi, qword [rbx + fileLock.pSFT]
   105 00000466 8B7643              <1>     mov esi, dword [rsi + sft.dMID]
   106 00000469 413BB073040000      <1>     cmp esi, dword [r8 + dMID]
   107 00000470 7505                <1>     jne .doLock
   108                              <1> ;If all three were equal, skip this lock!
   109                              <1> .nextLock:
   110 00000472 488B1B              <1>     mov rbx, qword [rbx + fileLock.pNext]  ;Go to next lock in chain
   111 00000475 EBC8                <1>     jmp short .lockLp
   112                              <1> .doLock:
   113                              <1> ;Input: rbx -> filelock to check on
   114                              <1> ;       rax -> Start byte to check
   115                              <1> ;       rdx -> End byte to check
   116 00000477 483B4310            <1>     cmp rax, qword [rbx + fileLock.qEnd]
   117 0000047B 77F5                <1>     ja .nextLock    ;If start is past the end, immediately check next!
   118 0000047D 483B5308            <1>     cmp rdx, qword [rbx + fileLock.qStart]
   119 00000481 72EF                <1>     jb .nextLock    ;If end is below the start, immediately check next!
   120                              <1> ;Now we check that we are not overlapping
   121 00000483 483B4308            <1>     cmp rax, qword [rbx + fileLock.qStart]
   122 00000487 7306                <1>     jae .overlap
   123 00000489 483B5310            <1>     cmp rdx, qword [rbx + fileLock.qEnd]
   124 0000048D 77E3                <1>     ja .nextLock
   125                              <1> .overlap:
   126                              <1> ;Here we have an overlap. Check if it is exact.
   127 0000048F 7504                <1>     jnz .ovlpExit   ;This check had to have been equal to be exact
   128 00000491 483B4308            <1>     cmp rax, qword [rbx + fileLock.qStart]  ;Keeps ZF set if equal
   129                              <1> .ovlpExit:
   130 00000495 F9                  <1>     stc
   131                              <1> .exit:
   132 00000496 5E                  <1>     pop rsi
   133                              <1>     return
    13                              <2> %%_ret:
    14 00000497 C3                  <2>  ret
    15                              <2> %assign retOff %%_ret-$$
   134                              <1> 
   135                              <1> getFreeLock:
   136                              <1> ;Gets a free lock.
   137                              <1> ;Output: CF=NC: rsi -> Lock
   138                              <1> ;        CF=CY: No more locks
   139 00000498 488B35(14000000)    <1>     mov rsi, qword [pFreeLock]
   140 0000049F 4885F6              <1>     test rsi, rsi
   141 000004A2 740C                <1>     jz .noMoreLocks
   142 000004A4 488B0E              <1>     mov rcx, qword [rsi + fileLock.pNext]   ;Move next entry to the head
   143 000004A7 48890D(14000000)    <1>     mov qword [pFreeLock], rcx
   144 000004AE F8                  <1>     clc
   145                              <1>     return
    13                              <2> %%_ret:
    14 000004AF C3                  <2>  ret
    15                              <2> %assign retOff %%_ret-$$
   146                              <1> .noMoreLocks:
   147 000004B0 B824000000          <1>     mov eax, errShrFul
   148 000004B5 F9                  <1>     stc
   149                              <1>     return
    13                              <2> %%_ret:
    14 000004B6 C3                  <2>  ret
    15                              <2> %assign retOff %%_ret-$$
