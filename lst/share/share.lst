   340                              <1> ;A lock is ours if the SFT pointer of the lock matches our SFT pointer in rdi
   341 0000063F 48397E18            <1>     cmp qword [rsi + fileLock.pSFT], rdi    ;Is the SFT ours?
   342 00000643 7536                <1>     jne .nextLock   ;If not, skip
   343 00000645 85D2                <1>     test edx, edx   ;If it is but we dont care for process ID, skip this
   344 00000647 7418                <1>     jz .skipProcess
   345                              <1> ;Now check this lock belongs to this process too
   346 00000649 4150                <1>     push r8
   347 0000064B 4C8B05(26000000)    <1>     mov r8, qword [pDosseg]
   348 00000652 498B806B040000      <1>     mov rax, qword [r8 + qPID]  ;Get the process id
