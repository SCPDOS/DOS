   757                              <1> closeJFTEntries:
   758                              <1> ;Closes all JFT entries pointing to a particular SFT for a process.
   759                              <1> ;Input: bl = SFTIndex
   760                              <1> ;       rax = PID
   761                              <1> ;Output: Closes all JFT entries.
   762                              <1> ;Preserves all registers
   763 000008F5 50                  <1>     push rax
   764 000008F6 E82C000000          <1>     call .isPIDSpecial   ;If the PID is special, we just exit.
   765 000008FB 7428                <1>     je .cjeExit2
   766 000008FD 51                  <1>     push rcx
   767 000008FE 57                  <1>     push rdi
   768 000008FF 4889C7              <1>     mov rdi, rax
   769 00000902 0FB74F4E            <1>     movzx ecx, word [rdi + psp.jftSize]   ;Get the size
   770 00000906 488D7F2A            <1>     lea rdi, qword [rdi + psp.jobFileTbl]   ;Point to JFT or JFTptr
   771 0000090A 81F914000000        <1>     cmp ecx, dfltJFTsize
   772 00000910 480F473F            <1>     cmova rdi, qword [rdi]  ;If above normal, pull the JFTPtr
   773 00000914 89D8                <1>     mov eax, ebx    ;Get the SFTIndx to scan for
   774                              <1> .cjeLp:
   775 00000916 F2AE                <1>     repne scasb     ;DOS sets direction so we dont worry
   776 00000918 7508                <1>     jne .cjeExit
   777 0000091A C647FFFF            <1>     mov byte [rdi - 1], -1  ;Free the entry
   778 0000091E 85C9                <1>     test ecx, ecx  ;If we are out of entries, dont reenter loop
   779 00000920 75F4                <1>     jnz .cjeLp
   780                              <1> .cjeExit:
   781 00000922 F8                  <1>     clc
   782 00000923 5F                  <1>     pop rdi
   783 00000924 59                  <1>     pop rcx
   784                              <1> .cjeExit2:
   785 00000925 58                  <1>     pop rax
   786                              <1>     return
