   832 00000960 EBFC                <1>     jmp short .halt ;Infinite loop, await CTRL+ALT+DEL
   833                              <1> .doWrite:
   834                              <1> ;We write directly to the console driver completely bypassing any 
   835                              <1> ;redirection, without resorting to using BIOS functions.
   836                              <1> ;We use the PSP as the buffer for the ioReqPkt.
   837                              <1> ;We obviously do no error checking or Int 24 invokation if things
   838                              <1> ; go wrong with this. 
   839                              <1> ;Input: rdi -> String to print
   840                              <1> ;Output: Hopefully, string printed.
   841 00000962 B812120000          <1>     mov eax, 1212h  ;Do dos strlen
   842 00000967 CD2F                <1>     int 2Fh         ;Get length of string pointed to by rdi in ecx
   843 00000969 FFC9                <1>     dec ecx ;Drop the terminating null from the count
   844                              <1>     retz    ;If this is zero, forget the error
    41                              <2> cret z
