   748                              <1> closeJFTEntries:
   749                              <1> ;Closes all JFT entries pointing to a particular SFT for a process.
   750                              <1> ;Input: bl = SFTIndex
   751                              <1> ;       rax = PID
   752                              <1> ;Output: Closes all JFT entries.
   753                              <1> ;Preserves all registers
   754 000008ED 50                  <1>     push rax
   755 000008EE E82C000000          <1>     call .isPIDSpecial   ;If the PID is special, we just exit.
   756 000008F3 7428                <1>     je .cjeExit2
   757 000008F5 51                  <1>     push rcx
   758 000008F6 57                  <1>     push rdi
   759 000008F7 4889C7              <1>     mov rdi, rax
   760 000008FA 0FB74F4E            <1>     movzx ecx, word [rdi + psp.jftSize]   ;Get the size
   761 000008FE 488D7F2A            <1>     lea rdi, qword [rdi + psp.jobFileTbl]   ;Point to JFT or JFTptr
   762 00000902 81F914000000        <1>     cmp ecx, dfltJFTsize
   763 00000908 480F473F            <1>     cmova rdi, qword [rdi]  ;If above normal, pull the JFTPtr
   764 0000090C 89D8                <1>     mov eax, ebx    ;Get the SFTIndx to scan for
   765                              <1> .cjeLp:
   766 0000090E F2AE                <1>     repne scasb     ;DOS sets direction so we dont worry
   767 00000910 7508                <1>     jne .cjeExit
   768 00000912 C647FFFF            <1>     mov byte [rdi - 1], -1  ;Free the entry
   769 00000916 85C9                <1>     test ecx, ecx  ;If we are out of entries, dont reenter loop
   770 00000918 75F4                <1>     jnz .cjeLp
   771                              <1> .cjeExit:
   772 0000091A F8                  <1>     clc
   773 0000091B 5F                  <1>     pop rdi
   774 0000091C 59                  <1>     pop rcx
   775                              <1> .cjeExit2:
   776 0000091D 58                  <1>     pop rax
   777                              <1>     return
