   734                              <1> findFreeMFT:
   735                              <1> ;Searches for a free MFT of a particular size or greater.
   736                              <1> ;Input: ecx = Minimum MFT size 
   737                              <1> ;Output: CF=NC: rbx -> MFT of appropriate size
   738                              <1> ;        CF=CY: No MFT found of this size. rbx -> End MFT
   739                              <1> ;Trashes rax. All other regs preserved.
   740 000008C0 488B1D(00000000)    <1>     mov rbx, qword [pMftArena]
   741                              <1> .lp:
   742 000008C7 803B00              <1>     cmp byte [rbx + mft.bSig], mftFree
   743 000008CA 7C40                <1>     jl findMFT.noMFT    ;If below, must be mftEnd. Exit error!
   744 000008CC 7506                <1>     jne .next           ;If not equal, must be mftAlloc. Goto next MFT
   745 000008CE 394B01              <1>     cmp dword [rbx + mft.dLen], ecx ;Is this MFT ok sizewise?
   746                              <1>     retnc   ;Not carry means dLen is geq eax, as required
    61                              <2> cret nc
