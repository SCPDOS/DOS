   281 000001F2 7406                <1>     jz .mftNext ;If its free, just goto next MFT
   282 000001F4 7C42                <1>     jl .exitBad ;If we are at the end, exit error!
   283 000001F6 FFCB                <1>     dec ebx     ;Drop one from the count, if zero, we have arrived
   284 000001F8 7408                <1>     jz .goSft
