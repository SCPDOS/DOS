   337                              <1> ;Point rsi such that it is one sft.pNextSFT away from the pointer to
   338                              <1> ; the next SFT
   339 00000612 488D73D3            <1>     lea rsi, qword [rbx + mft.pSFT - sft.pNextSFT]
   340                              <1> .lp:
   341 00000616 4885F6              <1>     test rsi, rsi   ;If we dont find rdi, something has gone terribly wrong
   342 00000619 7425                <1>     jz .crash
   343 0000061B 48397E3B            <1>     cmp qword [rsi + sft.pNextSFT], rdi    ;Is the next SFT us?
   344 0000061F 7406                <1>     je .found
   345 00000621 488B763B            <1>     mov rsi, qword [rsi + sft.pNextSFT] ;Go to next SFT
   346 00000625 EBEF                <1>     jmp short .lp
   347                              <1> .found:
   348                              <1> ;rsi -> Points to the previous SFT in the chain 
   349 00000627 488B473B            <1>     mov rax, qword [rdi + sft.pNextSFT] ;Get our next SFT value
   350 0000062B 4889463B            <1>     mov qword [rsi + sft.pNextSFT], rax ;And set the prev SFT to link over us
   351 0000062F 48C7474F00000000    <1>     mov qword [rdi + sft.pMFT], 0   ;Set pMFT to zero to mean we are done!
   352 00000637 48817B0E00000000    <1>     cmp qword [rbx + mft.pSFT], 0   ;Is the MFT SFT chain ptr 0?
   353                              <1>     return
