   401                              <1> closeRenDel:
   402                              <1> ;On rename/delete/setattr, this function is called to check we can proceed
   403                              <1> ; with the operation.
   404                              <1> ;Finds MFT based on the filename in fname1Ptr in the dosseg
   405                              <1> ;----------------------------------------------------------------------------
   406                              <1> ;Input: fname1Ptr -> Filename to do check on
   407                              <1> ;Output: Nothing
   408                              <1> ;----------------------------------------------------------------------------
   409                              <1> ;If 
   410                              <1> ;   the file is not open, then we return ok.
   411                              <1> ;Else if 
   412                              <1> ;   the file is opened by us uniquely and is open in compatibility mode,
   413                              <1> ;   then close the file and return ok.
   414                              <1> ;Else, we fail.
   415                              <1> ;----------------------------------------------------------------------------
   416 000002E3 4150                <1>     push r8
   417 000002E5 4C8B05(26000000)    <1>     mov r8, qword [pDosseg]
   418 000002EC E80B010000          <1>     call critEnter
   419                              <1> .again:
   420 000002F1 498BB050060000      <1>     mov rsi, qword [r8 + fname1Ptr] ;Get the filename pointer
   421 000002F8 E8B3050000          <1>     call findMFT    ;Looks for this file
   422 000002FD 7237                <1>     jc .exit    ;If the file doesn't exist, exit
   423                              <1> ;File MFT found. rbx -> MFT. 
   424                              <1> ; Now check that all the files on this chain have the mid and pid of 
   425                              <1> ; the requester and (are in compatibility mode or a net SFT).
   426 000002FF 488B730E            <1>     mov rsi, qword [rbx + mft.pSFT] ;This cant be empty so it must be an SFT
   427 00000303 4889F7              <1>     mov rdi, rsi    ;Save this SFT pointer in rdi
   428                              <1> .scanLp:
   429 00000306 418B8073040000      <1>     mov eax, dword [r8 + dMID]
   430 0000030D 3B4643              <1>     cmp eax, dword [rsi + sft.dMID]
   431 00000310 7524                <1>     jne .exit
   432 00000312 498B806B040000      <1>     mov rax, qword [r8 + qPID]
   433 00000319 483B4647            <1>     cmp rax, qword [rsi + sft.qPID]
   434 0000031D 7517                <1>     jne .exit
   435 0000031F 0FB74602            <1>     movzx eax, word [rsi + sft.wOpenMode]
   436 00000323 25F0000000          <1>     and eax, 0F0h    ;Get the sharing mode
   437                              <1> ;If compatibility mode or net fcb, proceed with close
   438 00000328 3D70000000          <1>     cmp eax, openNetFCBShr
   439 0000032D 740F                <1>     je .next
   440 0000032F 3D00000000          <1>     cmp eax, openCompat
   441 00000334 7408                <1>     je .next
   442                              <1> .exit:
   443 00000336 E8CB000000          <1>     call critExit
   444 0000033B 4158                <1>     pop r8
   445                              <1>     return
    13                              <2> %%_ret:
    14 0000033D C3                  <2>  ret
    15                              <2> %assign retOff %%_ret-$$
   446                              <1> .next:
   447 0000033E 488B763B            <1>     mov rsi, qword [rsi + sft.pNextSFT]
   448 00000342 4885F6              <1>     test rsi, rsi
   449 00000345 75BF                <1>     jnz .scanLp
   450                              <1> ;Here we must close all the handles referring to this SFT
   451                              <1> ;rdi -> First SFT 
   452 00000347 4989B863070000      <1>     mov qword [r8 + currentSFT], rdi    ;Set this SFT as current SFT
   453 0000034E E8E0010000          <1>     call closeHandlesForSFT
   454 00000353 E8D3010000          <1>     call closeSFT
   455 00000358 E994FFFFFF          <1>     jmp .again  ;Now do this again until no more files
   456                              <1> 
