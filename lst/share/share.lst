   412                              <1> ;        CF=CY: Sharing violation. eax has error code
   413 000006B4 48817E4F00000000    <1>     cmp qword [rsi + sft.pMFT], 0   ;This SFT better not already be on a chain
   414 000006BC 752E                <1>     jne .crash
