   746                              <1> getNameMeta:
   747                              <1> ;Gets the string length and checksum value
   748                              <1> ;Input: rsi -> String to search on
   749                              <1> ;Output: ecx = String length
   750                              <1> ;        edx = Checksum value
   751                              <1> ;Trashes eax.
   752 000008DD 56                  <1>     push rsi
   753 000008DE 31C9                <1>     xor ecx, ecx    ;Use for string length (zero inclusive)
   754 000008E0 31D2                <1>     xor edx, edx    ;Use for checksum value (dl)
   755                              <1> .metalp:
   756 000008E2 AC                  <1>     lodsb
   757 000008E3 00C2                <1>     add dl, al
   758 000008E5 80D200              <1>     adc dl, 0       ;Add 1 if this rolls over
   759 000008E8 FFC1                <1>     inc ecx
   760 000008EA 84C0                <1>     test al, al
   761 000008EC 75F4                <1>     jnz .metalp
   762 000008EE 5E                  <1>     pop rsi
   763                              <1>     return
