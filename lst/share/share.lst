   579                              <1> getMFT:
   580                              <1> ;Search for an MFT for a file. If one is not found, it creates it.
   581                              <1> ;Input: rsi -> Filename to search for
   582                              <1> ;Output: CF=NC: rbx -> MFT for this file.
   583                              <1> ;        CF=CY: eax = Error code.
   584                              <1> ;Start by working out the string length and checksum values
   585 000007C1 E8E5000000          <1>     call findMFT        ;Sets dl for checksum and ecx for string length
   586                              <1>     retnc
    61                              <2> cret nc
    19                              <3> %%_base:
    20                              <3> %assign baseVar %%_base-$$
    21                              <3> 
    22                              <3> 
    23                              <3> 
    24                              <3> 
    25                              <3> 
    26                              <3> 
    27                              <3> 
    28                              <3> 
    29                              <3> 
