   152                              <1> closeByID:
   153                              <1> ;Closes all files by IDs.
   154                              <1> ;Input: rcx = qPID (or -1 if we are not to use this)
   155                              <1> ;       rdx = dMID
   156                              <1> ;Searches through the MFT heap for allocated MFTs and within them,
   157                              <1> ; frees each SFT which meets the ID requirements
   158 000004B7 4150                <1>     push r8
   159 000004B9 4C8B05(26000000)    <1>     mov r8, qword [pDosseg]
   160 000004C0 488B35(00000000)    <1>     mov rsi, qword [pMftArena]
   161                              <1> .mftLp:
   162 000004C7 8B4601              <1>     mov eax, dword [rsi + mft.dLen]
   163 000004CA 488D3C36            <1>     lea rdi, qword [rsi + rsi]  ;Point rdi to the next MFT if one exists
   164 000004CE 803E00              <1>     cmp byte [rsi + mft.bSig], mftFree
   165 000004D1 724E                <1>     jb .exit
   166 000004D3 7444                <1>     jz .mftNext
   167                              <1> ;Here we have an allocated MFT. Now we go down it's SFT chain freeing
   168                              <1> ; the SFTs as specified
   169 000004D5 488B5E0E            <1>     mov rbx, qword [rsi + mft.pSFT] ;Point rbx to the first SFT
   170                              <1> .sftLp:
   171 000004D9 4885DB              <1>     test rbx, rbx   ;Once we are at the end of the sft chain, goto next MFT
   172 000004DC 743B                <1>     jz .mftNext
   173 000004DE 395343              <1>     cmp dword [rbx + sft.dMID], edx
   174 000004E1 7530                <1>     jne .sftNext
   175 000004E3 4881F9FFFFFFFF      <1>     cmp rcx, -1
   176 000004EA 7427                <1>     je .sftNext
   177 000004EC 48394B47            <1>     cmp qword  [rbx + sft.qPID], rcx
   178 000004F0 7521                <1>     jne .sftNext
   179                              <1> ;Here we have an sft to close. The one in rsi. 
   180 000004F2 488B5B3B            <1>     mov rbx, qword [rbx + sft.pNextSFT] ;Get ptr to next SFT in chain
   181 000004F6 53                  <1>     push rbx
   182 000004F7 51                  <1>     push rcx
   183 000004F8 52                  <1>     push rdx
   184 000004F9 57                  <1>     push rdi
   185 000004FA 4989B063070000      <1>     mov qword [r8 + currentSFT], rsi
   186 00000501 56                  <1>     push rsi    ;Save current SFT we are closing 
   187 00000502 E824000000          <1>     call closeHandlesForSFT
   188 00000507 5F                  <1>     pop rdi
   189 00000508 E816000000          <1>     call closeSFT   ;This wants the ptr in rdi
   190 0000050D 5F                  <1>     pop rdi
   191 0000050E 5A                  <1>     pop rdx
   192 0000050F 59                  <1>     pop rcx
   193 00000510 5B                  <1>     pop rbx
   194 00000511 EBC6                <1>     jmp short .sftLp
   195                              <1> .sftNext:
   196 00000513 488B5B3B            <1>     mov rbx, qword [rbx + sft.pNextSFT]
   197 00000517 EBC0                <1>     jmp short .sftLp
   198                              <1> .mftNext:
   199 00000519 4889FE              <1>     mov rsi, rdi    ;Move rsi to the next MFT
   200 0000051C E9A6FFFFFF          <1>     jmp .mftLp
   201                              <1> .exit:
   202 00000521 F8                  <1>     clc 
   203                              <1>     return
    13                              <2> %%_ret:
    14 00000522 C3                  <2>  ret
    15                              <2> %assign retOff %%_ret-$$
   204                              <1> 
   205                              <1> closeSFT:
   206                              <1> ;Closes current SFT
   207                              <1> ;Input: qword [currentSFT] = SFT to close
   208 00000523 B801120000          <1>     mov eax, 1201h ;Close the currentSFT
   209 00000528 CD2F                <1>     int 2Fh
   210                              <1>     return
    13                              <2> %%_ret:
    14 0000052A C3                  <2>  ret
    15                              <2> %assign retOff %%_ret-$$
   211                              <1> 
   212                              <1> closeHandlesForSFT:
   213                              <1> ;Closes all handles referencing the current SFT
   214                              <1> ;Input: r8 -> DOSSEG
   215                              <1> ;       qword [currentSFT] = SFT to close handles for
   216 0000052B 498BB063070000      <1>     mov rsi, qword [r8 + currentSFT]
   217 00000532 31DB                <1>     xor ebx, ebx
   218                              <1> .sftIndxLp:
   219 00000534 53                  <1>     push rbx
   220 00000535 B816120000          <1>     mov eax, 1216h  ;Get SFT Ptr from SFT Index into rdi
   221 0000053A CD2F                <1>     int 2Fh
   222 0000053C 5B                  <1>     pop rbx
   223 0000053D FFC3                <1>     inc ebx
   224 0000053F 4839FE              <1>     cmp rsi, rdi    ;Was this index correct?
   225 00000542 75F0                <1>     jne .sftIndxLp
   226 00000544 FFCB                <1>     dec ebx         ;Decrement it back, we are looking for this number
   227                              <1> ;Now we walk the Arena Chain to find every task ID and close the
   228                              <1> ; JFT entry for this file if the SFTIndex exists in that task's JFT
   229 00000546 31C0                <1>     xor eax, eax    ;Zero to give a PID that will not be at the start
   230 00000548 498B783B            <1>     mov rdi, qword [r8 + mcbChainPtr]   ;Get the MCB chain header in rdi
   231 0000054C EB26                <1>     jmp short .checkMCB ;Make sure this MCB is a valid MCB
   232                              <1> .mcbLp:
   233 0000054E 483B4701            <1>     cmp rax, qword [rdi + mcb.owner]    ;If new PID same as before, skip
   234 00000552 7409                <1>     je .getNextMCB
   235 00000554 488B4701            <1>     mov rax, qword [rdi + mcb.owner]    ;Else, get the new PID
   236 00000558 E890030000          <1>     call closeJFTEntries    ;Close all JFT entries for this process
   237                              <1> .getNextMCB:
   238 0000055D 803F5A              <1>     cmp byte [rdi + mcb.marker], mcbMarkEnd ;If we processed end block, exit
   239                              <1>     rete
