   396 00000698 488B05(14000000)    <1>     mov rax, qword [pFreeLock]              ;Get head of the free lock list
   397 0000069F 488906              <1>     mov qword [rsi + fileLock.pNext], rax   ;Link rsi to the head of free list
   398 000006A2 488935(14000000)    <1>     mov qword [pFreeLock], rsi              ;Make rsi the head of the free list
   399 000006A9 4889DE              <1>     mov rsi, rbx    ;Start from previous lock in the list again.
   400                              <1> .nextLock:
   401 000006AC 4889F3              <1>     mov rbx, rsi    ;Point rsi to this filelock
   402 000006AF 488B36              <1>     mov rsi, qword [rsi + fileLock.pNext]   ;Get next file lock
   403 000006B2 EBB6                <1>     jmp short .lp
