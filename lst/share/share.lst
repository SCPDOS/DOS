   590                              <1> .open:
   591                              <1> ;Here we handle new file opens! Copies data from the 
   592                              <1> ; topmost (last opened) SFT (rsi) of the SFT chain into 
   593                              <1> ; the newly opened SFT (rdi)
   594 000003D7 8B4613              <1>     mov eax, dword [rsi + sft.dTimeDate]
   595 000003DA 894713              <1>     mov dword [rdi + sft.dTimeDate], eax
   596 000003DD 8B4617              <1>     mov eax, dword [rsi + sft.dFileSize]
   597 000003E0 894717              <1>     mov dword [rdi + sft.dFileSize], eax
   598 000003E3 8B460F              <1>     mov eax, dword [rsi + sft.dStartClust]
   599 000003E6 89470F              <1>     mov dword [rdi + sft.dStartClust], eax
   600 000003E9 894723              <1>     mov dword [rdi + sft.dAbsClust], eax
   601 000003EC C7471F00000000      <1>     mov dword [rdi + sft.dRelClust], 0
   602 000003F3 EBA2                <1>     jmp short .exit
