   295                              <1> removeSFTfromMFT:
   296                              <1> ;Removes the SFT from the MFT's SFT chain.
   297                              <1> ;Input: rdi -> SFT we are closing.
   298                              <1> ;Output: ZF=ZE: No more files on MFT
   299                              <1> ;        ZF=NZ: More files on MFT.
   300                              <1> ;           rbx -> MFT for this file
   301                              <1> ;Trashes rax and rsi.
   302 000005DD 488B5F4F            <1>     mov rbx, qword [rdi + sft.pMFT] ;Get the MFT pointer
   303                              <1> ;Point rsi to the such that it is one sft.pNextSFT away from the pointer to
   304                              <1> ; the next SFT
   305 000005E1 488D73D3            <1>     lea rsi, qword [rbx + mft.pSFT - sft.pNextSFT]
   306                              <1> .lp:
   307 000005E5 4885F6              <1>     test rsi, rsi   ;If we dont find rdi, something has gone terribly wrong
   308 000005E8 7425                <1>     jz .crash
   309 000005EA 48397E3B            <1>     cmp qword [rsi + sft.pNextSFT], rdi    ;Is the next SFT us?
   310 000005EE 7406                <1>     je .found
   311 000005F0 488B763B            <1>     mov rsi, qword [rsi + sft.pNextSFT] ;Go to next SFT
   312 000005F4 EBEF                <1>     jmp short .lp
   313                              <1> .found:
   314                              <1> ;rsi -> Points to the previous SFT in the chain 
   315 000005F6 488B473B            <1>     mov rax, qword [rdi + sft.pNextSFT] ;Get our next SFT value
   316 000005FA 4889463B            <1>     mov qword [rsi + sft.pNextSFT], rax ;And set the prev SFT to link over us
   317 000005FE 48C7474F00000000    <1>     mov qword [rdi + sft.pMFT], 0   ;Set pMFT to zero to mean we are done!
   318 00000606 48817B0E00000000    <1>     cmp qword [rbx + mft.pSFT], 0   ;Is the MFT SFT chain ptr 0?
   319                              <1>     return
