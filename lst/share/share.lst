   157                              <1> closeByID:
   158                              <1> ;Closes all files by IDs.
   159                              <1> ;Input: rcx = qPID (or -1 if we are not to use this)
   160                              <1> ;       rdx = dMID
   161                              <1> ;Searches through the MFT heap for allocated MFTs and within them,
   162                              <1> ; frees each SFT which meets the ID requirements
   163 000004BD 4150                <1>     push r8
   164 000004BF 4C8B05(26000000)    <1>     mov r8, qword [pDosseg]
   165 000004C6 488B35(00000000)    <1>     mov rsi, qword [pMftArena]
   166                              <1> .mftLp:
   167 000004CD 8B4601              <1>     mov eax, dword [rsi + mft.dLen]
   168 000004D0 488D3C06            <1>     lea rdi, qword [rsi + rax]  ;Point rdi to the next MFT if one exists
   169 000004D4 803E00              <1>     cmp byte [rsi + mft.bSig], mftFree
   170 000004D7 724E                <1>     jb .exit
   171 000004D9 7444                <1>     jz .mftNext
   172                              <1> ;Here we have an allocated MFT. Now we go down it's SFT chain freeing
   173                              <1> ; the SFTs as specified
   174 000004DB 488B5E0E            <1>     mov rbx, qword [rsi + mft.pSFT] ;Point rbx to the first SFT
   175                              <1> .sftLp:
   176 000004DF 4885DB              <1>     test rbx, rbx   ;Once we are at the end of the sft chain, goto next MFT
   177 000004E2 743B                <1>     jz .mftNext
   178 000004E4 395343              <1>     cmp dword [rbx + sft.dMID], edx
   179 000004E7 7530                <1>     jne .sftNext
   180 000004E9 4881F9FFFFFFFF      <1>     cmp rcx, -1 ;If -1, then just equal dMID suffices. Close this SFT
   181 000004F0 7406                <1>     je .sftGo
   182 000004F2 48394B47            <1>     cmp qword [rbx + sft.qPID], rcx
   183 000004F6 7521                <1>     jne .sftNext
   184                              <1> .sftGo:
   185                              <1> ;Here we have an sft to close. The one in rsi. 
   186 000004F8 49899863070000      <1>     mov qword [r8 + currentSFT], rbx    ;Set the current SFT as rbx
   187 000004FF FF733B              <1>     push qword [rbx + sft.pNextSFT] ;Save the ptr to next SFT in chain
   188 00000502 51                  <1>     push rcx    ;Save the qPID (or -1 signature) for checking
   189 00000503 52                  <1>     push rdx    ;Save the dMID for checking
   190 00000504 56                  <1>     push rsi    ;Save the current MFT we are processing
   191 00000505 57                  <1>     push rdi    ;Save the next MFT
   192 00000506 53                  <1>     push rbx    ;Save current SFT we are closing 
   193 00000507 E827000000          <1>     call closeHandlesForSFT
   194 0000050C 5F                  <1>     pop rdi     ;Get the current SFT we are closing into rdi for the close
   195 0000050D E819000000          <1>     call closeSFT   ;This might delete the current MFT...
   196 00000512 5F                  <1>     pop rdi     ;Get the next MFT
   197 00000513 5E                  <1>     pop rsi     ;Get the current MFT (might be invalid now)
   198 00000514 5A                  <1>     pop rdx     ;Get the dMID
   199 00000515 59                  <1>     pop rcx     ;Get the qPID (or -1 signature)
   200 00000516 5B                  <1>     pop rbx     ;Get the ptr to the next SFT in the chain (might be null)
   201 00000517 EBC6                <1>     jmp short .sftLp
   202                              <1> .sftNext:
   203 00000519 488B5B3B            <1>     mov rbx, qword [rbx + sft.pNextSFT]
   204 0000051D EBC0                <1>     jmp short .sftLp
   205                              <1> .mftNext:
   206 0000051F 4889FE              <1>     mov rsi, rdi    ;Move rsi to the next MFT
   207 00000522 E9A6FFFFFF          <1>     jmp .mftLp
   208                              <1> .exit:
   209 00000527 4158                <1>     pop r8
   210 00000529 F8                  <1>     clc 
   211                              <1>     return
    13                              <2> %%_ret:
    14 0000052A C3                  <2>  ret
    15                              <2> %assign retOff %%_ret-$$
   212                              <1> 
   213                              <1> closeSFT:
   214                              <1> ;Closes current SFT
   215                              <1> ;Input: qword [currentSFT] = SFT to close
   216 0000052B B801120000          <1>     mov eax, 1201h ;Close the currentSFT
   217 00000530 CD2F                <1>     int 2Fh
   218                              <1>     return
    13                              <2> %%_ret:
    14 00000532 C3                  <2>  ret
    15                              <2> %assign retOff %%_ret-$$
   219                              <1> 
   220                              <1> closeHandlesForSFT:
   221                              <1> ;Closes all handles referencing the current SFT
   222                              <1> ;Input: r8 -> DOSSEG
   223                              <1> ;       qword [currentSFT] = SFT to close handles for
   224                              <1> ;rdx, rbp and r8 saved. All other regs trashed.
   225 00000533 498BB063070000      <1>     mov rsi, qword [r8 + currentSFT]
   226 0000053A 31DB                <1>     xor ebx, ebx
   227                              <1> .sftIndxLp:
   228 0000053C 53                  <1>     push rbx
   229 0000053D B816120000          <1>     mov eax, 1216h  ;Get SFT Ptr from SFT Index into rdi
   230 00000542 CD2F                <1>     int 2Fh
   231 00000544 5B                  <1>     pop rbx
   232 00000545 FFC3                <1>     inc ebx
   233 00000547 4839FE              <1>     cmp rsi, rdi    ;Was this index correct?
   234 0000054A 75F0                <1>     jne .sftIndxLp
   235 0000054C FFCB                <1>     dec ebx         ;Decrement it back, we are looking for this number
   236                              <1> ;Now we walk the Arena Chain to find every task ID and close the
   237                              <1> ; JFT entry for this file if the SFTIndex exists in that task's JFT
   238 0000054E 31C0                <1>     xor eax, eax    ;Zero to give a PID that will not be at the start
   239 00000550 498B783B            <1>     mov rdi, qword [r8 + mcbChainPtr]   ;Get the MCB chain header in rdi
   240 00000554 EB26                <1>     jmp short .checkMCB ;Make sure this MCB is a valid MCB
   241                              <1> .mcbLp:
   242 00000556 483B4701            <1>     cmp rax, qword [rdi + mcb.owner]    ;If new PID same as before, skip
   243 0000055A 7409                <1>     je .getNextMCB
   244 0000055C 488B4701            <1>     mov rax, qword [rdi + mcb.owner]    ;Else, get the new PID
   245 00000560 E890030000          <1>     call closeJFTEntries    ;Close all JFT entries for this process
   246                              <1> .getNextMCB:
   247 00000565 803F5A              <1>     cmp byte [rdi + mcb.marker], mcbMarkEnd ;If we processed end block, exit
   248                              <1>     rete
    49                              <2> cret e
