   257                              <1> ;Else, goto next block
   258 00000566 8B4F09              <1>     mov ecx, dword [rdi + mcb.blockSize]    ;Get size of block in paras
   259 00000569 48C1E104            <1>     shl rcx, 4      ;Turn into bytes
   260 0000056D 4881C110000000      <1>     add rcx, mcb_size
   261 00000574 4801CF              <1>     add rdi, rcx    ;Go to next MCB
   262                              <1> .checkMCB:
   263 00000577 8A0F                <1>     mov cl, byte [rdi + mcb.marker] ;Now check the new MCB is valid
   264 00000579 80F95A              <1>     cmp cl, mcbMarkEnd
