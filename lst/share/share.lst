   622                              <1> defragMFTArena:
   623                              <1> ;Defragments the MFT arena. Moves all allocated MFTs to the start.
   624                              <1> ;Creates a single large free MFT from all the free space.
   625                              <1> ;Input: Nothing
   626                              <1> ;Output: MFT defragged. rbx -> New free MFT, eax = New Free MFT size
   627                              <1> ; All other regs preserved.
   628 00000827 51                  <1>     push rcx
   629 00000828 52                  <1>     push rdx
   630 00000829 56                  <1>     push rsi
   631 0000082A 57                  <1>     push rdi
   632                              <1> ;rsi = Read pointer
   633                              <1> ;rdi = Write pointer
   634                              <1> ;edx = Free space accumulator
   635 0000082B 488B35(00000000)    <1>     mov rsi, qword [pMftArena]
   636 00000832 4889F7              <1>     mov rdi, rsi
   637 00000835 31D2                <1>     xor edx, edx
   638                              <1> .lp:
   639                              <1> ;If we encounter an allocated mft, we move it over, moving the 
   640                              <1> ; the read and write pointers. If we encounter a free mft, we add its
   641                              <1> ; size and move the read pointer.
   642 00000837 803E00              <1>     cmp byte [rsi + mft.bSig], mftFree
   643 0000083A 7826                <1>     js .exit    ;At this point, all compression is done. Goto end
   644 0000083C 741A                <1>     je .free
   645                              <1> ;Here we copy over. Before we do, we walk down the SFT chain
   646                              <1> ; updating the MFT pointer in each SFT.
   647                              <1> ;rsi -> Allocated MFT
   648                              <1> ;rdi -> Where this MFT will be moved to
   649 0000083E 488B5E0E            <1>     mov rbx, qword [rsi + mft.pSFT]     ;Point rbx to the first SFT in chain.
   650                              <1> .sftLp:
   651 00000842 4885DB              <1>     test rbx, rbx   ;End of SFT chain?
   652 00000845 740A                <1>     jz .sftEnd
   653 00000847 48897B4F            <1>     mov qword [rbx + sft.pMFT], rdi     ;Update the SFT's MFT pointer
   654 0000084B 488B5B3B            <1>     mov rbx, qword [rbx + sft.pNextSFT]
   655 0000084F EBF1                <1>     jmp short .sftLp
   656                              <1> .sftEnd:
   657                              <1> ;All SFTs updated, now we copy the MFT up.
   658 00000851 8B4E01              <1>     mov ecx, dword [rsi + mft.dLen] ;Get the length of this MFT
   659 00000854 F3A4                <1>     rep movsb   ;Moves both pointers to the end of the MFT
   660                              <1> ;Now rdi points to the next write space and rsi points to the next MFT
   661 00000856 EBDF                <1>     jmp short .lp
   662                              <1> .free:
   663                              <1> ;Dont worry about overflow. Max dLen is 1Mb, way less than 32 bit max.
   664 00000858 8B4601              <1>     mov eax, dword [rsi + mft.dLen] ;Get the length
   665 0000085B 01C2                <1>     add edx, eax    ;Add to the free space accumulator
   666 0000085D 4801C6              <1>     add rsi, rax    ;Move the read pointer past this free space
   667 00000860 EBD5                <1>     jmp short .lp
   668                              <1> .exit:
   669                              <1> ;Now we must make a single free MFT at the write pointer with the 
   670                              <1> ; correct size and assert it is correct
   671                              <1> ;rdi -> Where to make this MFT
   672                              <1> ;edx = Accumulated free space
   673 00000862 C60700              <1>     mov byte [rdi + mft.bSig], mftFree
   674 00000865 895701              <1>     mov dword [rdi + mft.dLen], edx
   675 00000868 89D0                <1>     mov eax, edx    ;Get the free MFT size into eax
   676 0000086A 4889FB              <1>     mov rbx, rdi    ;Get the free MFT pointer into rbx
   677 0000086D 4801D7              <1>     add rdi, rdx    ;Now check the MFT chain is not corrupted
   678 00000870 803FFF              <1>     cmp byte [rdi + mft.bSig], mftEnd
   679 00000873 7505                <1>     jne .crash
   680 00000875 5F                  <1>     pop rdi
   681 00000876 5E                  <1>     pop rsi
   682 00000877 5A                  <1>     pop rdx
   683 00000878 59                  <1>     pop rcx
   684                              <1>     return
    13                              <2> %%_ret:
    14 00000879 C3                  <2>  ret
    15                              <2> %assign retOff %%_ret-$$
   685                              <1> .crash:
   686 0000087A E8D2000000          <1>     call errPrintAndHalt    ;No return. Use call to push string ptr to stack
   687 0000087F 4D4654204445465241- <1>     db "MFT DEFRAG FAILURE",CR,LF,NUL
