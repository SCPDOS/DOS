   765                              <1> closeJFTEntries:
   766                              <1> ;Closes all JFT entries pointing to a particular SFT for a process.
   767                              <1> ;Input: bl = SFTIndex
   768                              <1> ;       rax = PID
   769                              <1> ;Output: Closes all JFT entries.
   770                              <1> ;Preserves all registers
   771 000008F0 50                  <1>     push rax
   772 000008F1 E82C000000          <1>     call .isPIDSpecial   ;If the PID is special, we just exit.
   773 000008F6 7428                <1>     je .cjeExit2
   774 000008F8 51                  <1>     push rcx
   775 000008F9 57                  <1>     push rdi
   776 000008FA 4889C7              <1>     mov rdi, rax
   777 000008FD 0FB74F4E            <1>     movzx ecx, word [rdi + psp.jftSize]   ;Get the size
   778 00000901 488D7F2A            <1>     lea rdi, qword [rdi + psp.jobFileTbl]   ;Point to JFT or JFTptr
   779 00000905 81F914000000        <1>     cmp ecx, dfltJFTsize
   780 0000090B 480F473F            <1>     cmova rdi, qword [rdi]  ;If above normal, pull the JFTPtr
   781 0000090F 89D8                <1>     mov eax, ebx    ;Get the SFTIndx to scan for
   782                              <1> .cjeLp:
   783 00000911 F2AE                <1>     repne scasb     ;DOS sets direction so we dont worry
   784 00000913 7508                <1>     jne .cjeExit
   785 00000915 C647FFFF            <1>     mov byte [rdi - 1], -1  ;Free the entry
   786 00000919 85C9                <1>     test ecx, ecx  ;If we are out of entries, dont reenter loop
   787 0000091B 75F4                <1>     jnz .cjeLp
   788                              <1> .cjeExit:
   789 0000091D F8                  <1>     clc
   790 0000091E 5F                  <1>     pop rdi
   791 0000091F 59                  <1>     pop rcx
   792                              <1> .cjeExit2:
   793 00000920 58                  <1>     pop rax
   794                              <1>     return
