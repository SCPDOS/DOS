   447                              <1> dirUpdate:      
   448                              <1> ;Update dir info across all SFTs for a file. 
   449                              <1> ;----------------------------------------------------------------------------
   450                              <1> ;Input: rdi -> SFT to update dir entry from
   451                              <1> ;       eax = 0: Update the date/time fields only
   452                              <1> ;           = 1: Update size fields for growth
   453                              <1> ;           = 2: Update size fields for shrink (i.e. truncate/open calls)
   454                              <1> ;           = 3: Update all fields
   455                              <1> ;Output: Nothing, all SFTs in MFT chain updated.
   456                              <1> ;        rax and rcx trashed.
   457                              <1> ;----------------------------------------------------------------------------
   458                              <1> ; If rdi is a chardev or a redir file, return
   459                              <1> ; Get MFT pointer. 
   460                              <1> ; If 
   461                              <1> ;   MFT pointer is null, return.
   462                              <1> ; Else
   463                              <1> ;   Get first SFT pointer from MFT into rsi   
   464                              <1> ; If eax = 0:
   465                              <1> ;   Walk the SFT chain along rsi updating date/time fields except for us.
   466                              <1> ; Else if eax = 1:
   467                              <1> ;   Walk the SFT chain along rsi updating dFileSize and dStartClust fields 
   468                              <1> ;   except for us.
   469                              <1> ; Else if eax = 2:
   470                              <1> ;   Walk the SFT chain along rsi updating dFileSize, dStartClust and 
   471                              <1> ;   setting dRelClust to 0 and dAbsClust to dStartClust except for us.
   472                              <1> ; Else if eax = 3:
   473                              <1> ;   Update date/time and dFileSize, dStartClust, dRelClust and dAbsClust 
   474                              <1> ;   fields for us from the oldest SFT in the SFT chain for this MFT. 
   475                              <1> ;   
   476                              <1> ; Return.
   477                              <1> ;**** Note ****
   478                              <1> ;In open and shrink we reset dRelClust to 0 and dAbsClust to dStartClust
   479                              <1> ;to signify that all file IO should start from the start of the file.
   480                              <1> ;This is a future optimisation as right now, the DOS kernel never depends 
   481                              <1> ;on these values. These values are however correctly synchronised on each
   482                              <1> ;read/write so in the future, we can relatively easily add a check to make
   483                              <1> ;use of these values, unless they are at the start of the file at which
   484                              <1> ;case we use the current algorithms.
   485                              <1> ;----------------------------------------------------------------------------
   486 00000356 66F747058080        <1>     test word [rdi + sft.wDeviceInfo], devCharDev | devRedir
   487                              <1>     retnz
    45                              <2> cret nz
