    14 0000036E C3                  <4>  ret
    15                              <4> %assign retOff %%_ret-$$
    36                              <3> %%a:
    37                              <3> 
   540 0000036F 51                  <1>     push rcx
   541 00000370 56                  <1>     push rsi
   542 00000371 488B774F            <1>     mov rsi, qword [rdi + sft.pMFT] ;Get MFT pointer in rsi
   543 00000375 4885F6              <1>     test rsi, rsi   ;If this is a null pointer, return
