    52                                  %include "./src/share/text/shutils.asm"
     1                              <1> ;-----------------------------------------------------------------------------
     2                              <1> ;All utility functions go here, in order.
     3                              <1> ;-----------------------------------------------------------------------------
     4                              <1> ; critEnter -> Enters a DOS 1 critical section
     5                              <1> ; critExit -> Exits a DOS 1 critical section
     6                              <1> ; lockPreamble -> Sets up the registers for set/clear flock
     7                              <1> ; checkLockOverlap -> Checks if a lock with the given bounds exists
     8                              <1> ; getFreeLock -> Removes a free lock from the free lock list
     9                              <1> ; closeByID -> Closses all files according to IDs
    10                              <1> ; closeSFT -> Wrapper for Close SFT
    11                              <1> ; closeHandlesForSFT -> Closes handles referencing an SFT
    12                              <1> ; freeMFT -> Frees an MFT from the MFT arena
    13                              <1> ; removeSFTfromMFT -> Removes an SFT from an MFT's SFT chain
    14                              <1> ; freeLocks -> Frees all file locks associated to a SFT
    15                              <1> ; addSFTtoMFT -> Adds an SFT to its MFT chain.
    16                              <1> ; getMFT -> Gets an MFT for a given filename. Creates if it has to.
    17                              <1> ; defragMFTArena -> Defragments the MFT arena
    18                              <1> ; findFreeMFT -> Finds a free MFT for a given size
    19                              <1> ; findMFT -> Find an MFT for a given filename
    20                              <1> ; getNameMeta -> Computes the length and checksum of a filename
    21                              <1> ; closeJFTentries -> Closes all JFT entries pointing to a 
    22                              <1> ;                       particular SFT for a process.
    23                              <1> ; errPrintAndHalt -> Prints a formatted error message and halts the machine
    24                              <1> ;-----------------------------------------------------------------------------
    25                              <1> 
    26                              <1> 
    27                              <1> critEnter:
    28 00000405 50                  <1>     push rax
    29 00000406 B801800000          <1>     mov eax, 8001h  ;Enter DOS Level 1 critical section
    30 0000040B CD2A                <1>     int 2ah
    31 0000040D 58                  <1>     pop rax
    32                              <1>     return
    13                              <2> %%_ret:
    14 0000040E C3                  <2>  ret
    15                              <2> %assign retOff %%_ret-$$
    33                              <1> critExit:
    34 0000040F 50                  <1>     push rax
    35 00000410 B801810000          <1>     mov eax, 8101h  ;Exit DOS Level 1 critical section
    36 00000415 CD2A                <1>     int 2ah
    37 00000417 58                  <1>     pop rax
    38                              <1>     return
    13                              <2> %%_ret:
    14 00000418 C3                  <2>  ret
    15                              <2> %assign retOff %%_ret-$$
    39                              <1> 
    40                              <1> lockPreamble:
    41                              <1> ;Sets up the regs for the lock/unlock operation
    42                              <1> ;Input: rdi -> SFT for file
    43                              <1> ;       ecx:edx = Start offset
    44                              <1> ;       esi:eax = Length of region
    45                              <1> ;Output:    CF=NC: Ok to proceed with locking
    46                              <1> ;               rax = Start byte of lock
    47                              <1> ;               rdx = End byte of lock
    48                              <1> ;               rbp -> MFT we are adding the lock to
    49                              <1> ;               rbx = rdi = Trashed
    50                              <1> ;           CF=CY: Error!
    51                              <1> ;               ZF=ZE: Lock equals a previous lock
    52                              <1> ;                   rbx -> Lock we matched to
    53                              <1> ;                   rdi -> Lock pointing to rbx
    54                              <1> ;               ZF=NZ: Lock partially overlaps or of 0 length
    55                              <1> ;           No register guarantee in this error condition.
    56                              <1> ;ecx and esi trashed. All other registers ok.
    57 00000419 48C1E620            <1>     shl rsi, 32     ;Move the high bits of length high
    58 0000041D 4809F0              <1>     or rax, rsi     ;Stick the length bits together w/o overlap
    59 00000420 7419                <1>     jz .badExit     ;If the length is zero, fail the operation
    60 00000422 48C1E120            <1>     shl rcx, 32     ;Move the high bits of the start byte high
    61 00000426 4809CA              <1>     or rdx, rcx     ;Stick the start byte bits together w/o overlap
    62 00000429 4801D0              <1>     add rax, rdx    ;Add the start byte to the length to get first byte free
    63 0000042C 48FFC8              <1>     dec rax         ;And now point rax to the last byte in the lock
    64 0000042F 4892                <1>     xchg rdx, rax   ;And swap em
    65                              <1> ;rax -> Start byte of lock
    66                              <1> ;rdx -> End byte of lock
    67                              <1> ;rsi is now free
    68                              <1> ;rcx is now free
    69 00000431 488B6F4F            <1>     mov rbp, qword [rdi + sft.pMFT] ;Set rbp to the mft to inspect
    70 00000435 31C9                <1>     xor ecx, ecx
    71 00000437 FFC1                <1>     inc ecx     ;Check all locks for overlap
    72 00000439 EB09                <1>     jmp short checkLockOverlap  ;Return through here to save bytes
    73                              <1> .badExit:
    74                              <1> ;We return CF=CY and ZF=NZ if the length was zero! Hence setting the 
    75                              <1> ; error code to have a guaranteed non-zero value to test to clear ZF.
    76 0000043B B821000000          <1>     mov eax, errLokVio
    77 00000440 85C0                <1>     test eax, eax   ;Clear the ZF flag
    78 00000442 F9                  <1>     stc             ;And set CF
    79                              <1>     return
    13                              <2> %%_ret:
    14 00000443 C3                  <2>  ret
    15                              <2> %assign retOff %%_ret-$$
    80                              <1> 
    81                              <1> checkLockOverlap:
    82                              <1> ;Input: rax = Start byte to check
    83                              <1> ;       rdx = End byte to check
    84                              <1> ;       rbp -> MFT to search on
    85                              <1> ;       ecx = 0: Do not check locks belonging to currentSFT, dMID, qPID
    86                              <1> ;           = 1: Check all locks
    87                              <1> ;Output: CF=NC: No overlap!
    88                              <1> ;           rbx = Trashed (Null)
    89                              <1> ;           rdi = Trashed 
    90                              <1> ;        CF=CY: Overlap!
    91                              <1> ;           ZF=ZE: Lock region matched exactly
    92                              <1> ;           ZF=NZ: Lock region not matched exactly
    93                              <1> ;           rbx -> Lock we matched to
    94                              <1> ;           rdi -> Lock pointing to rbx
    95                              <1> ;All other regs preserved
    96 00000444 56                  <1>     push rsi
    97 00000445 488B5D06            <1>     mov rbx, qword [rbp + mft.pLock]
    98 00000449 488D7D06            <1>     lea rdi, qword [rbp + mft.pLock - fileLock.pNext]
    99                              <1> .lockLp:
   100 0000044D 4885DB              <1>     test rbx, rbx
   101 00000450 744D                <1>     jz .exit
   102 00000452 85C9                <1>     test ecx, ecx   ;Check if we must do this lock?
   103 00000454 7532                <1>     jnz .doLock
   104                              <1> ;Now we check that this lock isnt the same as the current SFT, qPID and dMID.
   105                              <1> ;If any are not equal, we do the lock. If they are all the same, skip.
   106                              <1> ;Check currentSFT
   107 00000456 498BB063070000      <1>     mov rsi, qword [r8 + currentSFT]
   108 0000045D 483B7318            <1>     cmp rsi, qword [rbx + fileLock.pSFT]
   109 00000461 7525                <1>     jne .doLock
   110                              <1> ;Check qPID
   111 00000463 488B7320            <1>     mov rsi, qword [rbx + fileLock.qPID]    
   112 00000467 493BB06B040000      <1>     cmp rsi, qword [r8 + qPID]
   113 0000046E 7518                <1>     jne .doLock
   114                              <1> ;Check dMID
   115 00000470 488B7318            <1>     mov rsi, qword [rbx + fileLock.pSFT]
   116 00000474 8B7643              <1>     mov esi, dword [rsi + sft.dMID]
   117 00000477 413BB073040000      <1>     cmp esi, dword [r8 + dMID]
   118 0000047E 7508                <1>     jne .doLock
   119                              <1> ;If all three were equal, skip this lock!
   120                              <1> .nextLock:
   121 00000480 4889DF              <1>     mov rdi, rbx    ;Save ptr to the trailing lock in rdi
   122 00000483 488B1F              <1>     mov rbx, qword [rdi + fileLock.pNext]  ;Go to next lock in chain
   123 00000486 EBC5                <1>     jmp short .lockLp
   124                              <1> .doLock:
   125                              <1> ;Input: rbx -> filelock to check on
   126                              <1> ;       rax -> Start byte to check
   127                              <1> ;       rdx -> End byte to check
   128 00000488 483B4310            <1>     cmp rax, qword [rbx + fileLock.qEnd]
   129 0000048C 77F2                <1>     ja .nextLock    ;If start is past the end, immediately check next!
   130 0000048E 483B5308            <1>     cmp rdx, qword [rbx + fileLock.qStart]
   131 00000492 72EC                <1>     jb .nextLock    ;If end is below the start, immediately check next!
   132                              <1> ;Thus there must be some overlap! Check if exact
   133 00000494 483B4308            <1>     cmp rax, qword [rbx + fileLock.qStart]
   134 00000498 7504                <1>     jne .ovlpExit
   135 0000049A 483B5310            <1>     cmp rdx, qword [rbx + fileLock.qEnd]    ;Keeps ZF set if equal  
   136                              <1> .ovlpExit:
   137 0000049E F9                  <1>     stc
   138                              <1> .exit:
   139 0000049F 5E                  <1>     pop rsi
   140                              <1>     return
    13                              <2> %%_ret:
    14 000004A0 C3                  <2>  ret
    15                              <2> %assign retOff %%_ret-$$
   141                              <1> 
   142                              <1> getFreeLock:
   143                              <1> ;Gets a free lock and removes it from the free lock list.
   144                              <1> ;Does not allocate it yet though and it remains in rsi.
   145                              <1> ;Output: CF=NC: rsi -> Lock
   146                              <1> ;        CF=CY: No more locks
   147 000004A1 488B35(14000000)    <1>     mov rsi, qword [pFreeLock]
   148 000004A8 4885F6              <1>     test rsi, rsi
   149 000004AB 740A                <1>     jz .noMoreLocks
   150 000004AD FF36                <1>     push qword [rsi + fileLock.pNext]   ;Move next entry of free list...
   151 000004AF 8F05(14000000)      <1>     pop qword [pFreeLock]   ;... onto the head of the list.
   152 000004B5 F8                  <1>     clc
   153                              <1>     return
    13                              <2> %%_ret:
    14 000004B6 C3                  <2>  ret
    15                              <2> %assign retOff %%_ret-$$
   154                              <1> .noMoreLocks:
   155 000004B7 B824000000          <1>     mov eax, errShrFul
   156 000004BC F9                  <1>     stc
   157                              <1>     return
    13                              <2> %%_ret:
    14 000004BD C3                  <2>  ret
    15                              <2> %assign retOff %%_ret-$$
   158                              <1> 
   159                              <1> 
   160                              <1> closeByID:
   161                              <1> ;Closes all files by IDs.
   162                              <1> ;Input: rcx = -1 if we are not to use the qPID for searches, else 0.
   163                              <1> ;       SDA has qPID and dMID set
   164                              <1> ;Searches through the MFT heap for allocated MFTs and within them,
   165                              <1> ; frees each SFT which meets the ID requirements
   166                              <1> ;Trashes everything except r8.
   167 000004BE 4150                <1>     push r8
   168 000004C0 4C8B05(26000000)    <1>     mov r8, qword [pDosseg]
   169                              <1> ;Start by getting dMID and, optionally, qPID from SDA
   170 000004C7 418B9073040000      <1>     mov edx, dword [r8 + dMID]
   171 000004CE 490B886B040000      <1>     or rcx, qword [r8 + qPID]   ;If rcx=0, sets rcx to qPID. Else, stays at -1
   172 000004D5 488B3D(00000000)    <1>     mov rdi, qword [pMftArena]
   173 000004DC E853000000          <1>     call .mftAdvNext    ;Set rsi and rdi appropriately
   174 000004E1 803E00              <1>     cmp byte [rsi + mft.bSig], mftFree
   175 000004E4 750A                <1>     jne .mftGo  ;If not free, it can't be end as first is either alloc or free
   176                              <1> ;Here if the first block was free. rdi -> First non-free block.
   177                              <1> ;Let it fall through. If rdi points to the end block, we have no allocd MFTs
   178                              <1> ; so we exit ok! Else, start from rdi, setup rsi and move rdi to next 
   179                              <1> ; mft after it!
   180                              <1> .mftNext:
   181 000004E6 803FFF              <1>     cmp byte [rdi + mft.bSig], mftEnd   ;Is this MFT an end MFT?
   182 000004E9 7446                <1>     je .end
   183                              <1> ;We advance rdi before processing rsi. The advance must be done
   184                              <1> ; before any possible close as the close might invalidate the pointer in rsi.
   185 000004EB E844000000          <1>     call .mftAdvNext    ;Return rdi -> Next Non-free MFT
   186                              <1> .mftGo:
   187                              <1> ;Enter here with:
   188                              <1> ;rdi -> Next MFT in MFT block
   189                              <1> ;rsi -> MFT we will be closing SFTs on
   190                              <1> ;Now we go down rsi's SFT chain freeing the SFTs as specified.
   191 000004F0 488B5E0E            <1>     mov rbx, qword [rsi + mft.pSFT] ;Point rbx to first SFT in mft's sft chain
   192                              <1> .sftLp:
   193 000004F4 4885DB              <1>     test rbx, rbx   ;Once we are at the end of the sft chain, goto next MFT
   194 000004F7 74ED                <1>     jz .mftNext
   195                              <1> ;Here we have an SFT for investigation. Set it to current and push the
   196                              <1> ; next SFT on the stack
   197 000004F9 49899863070000      <1>     mov qword [r8 + currentSFT], rbx    ;Set the current SFT as rbx
   198 00000500 FF733B              <1>     push qword [rbx + sft.pNextSFT] ;Save the ptr to next SFT in chain
   199                              <1> ;Now check do we need to close this SFT
   200 00000503 395343              <1>     cmp dword [rbx + sft.dMID], edx
   201 00000506 7526                <1>     jne .sftSkip
   202 00000508 4881F9FFFFFFFF      <1>     cmp rcx, -1 ;If -1, then just equal dMID suffices. Close this SFT
   203 0000050F 7406                <1>     je .sftGo
   204 00000511 48394B47            <1>     cmp qword [rbx + sft.qPID], rcx
   205 00000515 7517                <1>     jne .sftSkip
   206                              <1> .sftGo:
   207                              <1> ;Here we have an sft to close. The one in rbx. 
   208                              <1> ;Set its count to 1, to make closeSFT clean up properly as we will
   209                              <1> ; close all jft entries across all processes. 
   210 00000517 66C7030100          <1>     mov word [rbx + sft.wNumHandles], 1
   211 0000051C 51                  <1>     push rcx    ;Save the qPID (or -1 signature) for checking
   212 0000051D 52                  <1>     push rdx    ;Save the dMID for checking
   213 0000051E 56                  <1>     push rsi    ;Save the current MFT we are processing
   214 0000051F 57                  <1>     push rdi    ;Save the next MFT
   215                              <1> ;These two require currentSFT set
   216 00000520 E826000000          <1>     call closeHandlesForSFT ;Close all JFT entries pointing to this SFT
   217 00000525 E819000000          <1>     call closeSFT   ;This might delete the current MFT... 
   218 0000052A 5F                  <1>     pop rdi     ;Get the next MFT
   219 0000052B 5E                  <1>     pop rsi     ;Get the current MFT (might be invalid now)
   220 0000052C 5A                  <1>     pop rdx     ;Get the dMID
   221 0000052D 59                  <1>     pop rcx     ;Get the qPID (or -1 signature)
   222                              <1> .sftSkip:
   223 0000052E 5B                  <1>     pop rbx     ;Get ptr to the next SFT in the chain (might be null)
   224 0000052F EBC3                <1>     jmp short .sftLp
   225                              <1> .end:
   226                              <1> ;Else, the MFT was the end MFT so we are done! Exit!
   227 00000531 4158                <1>     pop r8
   228                              <1>     return
    13                              <2> %%_ret:
    14 00000533 C3                  <2>  ret
    15                              <2> %assign retOff %%_ret-$$
   229                              <1> .mftAdvNext:
   230                              <1> ;Advances rdi to the next non-free MFT (stops at mftEnd).
   231                              <1> ;Input: rdi -> MFT to start advancing from.
   232                              <1> ;Output: rdi -> Next non-free MFT
   233                              <1> ;        rsi -> MFT we started at
   234 00000534 4889FE              <1>     mov rsi, rdi
   235                              <1> .manLp:
   236 00000537 8B4701              <1>     mov eax, dword [rdi + mft.dLen]
   237 0000053A 4801C7              <1>     add rdi, rax  
