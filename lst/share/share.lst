    36                              <3> %%a:
    37                              <3> 
   372 000006A7 48895E4F            <1>     mov qword [rsi + sft.pMFT], rbx
   373                              <1> ;Now add this SFT to the front of the list.
   374 000006AB 488B7B0E            <1>     mov rdi, qword [rbx + mft.pSFT] ;Get the head of the SFT list
   375 000006AF 48897E3B            <1>     mov qword [rsi + sft.pNextSFT], rdi ;Link new SFT to previous head
   376 000006B3 4889730E            <1>     mov qword [rbx + mft.pSFT], rsi ;Put new SFT at head of MFT list
