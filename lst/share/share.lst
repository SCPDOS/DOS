   263                              <1> freeMFT:
   264                              <1> ;Frees the MFT if it is safe to do so. Crashes otherwise. Combines 
   265                              <1> ; any adjacent free space too.
   266                              <1> ;Input: rbx -> MFT to free
   267                              <1> ;Output: MFT freed. Any adjacent free space is absorbed by this MFT too.
   268                              <1> ;Trashes rax, rbx and rsi
   269 000005A7 488B430E            <1>     mov rax, qword [rbx + mft.pSFT]
   270 000005AB 48094306            <1>     or qword [rbx + mft.pLock], rax ;If pLock or pSFT is non-zero, hard error
   271 000005AF 751A                <1>     jnz .crash
   272 000005B1 C60300              <1>     mov byte [rbx + mft.bSig], mftFree
   273                              <1> .lp:
   274                              <1> ;Checks the adjacent MFT. If it is free, we combine it to this free MFT.
