   614                              <1> getMFT:
   615                              <1> ;Search for an MFT for a file. If one is not found, it creates it.
   616                              <1> ;Input: rsi -> Filename to search for
   617                              <1> ;Output: CF=NC: rbx -> MFT for this file.
   618                              <1> ;        CF=CY: eax = Error code.
   619                              <1> ;Start by working out the string length and checksum values
   620 000007F2 E8E5000000          <1>     call findMFT        ;Sets dl for checksum and ecx for string length
   621                              <1>     retnc
    61                              <2> cret nc
    19                              <3> %%_base:
    20                              <3> %assign baseVar %%_base-$$
    21                              <3> 
    22                              <3> 
    23                              <3> 
    24                              <3> 
    25                              <3> 
    26                              <3> 
    27                              <3> 
    28                              <3> 
    29                              <3> 
    30                              <3> 
    31                              <3> 
    32                              <3> 
    33                              <3> 
    34 000007F7 7201                <3>  j%-1 short %%a
    35                              <3>  return
