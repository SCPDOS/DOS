   278                              <1> removeSFTfromMFT:
   279                              <1> ;Removes the SFT from the MFT's SFT chain.
   280                              <1> ;Input: rdi -> SFT we are closing.
   281                              <1> ;Output: ZF=ZE: No more files on MFT
   282                              <1> ;        ZF=NZ: More files on MFT.
   283                              <1> ;           rbx -> MFT for this file
   284                              <1> ;Trashes rax and rsi.
   285 000005DA 488B5F4F            <1>     mov rbx, qword [rdi + sft.pMFT] ;Get the MFT pointer
   286                              <1> ;Point rsi to the such that it is one sft.pNextSFT away from the pointer to
   287                              <1> ; the next SFT
   288 000005DE 488D73D3            <1>     lea rsi, qword [rbx + mft.pSFT - sft.pNextSFT]
   289                              <1> .lp:
   290 000005E2 4885F6              <1>     test rsi, rsi   ;If we dont find rdi, something has gone terribly wrong
   291 000005E5 7425                <1>     jz .crash
   292 000005E7 48397E3B            <1>     cmp qword [rsi + sft.pNextSFT], rdi    ;Is the next SFT us?
   293 000005EB 7406                <1>     je .found
   294 000005ED 488B763B            <1>     mov rsi, qword [rsi + sft.pNextSFT] ;Go to next SFT
   295 000005F1 EBEF                <1>     jmp short .lp
   296                              <1> .found:
   297                              <1> ;rsi -> Points to the previous SFT in the chain 
   298 000005F3 488B473B            <1>     mov rax, qword [rdi + sft.pNextSFT] ;Get our next SFT value
   299 000005F7 4889463B            <1>     mov qword [rsi + sft.pNextSFT], rax ;And set the prev SFT to link over us
   300 000005FB 48C7474F00000000    <1>     mov qword [rdi + sft.pMFT], 0   ;Set pMFT to zero to mean we are done!
   301 00000603 48817B0E00000000    <1>     cmp qword [rbx + mft.pSFT], 0   ;Is the MFT SFT chain ptr 0?
   302                              <1>     return
    13                              <2> %%_ret:
    14 0000060B C3                  <2>  ret
    15                              <2> %assign retOff %%_ret-$$
