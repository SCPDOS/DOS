   157                              <1> closeByID:
   158                              <1> ;Closes all files by IDs.
   159                              <1> ;Input: rcx = qPID (or -1 if we are not to use this)
   160                              <1> ;       rdx = dMID
   161                              <1> ;Searches through the MFT heap for allocated MFTs and within them,
   162                              <1> ; frees each SFT which meets the ID requirements
   163 000004B9 4150                <1>     push r8
   164 000004BB 4C8B05(26000000)    <1>     mov r8, qword [pDosseg]
   165 000004C2 488B3D(00000000)    <1>     mov rdi, qword [pMftArena]
   166 000004C9 E84C000000          <1>     call .mftAdvNext    ;Start by skipping any leading free blocks
   167                              <1> .mftNext:
   168 000004CE 4889FE              <1>     mov rsi, rdi    ;Set current MFT = Next MFT 
   169 000004D1 803FFF              <1>     cmp byte [rdi + mft.bSig], mftEnd   ;Is this MFT an end MFT?
   170 000004D4 7441                <1>     je .end
   171                              <1> ;Here, we advance rdi before processing rsi. The advance must be done
   172                              <1> ; before any possible close as the close might invalidate the pointer in rsi.
   173                              <1> ;rsi will always be an allocated SFT as it isn't free or end
   174 000004D6 E83F000000          <1>     call .mftAdvNext ;Returns rdi -> Next Non-free MFT. rsi -> MFT to process.
   175                              <1> ;Now we go down rsi's SFT chain freeing the SFTs as specified.
   176 000004DB 488B5E0E            <1>     mov rbx, qword [rsi + mft.pSFT] ;Point rbx to the first SFT
   177                              <1> .sftLp:
   178 000004DF 4885DB              <1>     test rbx, rbx   ;Once we are at the end of the sft chain, goto next MFT
   179 000004E2 74EA                <1>     jz .mftNext
   180                              <1> ;Here we have an SFT for investigation. Set it to current and push the
   181                              <1> ; next SFT on the stack
   182 000004E4 49899863070000      <1>     mov qword [r8 + currentSFT], rbx    ;Set the current SFT as rbx
   183 000004EB FF733B              <1>     push qword [rbx + sft.pNextSFT] ;Save the ptr to next SFT in chain
   184                              <1> ;Now check do we need to close this SFT
   185 000004EE 395343              <1>     cmp dword [rbx + sft.dMID], edx
   186 000004F1 7521                <1>     jne .sftSkip
   187 000004F3 4881F9FFFFFFFF      <1>     cmp rcx, -1 ;If -1, then just equal dMID suffices. Close this SFT
   188 000004FA 7406                <1>     je .sftGo
   189 000004FC 48394B47            <1>     cmp qword [rbx + sft.qPID], rcx
   190 00000500 7512                <1>     jne .sftSkip
   191                              <1> .sftGo:
   192                              <1> ;Here we have an sft to close. The one in rsi. 
   193 00000502 51                  <1>     push rcx    ;Save the qPID (or -1 signature) for checking
   194 00000503 52                  <1>     push rdx    ;Save the dMID for checking
   195 00000504 56                  <1>     push rsi    ;Save the current MFT we are processing
   196 00000505 57                  <1>     push rdi    ;Save the next MFT
   197                              <1> ;These two require currentSFT set
   198 00000506 E823000000          <1>     call closeHandlesForSFT
   199 0000050B E816000000          <1>     call closeSFT   ;This might delete the current MFT... 
   200 00000510 5F                  <1>     pop rdi     ;Get the next MFT
   201 00000511 5E                  <1>     pop rsi     ;Get the current MFT (might be invalid now)
   202 00000512 5A                  <1>     pop rdx     ;Get the dMID
   203 00000513 59                  <1>     pop rcx     ;Get the qPID (or -1 signature)
   204                              <1> .sftSkip:
   205 00000514 5B                  <1>     pop rbx     ;Get ptr to the next SFT in the chain (might be null)
   206 00000515 EBC8                <1>     jmp short .sftLp
   207                              <1> .end:
   208                              <1> ;Else, the MFT was the end MFT so we are done! Exit!
   209 00000517 4158                <1>     pop r8
   210                              <1>     return
    13                              <2> %%_ret:
    14 00000519 C3                  <2>  ret
    15                              <2> %assign retOff %%_ret-$$
   211                              <1> .mftAdvNext:
   212                              <1> ;Advances rdi to the next non-free MFT (stops at mftEnd).
   213                              <1> ;Input: rdi -> MFT to start advancing from.
   214 0000051A 8B4701              <1>     mov eax, dword [rdi + mft.dLen]
   215 0000051D 4801C7              <1>     add rdi, rax  
   216 00000520 803F00              <1>     cmp byte [rdi + mft.bSig], mftFree  ;Do we keep advancing?
   217 00000523 74F5                <1>     je .mftAdvNext  ;If rdi points to a free MFT, yes!
   218                              <1>     return
    13                              <2> %%_ret:
    14 00000525 C3                  <2>  ret
    15                              <2> %assign retOff %%_ret-$$
   219                              <1> 
