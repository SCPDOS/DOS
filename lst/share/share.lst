   272 000001F4 803E00              <1>     cmp byte [rsi + mft.bSig], mftFree
   273 000001F7 7406                <1>     jz .mftNext ;If its free, just goto next MFT
   274 000001F9 7242                <1>     jb .exitBad ;If we are at the end, exit error!
   275 000001FB FFCB                <1>     dec ebx     ;Drop one from the count, if zero, we have arrived
   276 000001FD 7408                <1>     jz .goSft
