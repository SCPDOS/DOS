   295                              <1> ; rsi -> our SFT
   296                              <1> ; rdi -> Filename to return
   297                              <1> ;Now count the number of locks this file has. 
   298 00000221 488B764F            <1>     mov rsi, qword [rsi + sft.pMFT] ;Point back to the MFT
   299 00000225 488B7606            <1>     mov rsi, qword [rsi + mft.pLock] ;Point to the lock list
   300                              <1> .lockLp:
