    32                              <1> open:           
    33                              <1> ;Called on file create/open. Creates/Finds an MFT entry for the file
    34                              <1> ; being opened and adds the new SFT to the MFT chain.
    35                              <1> ;----------------------------------------------------------------------------
    36                              <1> ;Input: qword [fname1Ptr] -> Fully qualified pathname to open
    37                              <1> ;       qword [currentSFT] -> SFT that was just created/opened
    38                              <1> ;           This SFT needs the following fields filled in:
    39                              <1> ;               .wOpenMode
    40                              <1> ;               .bFileAttrib
    41                              <1> ;               .dMID
    42                              <1> ;               .qPID
    43                              <1> ;               .pMFT
    44                              <1> ;       qword [qPID] -> Process ID of the requesting task
    45                              <1> ;       dword [dMID] -> Machine ID of the requesting task
    46                              <1> ;Output: CF=NC: Proceed happily with SFT linked into the MFT for the file.
    47                              <1> ;        CF=CY: eax = Error code for request. Abort, free SFT.
    48                              <1> ;Use r8 as DOSSEG base
    49                              <1> ;----------------------------------------------------------------------------
    50 00000013 E8E4030000          <1>     call critEnter
    51 00000018 4150                <1>     push r8
    52 0000001A 4C8B05(26000000)    <1>     mov r8, qword [pDosseg]
    53 00000021 498BB050060000      <1>     mov rsi, qword [r8 + fname1Ptr] ;Get the filename pointer
    54 00000028 E899070000          <1>     call getMFT
    55 0000002D 720C                <1>     jc .exit
    56                              <1> ;rbx -> MFT for this file here.
    57 0000002F 498BB063070000      <1>     mov rsi, qword [r8 + currentSFT]    ;Get the current SFT now
    58 00000036 E84D060000          <1>     call addSFTtoMFT    ;Bubble CF
    59                              <1> .exit:
    60 0000003B 4158                <1>     pop r8
    61 0000003D E8C4030000          <1>     call critExit
    62                              <1>     return
    13                              <2> %%_ret:
    14 00000042 C3                  <2>  ret
    15                              <2> %assign retOff %%_ret-$$
    63                              <1> 
    64                              <1> close:          
    65                              <1> ;Called on file close. Frees all sharing information associated with
    66                              <1> ; a file.
    67                              <1> ;Input: rdi -> SFT we are closing.
    68 00000043 E8B4030000          <1>     call critEnter
    69 00000048 488B5F4F            <1>     mov rbx, qword [rdi + sft.pMFT]
    70 0000004C 4885DB              <1>     test rbx, rbx   ;If this is an SFT from before Share loaded, do nothing!
    71 0000004F 741C                <1>     jz .exit
    72 00000051 0FBF07              <1>     movsx eax, word [rdi + sft.wNumHandles] ;Get the count
    73 00000054 85C0                <1>     test eax, eax   ;If count is zero, free all sharing data
    74 00000056 7404                <1>     jz .goClose
    75 00000058 FFC0                <1>     inc eax         ;If this handle is -1, also free any sharing data.
    76 0000005A 7511                <1>     jnz .exit       ;If not -1 or 0, then inc eax > 0 and so we just exit
    77                              <1> .goClose:
    78 0000005C E8CE050000          <1>     call freeLocks  ;Free all locks associated to this SFT
    79 00000061 E87C050000          <1>     call removeSFTfromMFT ;Delink this SFT from the SFT link
    80 00000066 7505                <1>     jnz .exit       ;If not last SFT in MFT chain, dont free MFT
    81 00000068 E83A050000          <1>     call freeMFT    ;If no more SFTs, free the MFT. Do small GC.
    82                              <1> .exit:
    83 0000006D E894030000          <1>     call critExit
    84                              <1>     return
    13                              <2> %%_ret:
    14 00000072 C3                  <2>  ret
    15                              <2> %assign retOff %%_ret-$$
    85                              <1> 
    86                              <1> closeAllByMachine:      
    87                              <1> ;Close all files for a machine.
    88                              <1> ;Input: rdx -> DPL (use dMID only)
    89 00000073 E884030000          <1>     call critEnter
    90 00000078 31C9                <1>     xor ecx, ecx
    91 0000007A 48FFC9              <1>     dec rcx ;Get -1 into ecx to indicate not to use this
    92 0000007D 488B5218            <1>     mov rdx, qword [rdx + dpl.rdx]  ;Get the MID
    93 00000081 E837040000          <1>     call closeByID
    94 00000086 E87B030000          <1>     call critExit
    95                              <1>     return
    13                              <2> %%_ret:
    14 0000008B C3                  <2>  ret
    15                              <2> %assign retOff %%_ret-$$
    96                              <1> 
    97                              <1> closeAllByProcess:      
    98                              <1> ;Close all files for a task.
    99                              <1> ;Input: rdx -> DPL (use dMID and qPID)
   100 0000008C E86B030000          <1>     call critEnter
   101 00000091 488B4A18            <1>     mov rcx, qword [rdx + dpl.rdx]  ;Get the PID
   102 00000095 488B5218            <1>     mov rdx, qword [rdx + dpl.rdx]  ;Get the MID
   103 00000099 E81F040000          <1>     call closeByID
   104 0000009E E863030000          <1>     call critExit
   105                              <1>     return
    13                              <2> %%_ret:
    14 000000A3 C3                  <2>  ret
    15                              <2> %assign retOff %%_ret-$$
   106                              <1> 
   107                              <1> closeAllByName:      
   108                              <1> ;Close all files by name.
   109                              <1> ;Input: rdx -> DPL (use rdx, dMID and qPID)
   110 000000A4 E853030000          <1>     call critEnter
   111 000000A9 4150                <1>     push r8
   112 000000AB 4C8B05(26000000)    <1>     mov r8, qword [pDosseg] ;Needed for the close handles call below
   113 000000B2 488B7218            <1>     mov rsi, qword [rdx + dpl.rdx]  ;Get the filename ptr in rsi
   114 000000B6 E8F5070000          <1>     call findMFT    ;Find the MFT for this file name
   115 000000BB 7224                <1>     jc .exit
   116 000000BD 488B7B0E            <1>     mov rdi, qword [rbx + mft.pSFT] ;Get the ptr to the first SFT
   117                              <1> .lp:
   118                              <1> ;We work by looking ahead an SFT in the chain. This is because closeSFT
   119                              <1> ; might free the MFT so instead of having to search for it each time
   120                              <1> ; we look for the condition on which it will be freed, i.e. the sft we are at
   121                              <1> ; being the last SFT open on that MFT.
   122 000000C1 4885FF              <1>     test rdi, rdi   ;Is the SFT ptr null? Exit if so
   123 000000C4 741B                <1>     jz .exit
   124 000000C6 4989B863070000      <1>     mov qword [r8 + currentSFT], rdi    ;Else, set this SFT to be current
   125 000000CD 498B703B            <1>     mov rsi, qword [r8 + sft.pNextSFT]  ;Get the next SFT
   126 000000D1 56                  <1>     push rsi    ;Preserve next SFT across the next two calls
   127 000000D2 57                  <1>     push rdi    ;Preserve rdi across this call
   128 000000D3 E85B040000          <1>     call closeHandlesForSFT ;Closes this SFT on all processes
   129 000000D8 5F                  <1>     pop rdi     ;Get back the ptr to current SFT
   130 000000D9 E84D040000          <1>     call closeSFT   ;Close this SFT
   131 000000DE 5F                  <1>     pop rdi     ;Get the ptr to the next SFT in rdi
   132 000000DF EBE0                <1>     jmp short .lp
   133                              <1> .exit:
   134 000000E1 4158                <1>     pop r8
   135 000000E3 E81E030000          <1>     call critExit
   136                              <1>     return
    13                              <2> %%_ret:
    14 000000E8 C3                  <2>  ret
    15                              <2> %assign retOff %%_ret-$$
   137                              <1> 
   138                              <1> lockFile:       
   139                              <1> ;Lock a file region.
   140                              <1> ;Input: rdi -> SFT for file
   141                              <1> ;       ecx:edx = Start offset
   142                              <1> ;       esi:eax = Length of region
   143 000000E9 E80E030000          <1>     call critEnter
   144 000000EE 4150                <1>     push r8
   145 000000F0 4C8B05(26000000)    <1>     mov r8, qword [pDosseg]
   146 000000F7 48817F4F00000000    <1>     cmp qword [rdi + sft.pMFT], 0   ;If we don't have an MFT, fail
   147 000000FF 743A                <1>     je .exitBad
   148 00000101 57                  <1>     push rdi    ;Save SFT ptr
   149 00000102 E809030000          <1>     call lockPreamble   ;Trashes rbx and rdi
   150 00000107 5F                  <1>     pop rdi
   151 00000108 7229                <1>     jc .exit
   152 0000010A E891030000          <1>     call getFreeLock    ;Get a free lock in rsi
   153 0000010F 7222                <1>     jc .exit
   154                              <1> ;Here we have:
   155                              <1> ;   CF=NC
   156                              <1> ;   rbp -> MFT to add to
   157                              <1> ;   rax = Start of locked region
   158                              <1> ;   rdx = End of locked region
   159                              <1> ;   rdi -> SFT owning the lock
   160                              <1> ;   rsi -> Free lock we are creating
   161 00000111 48894608            <1>     mov qword [rsi + fileLock.qStart], rax
   162 00000115 48895610            <1>     mov qword [rsi + fileLock.qEnd], rdx
   163 00000119 48897E18            <1>     mov qword [rsi + fileLock.pSFT], rdi
   164 0000011D 498B804F040000      <1>     mov rax, qword [r8 + currentPSP]
   165 00000124 48894620            <1>     mov qword [rsi + fileLock.qPID], rax
   166 00000128 488B4506            <1>     mov rax, qword [rbp + mft.pLock]    ;Get the head of the list
   167 0000012C 488906              <1>     mov qword [rsi + fileLock.pNext], rax   ;Link to the new file lock
   168 0000012F 48897306            <1>     mov qword [rbx + mft.pLock], rsi    ;Add the lock to the head of the list
   169                              <1> .exit:    
   170 00000133 4158                <1>     pop r8
   171 00000135 E8CC020000          <1>     call critExit
   172                              <1>     return
    13                              <2> %%_ret:
    14 0000013A C3                  <2>  ret
    15                              <2> %assign retOff %%_ret-$$
   173                              <1> .exitBad:
   174 0000013B B821000000          <1>     mov eax, errLokVio
   175 00000140 F9                  <1>     stc
   176 00000141 EBF0                <1>     jmp short .exit
   177                              <1> 
   178                              <1> unlockFile:     
   179                              <1> ;Unlock file region. 
   180                              <1> ;Input: rdi -> SFT for file
   181                              <1> ;       ecx:edx = Start offset
   182                              <1> ;       esi:eax = Length of region
   183 00000143 E8B4020000          <1>     call critEnter
   184 00000148 4150                <1>     push r8
   185 0000014A 4C8B05(26000000)    <1>     mov r8, qword [pDosseg]
   186 00000151 48817F4F00000000    <1>     cmp qword [rdi + sft.pMFT], 0   ;If we don't have an MFT, fail
   187 00000159 74E0                <1>     je lockFile.exitBad
   188 0000015B 57                  <1>     push rdi    ;Save current SFT
   189 0000015C E8AF020000          <1>     call lockPreamble   ;Get rbx -> Matched lock, rdi -> Lock pointing to rbx
   190 00000161 5E                  <1>     pop rsi     ;Get back current SFT in rsi
   191 00000162 73D7                <1>     jnc lockFile.exitBad    ;If true, no match, rdi and rbx meaningless.
   192 00000164 75D5                <1>     jnz lockFile.exitBad    ;If true, not exact match.
   193                              <1> ;   rbp -> MFT to remove lock from
   194                              <1> ;   rsi -> SFT owning the lock
   195                              <1> ;   rbx -> Lock to free
   196                              <1> ;   rdi -> Lock pointed to by rbx
   197 00000166 48397318            <1>     cmp qword [rbx + fileLock.pSFT], rsi    ;Check we own this lock
   198 0000016A 75CF                <1>     jne lockFile.exitBad
   199 0000016C 498B804F040000      <1>     mov rax, qword [r8 + currentPSP]
   200 00000173 48394320            <1>     cmp qword [rbx + fileLock.qPID], rax    ;Check this process can remove it
   201 00000177 75C2                <1>     jne lockFile.exitBad
   202                              <1> ;Link over the lock we are freeing (pointed to by rbx), removing from mft list
   203 00000179 488B03              <1>     mov rax, qword [rbx + fileLock.pNext]
   204 0000017C 488907              <1>     mov qword [rdi + fileLock.pNext], rax
   205                              <1> ;Add the lock (pointed to by rbx) to the head of the free list
   206 0000017F 488B05(14000000)    <1>     mov rax, qword [pFreeLock]
   207 00000186 488903              <1>     mov qword [rbx + fileLock.pNext], rax
   208 00000189 48891D(14000000)    <1>     mov qword [pFreeLock], rbx
   209 00000190 EBA1                <1>     jmp short lockFile.exit
   210                              <1> 
   211                              <1> 
   212                              <1> checkRegionLock:  
   213                              <1> ;Check file region locked.
   214                              <1> ;Input: rdi -> SFT for current file
   215                              <1> ;       ecx = Length of region from current position in file
   216                              <1> ;       dword [currByteF] set up with current position in file
   217                              <1> ;Get the mft ptr, walk the lock list and check that the range specified
   218                              <1> ; in between current offset and current offset + ecx is not within any range
   219 00000192 E865020000          <1>     call critEnter
   220 00000197 53                  <1>     push rbx
   221 00000198 51                  <1>     push rcx
