   579                              <1> ;We get here if this file has no MFT.
   580                              <1> ;Create an MFT entry. dl and ecx are always preserved in functions below
   581 000007CE 81C116000000        <1>     add ecx, mft_size   ;ecx now has the full MFT entry size
   582 000007D4 E8BB000000          <1>     call findFreeMFT
   583 000007D9 730F                <1>     jnc .buildMFT
   584 000007DB E847000000          <1>     call defragMFTArena ;Returns rbx -> Free MFT, eax = Free MFT size
   585 000007E0 39C8                <1>     cmp eax, ecx        ;Do we fit in this free space?
   586 000007E2 7306                <1>     jnc .buildMFT
   587                              <1> ;Here if CF=CY. Return Sharing buffer full error!
   588 000007E4 B824000000          <1>     mov eax, errShrFul
   589                              <1>     return
