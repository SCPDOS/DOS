   819                              <1> errPrintAndHalt:
   820                              <1> ;********************************************
   821                              <1> ;This function is called such that the return address points to the 
   822                              <1> ; null terminated string to print. We never return from this.
   823                              <1> ;********************************************
   824                              <1> ;Input: TOS -> Ptr to string to print after header.
   825                              <1> ;Output: Never return.
   826 0000094C 488D3D56000000      <1>     lea rdi, .sHdr
