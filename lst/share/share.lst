   241 00000563 8B4F09              <1>     mov ecx, dword [rdi + mcb.blockSize]    ;Get size of block in paras
   242 00000566 48C1E104            <1>     shl rcx, 4      ;Turn into bytes
   243 0000056A 4881C110000000      <1>     add rcx, mcb_size
