   352                              <1> .skipProcess:
   353                              <1> ;Here we delink the flock. We move it from the MFT list to the Free list
   354                              <1> ; and cross link.
   355                              <1> ;Registers on entry
   356                              <1> ;rdi -> Our SFT
   357                              <1> ;rsi -> Lock
   358                              <1> ;rbx -> The previous lock in the file chain (only first qword valid)
   359                              <1> ;edx = Flag, do not use.
   360 00000661 488B06              <1>     mov rax, qword [rsi + fileLock.pNext]   ;Unlink rsi by linking the prev...
   361 00000664 488903              <1>     mov qword [rbx + fileLock.pNext], rax   ;... flock to the flock after rsi
   362 00000667 488B05(14000000)    <1>     mov rax, qword [pFreeLock]              ;Get head of the free lock list
   363 0000066E 488906              <1>     mov qword [rsi + fileLock.pNext], rax   ;Link rsi to the head of free list
   364 00000671 488935(14000000)    <1>     mov qword [pFreeLock], rsi              ;Make rsi the head of the free list
   365 00000678 4889DE              <1>     mov rsi, rbx    ;Start from previous lock in the list again.
   366                              <1> .nextLock:
   367 0000067B 4889F3              <1>     mov rbx, rsi    ;Point rsi to this filelock
   368 0000067E 488B36              <1>     mov rsi, qword [rsi + fileLock.pNext]   ;Get next file lock
   369 00000681 EBB6                <1>     jmp short .lp
