   323                              <1> closeNetworkFiles:   
   324                              <1> ;Close a newly created SFT-FCB handle for a procedure.
   325                              <1> ;Network SFT-FCBs handles are all collapsed into one SFT.
   326                              <1> ;----------------------------------------------------------------------------
   327                              <1> ;Input: rsi -> Newly created SFT
   328                              <1> ;       ax = SFTNdx for this newly created file
   329                              <1> ;Output: CF=NC: ax = SFTNdx for the SFT (Same as on input if not a SFT-FCB)
   330                              <1> ;        CF=CY: No SFT found
   331                              <1> ;----------------------------------------------------------------------------
   332                              <1> ;If
   333                              <1> ;   rsi -> SFT that is a network SFT-FCB (i.e. bit openNetFCBShr set 
   334                              <1> ;   in openmode), then we close any duplicate handles using a single
   335                              <1> ;   SFT to maintain the state (if there are none then we use this SFT
   336                              <1> ;   as the SFT-FCB). We increment the new main SFT refcount instead of 
   337                              <1> ;   having multiple SFTs.
   338                              <1> ;----------------------------------------------------------------------------
   339 00000248 4150                <1>     push r8
   340 0000024A 4C8B05(26000000)    <1>     mov r8, qword [pDosseg]
   341 00000251 0FB74602            <1>     movzx eax, word [rsi + sft.wOpenMode]
   342 00000255 25F0000000          <1>     and eax, 0F0h    ;Save the share bits
   343 0000025A 3D70000000          <1>     cmp eax, openNetFCBShr
   344 0000025F 7573                <1>     jne .exitNormal
   345 00000261 31DB                <1>     xor ebx, ebx
   346                              <1> .ptrLp:
   347 00000263 53                  <1>     push rbx
   348 00000264 B816120000          <1>     mov eax, 1216h  ;getSFTPtrfromSFTNdx -> Get in rdi the SFT for index bx
   349 00000269 CD2F                <1>     int 2Fh
   350 0000026B 5B                  <1>     pop rbx
   351 0000026C 726E                <1>     jc .exit
   352 0000026E 4839F7              <1>     cmp rdi, rsi    ;Skip ourselves
   353 00000271 742D                <1>     je .ptrNext
   354 00000273 66813F0000          <1>     cmp word [rdi + sft.wNumHandles], 0 ;Handle must have empty count
   355 00000278 7426                <1>     je .ptrNext
   356 0000027A 0FB74602            <1>     movzx eax, word [rsi + sft.wOpenMode]
   357 0000027E 663B4702            <1>     cmp ax, word [rdi + sft.wOpenMode]
   358 00000282 751C                <1>     jne .ptrNext
   359 00000284 8B4643              <1>     mov eax, dword [rsi + sft.dMID]
   360 00000287 394743              <1>     cmp dword [rdi + sft.dMID], eax
   361 0000028A 7514                <1>     jne .ptrNext
   362 0000028C 488B4647            <1>     mov rax, qword [rsi + sft.qPID]
   363 00000290 48394747            <1>     cmp qword [rdi + sft.qPID], rax
   364 00000294 750A                <1>     jne .ptrNext
   365 00000296 488B464F            <1>     mov rax, qword [rsi + sft.pMFT]
   366 0000029A 4839474F            <1>     cmp qword [rdi + sft.pMFT], rax
   367 0000029E 7404                <1>     je .ptrFnd  ;If all this, then we have a duplicate net handle
   368                              <1> .ptrNext:
   369 000002A0 FFC3                <1>     inc ebx
   370 000002A2 EBBF                <1>     jmp short .ptrLp
   371                              <1> .ptrFnd:
   372                              <1> ;rsi is a duplicate of rdi for this process
   373 000002A4 66C7060000          <1>     mov word [rsi + sft.wNumHandles], 0 ;Free the handle we just allocated
   374 000002A9 57                  <1>     push rdi    ;rdi is the master FCB SFT 
   375 000002AA 53                  <1>     push rbx    ;Save the sftindex
   376 000002AB 4889F7              <1>     mov rdi, rsi
   377 000002AE E890FDFFFF          <1>     call close  ;Close the current SFT now
   378 000002B3 58                  <1>     pop rax     ;Get the sftindex into eax
   379 000002B4 5F                  <1>     pop rdi
   380 000002B5 66FF07              <1>     inc word [rdi + sft.wNumHandles]    ;Add one now
   381 000002B8 31DB                <1>     xor ebx, ebx
   382                              <1> .jftlp:
   383 000002BA 50                  <1>     push rax
   384 000002BB B820120000          <1>     mov eax, 1220h  ;getJFTPtr -> Get ptr to this jft entry in psp in rdi
   385 000002C0 CD2F                <1>     int 2Fh
   386 000002C2 58                  <1>     pop rax
   387 000002C3 7217                <1>     jc .exit
   388 000002C5 3807                <1>     cmp byte [rdi], al
   389 000002C7 7404                <1>     je .jftFnd
   390 000002C9 FFC3                <1>     inc ebx
   391 000002CB EBED                <1>     jmp short .jftlp
   392                              <1> .jftFnd:
   393 000002CD C607FF              <1>     mov byte [rdi], -1
   394 000002D0 89D8                <1>     mov eax, ebx
   395 000002D2 EB08                <1>     jmp short .exit
   396                              <1> .exitNormal:
   397 000002D4 410FB7806D070000    <1>     movzx eax, word [r8 + currentHdl]   ;Get the handle value to return
   398                              <1> .exit:
   399 000002DC 4158                <1>     pop r8
   400                              <1>     return
    13                              <2> %%_ret:
    14 000002DE C3                  <2>  ret
    15                              <2> %assign retOff %%_ret-$$
