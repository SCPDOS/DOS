   327 00000633 488B7306            <1>     mov rsi, qword [rbx + mft.pLock]    ;Get the first lock of MFT in rsi 
   328 00000637 4881C306000000      <1>     add rbx, mft.pLock  ;Point rbx to the link field of the previous lock
