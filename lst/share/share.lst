   581                              <1> .buildMFT:
   582                              <1> ;Here we have the following values:
   583                              <1> ;rsi -> String to copy in
   584                              <1> ;rbx -> Space to allocate the MFT in. rbx points to a free MFT.
   585                              <1> ;ecx = New MFT full size
   586                              <1> ;dl = String checksum 
   587                              <1> 
   588                              <1> ;Work out if we want to split space into two MFTs or keep it as one.
   589                              <1> ;Check if the MFT we are pointing at has enough space for a minimum mft and
   590                              <1> ; our MFT. If there is more than enough space, we split into two MFTs. 
   591                              <1> ;Else, we just allocate the whole space and waste the few extra bytes.
   592 000007E2 8B4301              <1>     mov eax, dword [rbx + mft.dLen] ;Get the current size of the free MFT
   593 000007E5 29C8                <1>     sub eax, ecx        ;Remove our own allocation from the free MFT size
   594 000007E7 3D26000000          <1>     cmp eax, MIN_MFT_SIZE
   595 000007EC 760D                <1>     jbe .alloc   ;If this is beq, we just use this mft entry as is.
   596                              <1> ;eax has the size of the new free block
   597 000007EE 488D3C0B            <1>     lea rdi, qword [rbx + rcx]  ;Point rdi past the end of our new mft
   598 000007F2 C60700              <1>     mov byte [rdi + mft.bSig], mftFree  ;Make the new free block
   599 000007F5 894701              <1>     mov dword [rdi + mft.dLen], eax     ;Set the new free block's size
   600 000007F8 894B01              <1>     mov dword [rbx + mft.dLen], ecx     ;Set the newly allocated block's size
   601                              <1> .alloc:
   602                              <1> ;Finally, allocate the MFT. The size, if modified, is done already.
   603 000007FB C60301              <1>     mov byte [rbx + mft.bSig], mftAlloc
   604 000007FE 48C7430600000000    <1>     mov qword [rbx + mft.pLock], 0
   605 00000806 48C7430E00000000    <1>     mov qword [rbx + mft.pSFT], 0
   606 0000080E 885305              <1>     mov byte [rbx + mft.bCheckSum], dl  ;Set the checksum immediately.
   607 00000811 81E916000000        <1>     sub ecx, mft_size   ;Now get just the string length
   608 00000817 488D7B16            <1>     lea rdi, qword [rbx + mft.sName] 
   609 0000081B F3A4                <1>     rep movsb   ;Move the string over
   610 0000081D F8                  <1>     clc
   611                              <1>     return
    13                              <2> %%_ret:
    14 0000081E C3                  <2>  ret
    15                              <2> %assign retOff %%_ret-$$
   612                              <1> 
   613                              <1> defragMFTArena:
   614                              <1> ;Defragments the MFT arena. Moves all allocated MFTs to the start.
   615                              <1> ;Creates a single large free MFT from all the free space.
   616                              <1> ;Input: Nothing
   617                              <1> ;Output: MFT defragged. rbx -> New free MFT, eax = New Free MFT size
   618                              <1> ; All other regs preserved.
   619 0000081F 51                  <1>     push rcx
   620 00000820 52                  <1>     push rdx
   621 00000821 56                  <1>     push rsi
   622 00000822 57                  <1>     push rdi
   623                              <1> ;rsi = Read pointer
   624                              <1> ;rdi = Write pointer
   625                              <1> ;edx = Free space accumulator
   626 00000823 488B35(00000000)    <1>     mov rsi, qword [pMftArena]
   627 0000082A 4889F7              <1>     mov rdi, rsi
   628 0000082D 31D2                <1>     xor edx, edx
   629                              <1> .lp:
   630                              <1> ;If we encounter an allocated mft, we move it over, moving the 
   631                              <1> ; the read and write pointers. If we encounter a free mft, we add its
   632                              <1> ; size and move the read pointer.
   633 0000082F 803E00              <1>     cmp byte [rsi + mft.bSig], mftFree
   634 00000832 7826                <1>     js .exit    ;At this point, all compression is done. Goto end
   635 00000834 741A                <1>     je .free
   636                              <1> ;Here we copy over. Before we do, we walk down the SFT chain
   637                              <1> ; updating the MFT pointer in each SFT.
   638                              <1> ;rsi -> Allocated MFT
   639                              <1> ;rdi -> Where this MFT will be moved to
   640 00000836 488B5E0E            <1>     mov rbx, qword [rsi + mft.pSFT]     ;Point rbx to the first SFT in chain.
   641                              <1> .sftLp:
   642 0000083A 4885DB              <1>     test rbx, rbx   ;End of SFT chain?
   643 0000083D 740A                <1>     jz .sftEnd
   644 0000083F 48897B4F            <1>     mov qword [rbx + sft.pMFT], rdi     ;Update the SFT's MFT pointer
   645 00000843 488B5B3B            <1>     mov rbx, qword [rbx + sft.pNextSFT]
   646 00000847 EBF1                <1>     jmp short .sftLp
   647                              <1> .sftEnd:
   648                              <1> ;All SFTs updated, now we copy the MFT up.
   649 00000849 8B4E01              <1>     mov ecx, dword [rsi + mft.dLen] ;Get the length of this MFT
   650 0000084C F3A4                <1>     rep movsb   ;Moves both pointers to the end of the MFT
   651                              <1> ;Now rdi points to the next write space and rsi points to the next MFT
   652 0000084E EBDF                <1>     jmp short .lp
   653                              <1> .free:
   654                              <1> ;Dont worry about overflow. Max dLen is 1Mb, way less than 32 bit max.
   655 00000850 8B4601              <1>     mov eax, dword [rsi + mft.dLen] ;Get the length
   656 00000853 01C2                <1>     add edx, eax    ;Add to the free space accumulator
   657 00000855 4801C6              <1>     add rsi, rax    ;Move the read pointer past this free space
   658 00000858 EBD5                <1>     jmp short .lp
   659                              <1> .exit:
   660                              <1> ;Now we must make a single free MFT at the write pointer with the 
   661                              <1> ; correct size and assert it is correct
   662                              <1> ;rdi -> Where to make this MFT
   663                              <1> ;edx = Accumulated free space
   664 0000085A C60700              <1>     mov byte [rdi + mft.bSig], mftFree
   665 0000085D 895701              <1>     mov dword [rdi + mft.dLen], edx
   666 00000860 89D0                <1>     mov eax, edx    ;Get the free MFT size into eax
   667 00000862 4889FB              <1>     mov rbx, rdi    ;Get the free MFT pointer into rbx
   668 00000865 4801D7              <1>     add rdi, rdx    ;Now check the MFT chain is not corrupted
   669 00000868 803FFF              <1>     cmp byte [rdi + mft.bSig], mftEnd
   670 0000086B 7505                <1>     jne .crash
   671 0000086D 5F                  <1>     pop rdi
   672 0000086E 5E                  <1>     pop rsi
   673 0000086F 5A                  <1>     pop rdx
   674 00000870 59                  <1>     pop rcx
   675                              <1>     return
    13                              <2> %%_ret:
    14 00000871 C3                  <2>  ret
    15                              <2> %assign retOff %%_ret-$$
   676                              <1> .crash:
   677 00000872 E8D2000000          <1>     call errPrintAndHalt    ;No return. Use call to push string ptr to stack
   678 00000877 4D4654204445465241- <1>     db "MFT DEFRAG FAILURE",CR,LF,NUL
   678 00000880 47204641494C555245- <1>
   678 00000889 0D0A00              <1>
