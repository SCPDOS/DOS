   520 000003A0 89460F              <1>     mov dword [rsi + sft.dStartClust], eax
   521 000003A3 81F902000000        <1>     cmp ecx, 2      ;Was this a shrink call?
   522 000003A9 7409                <1>     je .gsDoShrink  ;Reset the cluster info if so
   523                              <1> ;Here if we are a grow call. Check if the SFT in rsi was newly created.
   524                              <1> ;If not, skip the reset below. Else, we set the absolute cluster now to
