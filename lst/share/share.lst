   271                              <1> freeMFT:
   272                              <1> ;Frees the MFT if it is safe to do so. Crashes otherwise. Combines 
   273                              <1> ; any adjacent free space too.
   274                              <1> ;Input: rbx -> MFT to free
   275                              <1> ;Output: MFT freed. Any adjacent free space is absorbed by this MFT too.
   276                              <1> ;Trashes rax, rbx and rsi
   277 000005A2 488B430E            <1>     mov rax, qword [rbx + mft.pSFT]
   278 000005A6 48094306            <1>     or qword [rbx + mft.pLock], rax ;If pLock or pSFT is non-zero, hard error
   279 000005AA 751A                <1>     jnz .crash
   280 000005AC C60300              <1>     mov byte [rbx + mft.bSig], mftFree
   281                              <1> .lp:
   282                              <1> ;Checks the adjacent MFT. If it is free, we combine it to this free MFT.
   283 000005AF 4889DE              <1>     mov rsi, rbx
   284 000005B2 8B4301              <1>     mov eax, dword [rbx + mft.dLen]
   285 000005B5 4801C6              <1>     add rsi, rax    ;Point to next MFT
   286 000005B8 803E00              <1>     cmp byte [rsi + mft.bSig], mftFree
   287                              <1>     retne   ;If not free, we exit
