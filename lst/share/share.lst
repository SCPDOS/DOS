    14 000007F9 C3                  <4>  ret
    15                              <4> %assign retOff %%_ret-$$
    36                              <3> %%a:
    37                              <3> 
   622                              <1> ;We get here if this file has no MFT.
   623                              <1> ;Create an MFT entry. dl and ecx are always preserved in functions below
   624 000007FA 81C116000000        <1>     add ecx, mft_size   ;ecx now has the full MFT entry size
   625 00000800 E8BB000000          <1>     call findFreeMFT
   626 00000805 730F                <1>     jnc .buildMFT
   627 00000807 E847000000          <1>     call defragMFTArena ;Returns rbx -> Free MFT, eax = Free MFT size
   628 0000080C 39C8                <1>     cmp eax, ecx        ;Do we fit in this free space?
   629 0000080E 7306                <1>     jnc .buildMFT
   630                              <1> ;Here if CF=CY. Return Sharing buffer full error!
   631 00000810 B824000000          <1>     mov eax, errShrFul
   632                              <1>     return
    13                              <2> %%_ret:
    14 00000815 C3                  <2>  ret
    15                              <2> %assign retOff %%_ret-$$
   633                              <1> .buildMFT:
   634                              <1> ;Here we have the following values:
   635                              <1> ;rsi -> String to copy in
   636                              <1> ;rbx -> Space to allocate the MFT in. rbx points to a free MFT.
   637                              <1> ;ecx = New MFT full size
   638                              <1> ;dl = String checksum 
   639                              <1> 
   640                              <1> ;Work out if we want to split space into two MFTs or keep it as one.
   641                              <1> ;Check if the MFT we are pointing at has enough space for a minimum mft and
   642                              <1> ; our MFT. If there is more than enough space, we split into two MFTs. 
   643                              <1> ;Else, we just allocate the whole space and waste the few extra bytes.
   644 00000816 8B4301              <1>     mov eax, dword [rbx + mft.dLen] ;Get the current size of the free MFT
   645 00000819 29C8                <1>     sub eax, ecx        ;Remove our own allocation from the free MFT size
   646 0000081B 3D26000000          <1>     cmp eax, MIN_MFT_SIZE
   647 00000820 760D                <1>     jbe .alloc   ;If this is beq, we just use this mft entry as is.
   648                              <1> ;eax has the size of the new free block
   649 00000822 488D3C0B            <1>     lea rdi, qword [rbx + rcx]  ;Point rdi past the end of our new mft
   650 00000826 C60700              <1>     mov byte [rdi + mft.bSig], mftFree  ;Make the new free block
   651 00000829 894701              <1>     mov dword [rdi + mft.dLen], eax     ;Set the new free block's size
   652 0000082C 894B01              <1>     mov dword [rbx + mft.dLen], ecx     ;Set the newly allocated block's size
   653                              <1> .alloc:
   654                              <1> ;Finally, allocate the MFT. The size, if modified, is done already.
   655 0000082F C60301              <1>     mov byte [rbx + mft.bSig], mftAlloc
   656 00000832 48C7430600000000    <1>     mov qword [rbx + mft.pLock], 0
   657 0000083A 48C7430E00000000    <1>     mov qword [rbx + mft.pSFT], 0
   658 00000842 885305              <1>     mov byte [rbx + mft.bCheckSum], dl  ;Set the checksum immediately.
   659 00000845 81E916000000        <1>     sub ecx, mft_size   ;Now get just the string length
   660 0000084B 488D7B16            <1>     lea rdi, qword [rbx + mft.sName] 
   661 0000084F F3A4                <1>     rep movsb   ;Move the string over
   662 00000851 F8                  <1>     clc
   663                              <1>     return
    13                              <2> %%_ret:
    14 00000852 C3                  <2>  ret
    15                              <2> %assign retOff %%_ret-$$
   664                              <1> 
   665                              <1> defragMFTArena:
   666                              <1> ;Defragments the MFT arena. Moves all allocated MFTs to the start.
   667                              <1> ;Creates a single large free MFT from all the free space.
   668                              <1> ;Input: Nothing
   669                              <1> ;Output: MFT arena defragged.
   670                              <1> ;        rbx -> New free MFT
   671                              <1> ;        eax = New Free MFT size
   672                              <1> ; All other regs preserved.
   673 00000853 51                  <1>     push rcx
   674 00000854 52                  <1>     push rdx
   675 00000855 56                  <1>     push rsi
   676 00000856 57                  <1>     push rdi
   677                              <1> ;rsi = Read pointer
   678                              <1> ;rdi = Write pointer
   679                              <1> ;edx = Free space accumulator
   680 00000857 488B35(00000000)    <1>     mov rsi, qword [pMftArena]
   681 0000085E 4889F7              <1>     mov rdi, rsi
   682 00000861 31D2                <1>     xor edx, edx
   683                              <1> .lp:
   684                              <1> ;If we encounter an allocated mft, we move it over, moving the 
   685                              <1> ; the read and write pointers. If we encounter a free mft, we add its
   686                              <1> ; size and move the read pointer.
   687 00000863 803E00              <1>     cmp byte [rsi + mft.bSig], mftFree
   688 00000866 7C26                <1>     jl .exit    ;At this point, all compression is done. Goto end
   689 00000868 741A                <1>     je .free
   690                              <1> ;Here we copy over. Before we do, we walk down the SFT chain
   691                              <1> ; updating the MFT pointer in each SFT.
   692                              <1> ;rsi -> Allocated MFT
   693                              <1> ;rdi -> Where this MFT will be moved to
   694 0000086A 488B5E0E            <1>     mov rbx, qword [rsi + mft.pSFT]     ;Point rbx to the first SFT in chain.
   695                              <1> .sftLp:
   696 0000086E 4885DB              <1>     test rbx, rbx   ;End of SFT chain?
   697 00000871 740A                <1>     jz .sftEnd
   698 00000873 48897B4F            <1>     mov qword [rbx + sft.pMFT], rdi     ;Update the SFT's MFT pointer
   699 00000877 488B5B3B            <1>     mov rbx, qword [rbx + sft.pNextSFT]
   700 0000087B EBF1                <1>     jmp short .sftLp
   701                              <1> .sftEnd:
   702                              <1> ;All SFTs updated, now we copy the MFT up.
   703 0000087D 8B4E01              <1>     mov ecx, dword [rsi + mft.dLen] ;Get the length of this MFT
   704 00000880 F3A4                <1>     rep movsb   ;Moves both pointers to the end of the MFT
   705                              <1> ;Now rdi points to the next write space and rsi points to the next MFT
   706 00000882 EBDF                <1>     jmp short .lp
   707                              <1> .free:
   708                              <1> ;Dont worry about overflow. Max dLen is 1Mb, way less than 32 bit max.
   709 00000884 8B4601              <1>     mov eax, dword [rsi + mft.dLen] ;Get the length
   710 00000887 01C2                <1>     add edx, eax    ;Add to the free space accumulator
   711 00000889 4801C6              <1>     add rsi, rax    ;Move the read pointer past this free space
   712 0000088C EBD5                <1>     jmp short .lp
   713                              <1> .exit:
   714                              <1> ;Now we must make a single free MFT at the write pointer with the 
   715                              <1> ; correct size and assert it is correct
   716                              <1> ;rdi -> Where to make this MFT
   717                              <1> ;edx = Accumulated free space
   718 0000088E C60700              <1>     mov byte [rdi + mft.bSig], mftFree
   719 00000891 895701              <1>     mov dword [rdi + mft.dLen], edx
   720 00000894 89D0                <1>     mov eax, edx    ;Get the free MFT size into eax
   721 00000896 4889FB              <1>     mov rbx, rdi    ;Get the free MFT pointer into rbx
   722 00000899 4801D7              <1>     add rdi, rdx    ;Now check the MFT chain is not corrupted
   723 0000089C 803FFF              <1>     cmp byte [rdi + mft.bSig], mftEnd
   724 0000089F 7505                <1>     jne .crash
   725 000008A1 5F                  <1>     pop rdi
   726 000008A2 5E                  <1>     pop rsi
   727 000008A3 5A                  <1>     pop rdx
   728 000008A4 59                  <1>     pop rcx
   729                              <1>     return
    13                              <2> %%_ret:
    14 000008A5 C3                  <2>  ret
    15                              <2> %assign retOff %%_ret-$$
   730                              <1> .crash:
   731 000008A6 E8CF000000          <1>     call errPrintAndHalt    ;No return. Use call to push string ptr to stack
   732 000008AB 4D4654204445465241- <1>     db "MFT DEFRAG FAILURE",CR,LF,NUL
   732 000008B4 47204641494C555245- <1>
   732 000008BD 0D0A00              <1>
