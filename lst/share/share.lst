   308                              <1> freeLocks:
   309                              <1> ;Frees all file locks associated to this rdi. 
   310                              <1> ;Input: rdi -> SFT for this file
   311                              <1> ;       edx = Flag for if we should free locks for process
   312                              <1> ;             -1 -> Free for process (on 5D04h calls)
   313                              <1> ;              0 -> Dont bother (otherwise)
   314                              <1> ;Output: All file locks owned by this process are delinked from the 
   315                              <1> ;        file chain and added to the free lock chain.
   316                              <1> ;Trashes rax, rbx, rsi.
   317 00000627 488B5F4F            <1>     mov rbx, qword [rdi + sft.pMFT]     ;Get MFT ptr in rbx
   318 0000062B 488B7306            <1>     mov rsi, qword [rbx + mft.pLock]    ;Get the first lock of MFT in rsi 
   319 0000062F 4881C306000000      <1>     add rbx, mft.pLock  ;Point rbx to the link field of the previous lock
   320                              <1> .lp:
   321 00000636 4885F6              <1>     test rsi, rsi   ;End of list? 
   322                              <1>     retz            ;Exit if so
    41                              <2> cret z
