   390                              <1> closeRenDel:
   391                              <1> ;On rename/delete/setattr, this function is called to check we can proceed
   392                              <1> ; with the operation.
   393                              <1> ;Finds MFT based on the filename in fname1Ptr in the dosseg
   394                              <1> ;----------------------------------------------------------------------------
   395                              <1> ;Input: fname1Ptr -> Filename to do check on
   396                              <1> ;Output: Nothing
   397                              <1> ;----------------------------------------------------------------------------
   398                              <1> ;If 
   399                              <1> ;   the file is not open, then we return ok.
   400                              <1> ;Else if 
   401                              <1> ;   the file is opened by us uniquely and is open in compatibility mode,
   402                              <1> ;   then close the file and return ok.
   403                              <1> ;Else, we fail.
   404                              <1> ;----------------------------------------------------------------------------
   405 000002DC 4150                <1>     push r8
   406 000002DE 4C8B05(26000000)    <1>     mov r8, qword [pDosseg]
   407 000002E5 E80B010000          <1>     call critEnter
   408                              <1> .again:
   409 000002EA 498BB050060000      <1>     mov rsi, qword [r8 + fname1Ptr] ;Get the filename pointer
   410 000002F1 E8B2050000          <1>     call findMFT    ;Looks for this file
   411 000002F6 7237                <1>     jc .exit    ;If the file doesn't exist, exit
   412                              <1> ;File MFT found. rbx -> MFT. 
   413                              <1> ; Now check that all the files on this chain have the mid and pid of 
   414                              <1> ; the requester and (are in compatibility mode or a net SFT).
   415 000002F8 488B730E            <1>     mov rsi, qword [rbx + mft.pSFT] ;This cant be empty so it must be an SFT
   416 000002FC 4889F7              <1>     mov rdi, rsi    ;Save this SFT pointer in rdi
   417                              <1> .scanLp:
   418 000002FF 418B8073040000      <1>     mov eax, dword [r8 + dMID]
   419 00000306 3B4643              <1>     cmp eax, dword [rsi + sft.dMID]
   420 00000309 7524                <1>     jne .exit
   421 0000030B 498B806B040000      <1>     mov rax, qword [r8 + qPID]
   422 00000312 483B4647            <1>     cmp rax, qword [rsi + sft.qPID]
   423 00000316 7517                <1>     jne .exit
   424 00000318 0FB74602            <1>     movzx eax, word [rsi + sft.wOpenMode]
   425 0000031C 25F0000000          <1>     and eax, 0F0h    ;Get the sharing mode
   426                              <1> ;If compatibility mode or net fcb, proceed with close
   427 00000321 3D70000000          <1>     cmp eax, openNetFCBShr
   428 00000326 740F                <1>     je .next
   429 00000328 3D00000000          <1>     cmp eax, openCompat
   430 0000032D 7408                <1>     je .next
   431                              <1> .exit:
   432 0000032F E8CB000000          <1>     call critExit
   433 00000334 4158                <1>     pop r8
   434                              <1>     return
    13                              <2> %%_ret:
    14 00000336 C3                  <2>  ret
    15                              <2> %assign retOff %%_ret-$$
   435                              <1> .next:
   436 00000337 488B763B            <1>     mov rsi, qword [rsi + sft.pNextSFT]
   437 0000033B 4885F6              <1>     test rsi, rsi
   438 0000033E 75BF                <1>     jnz .scanLp
   439                              <1> ;Here we must close all the handles referring to this SFT
   440                              <1> ;rdi -> First SFT 
   441 00000340 4989B863070000      <1>     mov qword [r8 + currentSFT], rdi    ;Set this SFT as current SFT
   442 00000347 E8DF010000          <1>     call closeHandlesForSFT
   443 0000034C E8D2010000          <1>     call closeSFT
   444 00000351 E994FFFFFF          <1>     jmp .again  ;Now do this again until no more files
   445                              <1> 
