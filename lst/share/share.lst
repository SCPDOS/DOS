   391                              <1> checkPermissions:
   392                              <1> ;Checks for sharing conflicts of the new SFT against all
   393                              <1> ; other SFTs in the chain. 
   394                              <1> ;If both new SFT and SFT on chain are compatibility 
   395                              <1> ; then check machine id. If they are equal, goto next SFT on chain.
   396                              <1> ;Else do table logic as described below.
   397                              <1> ;
   398                              <1> ;Input: rsi -> New SFT, with machine id field set
   399                              <1> ;       rbx -> MFT for this file.
   400                              <1> ;Output: CF=NC: No sharing conflicts.
   401                              <1> ;        CF=CY: Sharing conflict, eax has error code
   402 000006DA 53                  <1>     push rbx
   403 000006DB 4889F7              <1>     mov rdi, rsi        ;Save new SFT ptr in rdi
   404 000006DE E8A5000000          <1>     call getOpenMode    ;Get the adjusted sharing mode in eax
   405 000006E3 89C2                <1>     mov edx, eax        ;Use edx as the marker for if compat or not
   406 000006E5 81E2F0000000        <1>     and edx, 0F0h       ;Are the share bits 0?
   407 000006EB 7405                <1>     jz .compat
   408 000006ED BAF0000000          <1>     mov edx, 0F0h       ;Set to indicate no compat mode
   409                              <1> .compat:
   410 000006F2 E86C000000          <1>     call getTableIndex  ;Get table index in eax for new SFT. Use as row index
   411 000006F7 D1E0                <1>     shl eax, 1          ;Multiply by two, each row is a word
   412 000006F9 488D3545000000      <1>     lea rsi, .tbl
   413 00000700 0FB72C06            <1>     movzx ebp, word [rsi + rax] ;Get the table entry (bit row) into ebp
   414 00000704 488B730E            <1>     mov rsi, qword [rbx + mft.pSFT] ;Get the first SFT in chain
   415                              <1> .lp:
   416 00000708 4885F6              <1>     test rsi, rsi       ;Are we at the end of the chain?
   417 0000070B 7433                <1>     jz .exit            ;If so, all ok!
   418 0000070D E876000000          <1>     call getOpenMode    ;Else, get the adjusted open mode in eax for this sft
   419 00000712 89C1                <1>     mov ecx, eax
   420 00000714 81E10F000000        <1>     and ecx, 0Fh        ;Get the share bits
   421 0000071A 09D1                <1>     or ecx, edx         ;Check if both new and old files are in compat mode
   422 0000071C 7508                <1>     jnz .notBothCompat
   423                              <1> ;Both in compat mode means we do machine id check instead.
   424                              <1> ;If they match, we skip.
   425 0000071E 8B5E43              <1>     mov ebx, dword [rsi + sft.dMID]
   426 00000721 395F43              <1>     cmp dword [rdi + sft.dMID], ebx
   427 00000724 740F                <1>     je .gotoNext
   428                              <1> .notBothCompat:
   429 00000726 E838000000          <1>     call getTableIndex  ;Get table index but use as a column (bit) index
   430 0000072B 678D4802            <1>     lea ecx, dword [eax + 2]    ;+2 to drop the x bit and push our bit into CF
   431 0000072F 89E8                <1>     mov eax, ebp        ;Move row we are interested in into eax
   432 00000731 D3E8                <1>     shr eax, cl         ;Shift the bit we are interested into CF to check
   433 00000733 7206                <1>     jc .exitBad
   434                              <1> .gotoNext:
   435 00000735 488B763B            <1>     mov rsi, qword [rsi + sft.pNextSFT] ;Goto next SFT
   436 00000739 EBCD                <1>     jmp short .lp
   437                              <1> .exitBad:
   438                              <1> ;We come here with CF=CY
   439 0000073B B820000000          <1>     mov eax, errShrVio
   440                              <1> .exit:
   441 00000740 4889FE              <1>     mov rsi, rdi        ;Point rsi back to the new SFT
   442 00000743 5B                  <1>     pop rbx             ;Get back MFT pointer
   443                              <1>     return
    13                              <2> %%_ret:
    14 00000744 C3                  <2>  ret
    15                              <2> %assign retOff %%_ret-$$
   444                              <1> 
   445                              <1> .tbl:          
   446                              <1> ;Each word is a packed entry of 15 meaningful bits with the 
   447                              <1> ; lower most bit always set and meaningless.
   448                              <1> ;That is, each word is 5 lots of 3(share mode) bits.
   449                              <1> ;The bits of each word are interpreted as follows:
   450                              <1> ;     0NNNRRRWWWAAACCCxb 
   451                              <1> ; where: 
   452                              <1> ; NNN = Deny None permissions
   453                              <1> ; RRR = Deny Read permissions 
   454                              <1> ; WWW = Deny Write permissions
   455                              <1> ; AAA = Deny All permissions
   456                              <1> ; CCC = Compat permissions
   457                              <1> ; x   = Set and ignored.
   458                              <1> ;In each triple:
   459                              <1> ;   0LMNb 
   460                              <1> ; the bits are interpreted as:
   461                              <1> ; L = What to do on Read/Write access. 
   462                              <1> ; M = What to do on Write access. 
   463                              <1> ; N = What to do on Read access.
   464                              <1> ;If a bit is set, it means this combination is not allowed.
   465                              <1> ;
   466                              <1> ;We get the word we are interested in based on the open mode of
   467                              <1> ; the new SFT. This gives us a row. We then use the open mode of
   468                              <1> ; every SFT on the MFT's SFT chain, to get a bit offset into this word.
   469                              <1> ;If for every element of the SFT chain the bit in the word is 0,
   470                              <1> ; we are ok. If ever this bit is 1, we have a sharing violation.
   471                              <1> ;
   472                              <1> ;The values of this table obtained from the matrix of the the DOS 3.3 
   473                              <1> ; programmers guide (p. 6-121), where N=1 and Y=0, with the following changes
   474                              <1> ; to make implementation easier (as the numbers are ordered as so):
   475                              <1> ;1) We swap the order of the openRWAcc and openWrAcc columns/rows
   476                              <1> ;    putting RW always at the left/bottom most part. 
   477                              <1> ;2) Each row of the table below is for "subsequent IO" where each
   478                              <1> ;    bit of the entry is the column.
   479                              <1> ;3) We duplicate Deny all as for Compat
   480                              <1> 
   481                              <1> ;Table annotated as follows: 
   482                              <1> ;N=Deny none
   483                              <1> ;R=Deny read
   484                              <1> ;W=Deny write
   485                              <1> ;A=Deny all
   486                              <1> ;C=Compat
   487                              <1> ;B=Open Read/Write (both)
   488                              <1> ;O=Open Write (output)
   489                              <1> ;I=Open Read (input)
   490                              <1> ;
   491                              <1> ;        Initial Open modes
   492                              <1> ;       N   R   W   A   C  x    ;Subsequent opens
   493                              <1> ;      BOI BOI BOI BOI BOI x    
   494 00000745 FFFF                <1>     dw 111_111_111_111_111_1b   ;I        openCompat|openRdAcc
   495 00000747 FFFF                <1>     dw 111_111_111_111_111_1b   ;O C      openCompat|openWrAcc
   496 00000749 FFFF                <1>     dw 111_111_111_111_111_1b   ;B        openCompat|openRWAcc
   497                              <1> 
   498 0000074B FFFF                <1>     dw 111_111_111_111_111_1b   ;I      openDenRWShr|openRdAcc
   499 0000074D FFFF                <1>     dw 111_111_111_111_111_1b   ;O A    openDenRWShr|openWrAcc
   500 0000074F FFFF                <1>     dw 111_111_111_111_111_1b   ;B      openDenRWShr|openRWAcc
   501                              <1> 
   502 00000751 7FDF                <1>     dw 110_111_110_111_111_1b   ;I      openDenWrShr|openRdAcc
   503 00000753 FFDB                <1>     dw 110_110_111_111_111_1b   ;O W    openDenWrShr|openWrAcc
   504 00000755 FFDF                <1>     dw 110_111_111_111_111_1b   ;B      openDenWrShr|openRWAcc
   505                              <1> 
   506 00000757 FFBE                <1>     dw 101_111_101_111_111_1b   ;I      openDenRdShr|openRdAcc
   507 00000759 FFB7                <1>     dw 101_101_111_111_111_1b   ;O R    openDenRdShr|openWrAcc
   508 0000075B FFBF                <1>     dw 101_111_111_111_111_1b   ;B      openDenRdShr|openRWAcc
   509                              <1> 
   510 0000075D 7F1C                <1>     dw 000_111_000_111_111_1b   ;I      openDenNoShr|openRdAcc
   511 0000075F FF03                <1>     dw 000_000_111_111_111_1b   ;O N    openDenNoShr|openWrAcc
   512 00000761 FF1F                <1>     dw 000_111_111_111_111_1b   ;B      openDenNoShr|openWRAcc
   513                              <1> 
   514                              <1> getTableIndex:
   515                              <1> ;Turns the adjusted open mode into a table index value
   516                              <1> ;Input: eax = Adjusted open mode
   517                              <1> ;Output: eax = Index into the table (Number 0-14)
   518                              <1> ;        ecx = Share group (0-4)
   519                              <1> ;All other regs preserved
   520 00000763 89C1                <1>     mov ecx, eax
   521 00000765 250F000000          <1>     and eax, 0Fh    ;Isolate the open mode bits only
   522 0000076A 81E1F0000000        <1>     and ecx, 0F0h   ;Isolate the share bits only
   523 00000770 81F970000000        <1>     cmp ecx, openNetFCBShr  ;Is this a net FCB share?
   524 00000776 7502                <1>     jnz .notNetFCB
   525 00000778 31C9                <1>     xor ecx, ecx    ;Compatibility share in this case
   526                              <1> .notNetFCB:
   527                              <1> ;We want ecx <- (ecx >> 4)*3 to get the share group
   528 0000077A C1E904              <1>     shr ecx, 4      ;Get the share group
   529 0000077D 52                  <1>     push rdx
   530 0000077E 89CA                <1>     mov edx, ecx    ;Save it in edx
   531 00000780 D1E2                <1>     shl edx, 1      ;Multiply by 2
   532 00000782 01CA                <1>     add edx, ecx    ;Add to get it multiplied by three
   533 00000784 01D0                <1>     add eax, edx    ;Add share group*3 to the offset into the group
   534 00000786 5A                  <1>     pop rdx
   535                              <1>     return
    13                              <2> %%_ret:
    14 00000787 C3                  <2>  ret
    15                              <2> %assign retOff %%_ret-$$
   536                              <1> 
   537                              <1> getOpenMode:
   538                              <1> ;Gets the adjusted open mode.
   539                              <1> ;--------------------------------------------------------------------
   540                              <1> ;Input: rsi -> SFT to get adjusted open mode for
   541                              <1> ;Output: eax = Adjusted open mode.
   542                              <1> ;All other registers preserved.
   543                              <1> ;--------------------------------------------------------------------
   544                              <1> ;If not an FCB of any kind, then everything is ok. 
   545                              <1> ;If an SFTFCB then we put it into openCompat | openRW.
   546                              <1> ;If a NETFCB then we put it into openCompat.
   547                              <1> ;If RO file opened in openCompat, make into openDenWrShr | openRdAcc.
   548 00000788 53                  <1>     push rbx
   549 00000789 0FB74602            <1>     movzx eax, word [rsi + sft.wOpenMode]
   550 0000078D 66A90080            <1>     test ax, openSFTFCB ;Is this a local FCB?
   551 00000791 7405                <1>     jz .notFCB
   552 00000793 B802000000          <1>     mov eax, openCompat | openRWAcc  ;FCBs have r/w access in compat mode
   553                              <1> .notFCB:
   554 00000798 89C3                <1>     mov ebx, eax
   555 0000079A 81E3F0000000        <1>     and ebx, 0F0h           ;Mask off the access bits
   556 000007A0 81FB70000000        <1>     cmp ebx, openNetFCBShr  ;Is this a net FCB?
   557 000007A6 7505                <1>     jne .notNetFCB
   558 000007A8 250F000000          <1>     and eax, 0Fh        ;Mask off the share bits, turn into compat share
   559                              <1> .notNetFCB:
   560                              <1> ;Now al has the real open mode for this file. Do RO check now
   561 000007AD 89C3                <1>     mov ebx, eax
