   433                              <1> checkPermissions:
   434                              <1> ;Checks for sharing conflicts of the new SFT against all
   435                              <1> ; other SFTs in the chain. 
   436                              <1> ;If both new SFT and SFT on chain are compatibility 
   437                              <1> ; then check machine id. If they are equal, goto next SFT on chain.
   438                              <1> ;Else do table logic as described below.
   439                              <1> ;
   440                              <1> ;Input: rsi -> New SFT, with machine id field set
   441                              <1> ;       rbx -> MFT for this file.
   442                              <1> ;Output: CF=NC: No sharing conflicts.
   443                              <1> ;        CF=CY: Sharing conflict, eax has error code
   444                              <1> ; Preserves rbx and rsi.
   445 00000706 53                  <1>     push rbx
   446 00000707 4889F7              <1>     mov rdi, rsi        ;Save new SFT ptr in rdi
   447 0000070A E8A5000000          <1>     call getOpenMode    ;Get adjusted sharing mode in eax for new file in rdi
   448 0000070F 89C2                <1>     mov edx, eax        ;Use edx as the marker for if compat or not
   449 00000711 81E2F0000000        <1>     and edx, 0F0h       ;Are the share bits 0?
   450 00000717 7405                <1>     jz .compat
   451 00000719 BAF0000000          <1>     mov edx, 0F0h       ;Set to indicate no compat mode
   452                              <1> .compat:
   453 0000071E E86C000000          <1>     call getTableIndex  ;Get table index in eax for new SFT. Use as row index
   454 00000723 D1E0                <1>     shl eax, 1          ;Multiply by two, each row is a word
   455 00000725 488D3545000000      <1>     lea rsi, .tbl
   456 0000072C 0FB72C06            <1>     movzx ebp, word [rsi + rax] ;Get the table entry (bit row) into ebp
   457 00000730 488B730E            <1>     mov rsi, qword [rbx + mft.pSFT] ;Get the first SFT in chain
   458                              <1> .lp:
   459 00000734 4885F6              <1>     test rsi, rsi       ;Are we at the end of the chain?
   460 00000737 7433                <1>     jz .exit            ;If so, all ok!
   461 00000739 E876000000          <1>     call getOpenMode    ;Else, get the adjusted open mode in eax for this sft
   462 0000073E 89C1                <1>     mov ecx, eax
   463 00000740 81E10F000000        <1>     and ecx, 0Fh        ;Get the share bits
   464 00000746 09D1                <1>     or ecx, edx         ;Check if both new and old files are in compat mode
   465 00000748 7508                <1>     jnz .notBothCompat
   466                              <1> ;Both in compat mode means we do machine id check instead.
   467                              <1> ;If they match, we skip.
   468 0000074A 8B5E43              <1>     mov ebx, dword [rsi + sft.dMID]
   469 0000074D 395F43              <1>     cmp dword [rdi + sft.dMID], ebx
   470 00000750 740F                <1>     je .gotoNext
   471                              <1> .notBothCompat:
   472 00000752 E838000000          <1>     call getTableIndex  ;Get table index but use as a column (bit) index
   473 00000757 678D4802            <1>     lea ecx, dword [eax + 2]    ;+2 to drop the x bit and push our bit into CF
   474 0000075B 89E8                <1>     mov eax, ebp        ;Move row we are interested in into eax
   475 0000075D D3E8                <1>     shr eax, cl         ;Shift the bit we are interested into CF to check
   476 0000075F 7206                <1>     jc .exitBad
   477                              <1> .gotoNext:
   478 00000761 488B763B            <1>     mov rsi, qword [rsi + sft.pNextSFT] ;Goto next SFT
   479 00000765 EBCD                <1>     jmp short .lp
   480                              <1> .exitBad:
   481                              <1> ;We come here with CF=CY
   482 00000767 B820000000          <1>     mov eax, errShrVio
   483                              <1> .exit:
   484 0000076C 4889FE              <1>     mov rsi, rdi        ;Point rsi back to the new SFT
   485 0000076F 5B                  <1>     pop rbx             ;Get back MFT pointer
   486                              <1>     return
