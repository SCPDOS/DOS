   295 0000020F FFC9                <1>     dec ecx
   296 00000211 7406                <1>     jz .goEnd
   297 00000213 488B763B            <1>     mov rsi, qword [rsi + sft.pNextSFT]
   298 00000217 EBF1                <1>     jmp short .sftLp
