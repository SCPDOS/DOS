   563                              <1> .gotoNextSFT:
   564                              <1> ;Returns in rsi the next SFT entry.
   565                              <1> ;Input: rdi -> SFT we are updating from.
   566                              <1> ;       rsi -> SFT we just updated.
   567                              <1> ;Output: ZF=NZ: rsi -> Next SFT in the chain.
   568                              <1> ;        ZF=ZE: End of SFT chain.
   569 000003EC 488B763B            <1>     mov rsi, qword [rsi + sft.pNextSFT]
   570 000003F0 4885F6              <1>     test rsi, rsi
   571                              <1>     retz
