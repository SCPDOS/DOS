   551                              <1> .open:
   552                              <1> ;Here we handle new file opens! Copies data from the 
   553                              <1> ; topmost (earliest opened) SFT (rsi) of the SFT chain into 
   554                              <1> ; the newly opened SFT (rdi)
   555 000003CA 8B4613              <1>     mov eax, dword [rsi + sft.dTimeDate]
   556 000003CD 894713              <1>     mov dword [rdi + sft.dTimeDate], eax
   557 000003D0 8B4617              <1>     mov eax, dword [rsi + sft.dFileSize]
   558 000003D3 894717              <1>     mov dword [rdi + sft.dFileSize], eax
   559 000003D6 8B460F              <1>     mov eax, dword [rsi + sft.dStartClust]
   560 000003D9 89470F              <1>     mov dword [rdi + sft.dStartClust], eax
   561 000003DC 894723              <1>     mov dword [rdi + sft.dAbsClust], eax
   562 000003DF C7471F00000000      <1>     mov dword [rdi + sft.dRelClust], 0
   563 000003E6 EBA2                <1>     jmp short .exit
