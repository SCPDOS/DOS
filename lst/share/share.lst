   322                              <1> closeNetworkFiles:   
   323                              <1> ;Close a newly created SFT-FCB handle for a procedure.
   324                              <1> ;Network SFT-FCBs handles are all collapsed into one SFT.
   325                              <1> ;----------------------------------------------------------------------------
   326                              <1> ;Input: rsi -> Newly created SFT
   327                              <1> ;       ax = SFTNdx for this newly created file
   328                              <1> ;Output: CF=NC: ax = SFTNdx for the SFT (Same as on input if not a SFT-FCB)
   329                              <1> ;        CF=CY: No SFT found
   330                              <1> ;----------------------------------------------------------------------------
   331                              <1> ;If
   332                              <1> ;   rsi -> SFT that is a network SFT-FCB (i.e. bit openNetFCBShr set 
   333                              <1> ;   in openmode), then we close any duplicate handles using a single
   334                              <1> ;   SFT to maintain the state (if there are none then we use this SFT
   335                              <1> ;   as the SFT-FCB). We increment the new main SFT refcount instead of 
   336                              <1> ;   having multiple SFTs.
   337                              <1> ;----------------------------------------------------------------------------
   338 0000024C 4150                <1>     push r8
   339 0000024E 4C8B05(26000000)    <1>     mov r8, qword [pDosseg]
   340 00000255 0FB74602            <1>     movzx eax, word [rsi + sft.wOpenMode]
   341 00000259 25F0000000          <1>     and eax, 0F0h    ;Save the share bits
   342 0000025E 3D70000000          <1>     cmp eax, openNetFCBShr
   343 00000263 7573                <1>     jne .exitNormal
   344 00000265 31DB                <1>     xor ebx, ebx
   345                              <1> .ptrLp:
   346 00000267 53                  <1>     push rbx
   347 00000268 B816120000          <1>     mov eax, 1216h  ;getSFTPtrfromSFTNdx -> Get in rdi the SFT for index bx
   348 0000026D CD2F                <1>     int 2Fh
   349 0000026F 5B                  <1>     pop rbx
   350 00000270 726E                <1>     jc .exit
   351 00000272 4839F7              <1>     cmp rdi, rsi    ;Skip ourselves
   352 00000275 742D                <1>     je .ptrNext
   353 00000277 66813F0000          <1>     cmp word [rdi + sft.wNumHandles], 0 ;Handle must have empty count
   354 0000027C 7426                <1>     je .ptrNext
   355 0000027E 0FB74602            <1>     movzx eax, word [rsi + sft.wOpenMode]
   356 00000282 663B4702            <1>     cmp ax, word [rdi + sft.wOpenMode]
   357 00000286 751C                <1>     jne .ptrNext
   358 00000288 8B4643              <1>     mov eax, dword [rsi + sft.dMID]
   359 0000028B 394743              <1>     cmp dword [rdi + sft.dMID], eax
   360 0000028E 7514                <1>     jne .ptrNext
   361 00000290 488B4647            <1>     mov rax, qword [rsi + sft.qPID]
   362 00000294 48394747            <1>     cmp qword [rdi + sft.qPID], rax
   363 00000298 750A                <1>     jne .ptrNext
   364 0000029A 488B464F            <1>     mov rax, qword [rsi + sft.pMFT]
   365 0000029E 4839474F            <1>     cmp qword [rdi + sft.pMFT], rax
   366 000002A2 7404                <1>     je .ptrFnd  ;If all this, then we have a duplicate net handle
   367                              <1> .ptrNext:
   368 000002A4 FFC3                <1>     inc ebx
   369 000002A6 EBBF                <1>     jmp short .ptrLp
   370                              <1> .ptrFnd:
   371                              <1> ;rsi is a duplicate of rdi for this process
   372 000002A8 66C7060000          <1>     mov word [rsi + sft.wNumHandles], 0 ;Free the handle we just allocated
   373 000002AD 57                  <1>     push rdi    ;rdi is the master FCB SFT 
   374 000002AE 53                  <1>     push rbx    ;Save the sftindex
   375 000002AF 4889F7              <1>     mov rdi, rsi
   376 000002B2 E88CFDFFFF          <1>     call close  ;Close the current SFT now
   377 000002B7 58                  <1>     pop rax     ;Get the sftindex into eax
   378 000002B8 5F                  <1>     pop rdi
   379 000002B9 66FF07              <1>     inc word [rdi + sft.wNumHandles]    ;Add one now
   380 000002BC 31DB                <1>     xor ebx, ebx
   381                              <1> .jftlp:
   382 000002BE 50                  <1>     push rax
   383 000002BF B820120000          <1>     mov eax, 1220h  ;getJFTPtr -> Get ptr to this jft entry in psp in rdi
   384 000002C4 CD2F                <1>     int 2Fh
   385 000002C6 58                  <1>     pop rax
   386 000002C7 7217                <1>     jc .exit
   387 000002C9 3807                <1>     cmp byte [rdi], al
   388 000002CB 7404                <1>     je .jftFnd
   389 000002CD FFC3                <1>     inc ebx
   390 000002CF EBED                <1>     jmp short .jftlp
   391                              <1> .jftFnd:
   392 000002D1 C607FF              <1>     mov byte [rdi], -1
   393 000002D4 89D8                <1>     mov eax, ebx
   394 000002D6 EB08                <1>     jmp short .exit
   395                              <1> .exitNormal:
   396 000002D8 410FB7806D070000    <1>     movzx eax, word [r8 + currentHdl]   ;Get the handle value to return
   397                              <1> .exit:
   398 000002E0 4158                <1>     pop r8
   399                              <1>     return
    13                              <2> %%_ret:
    14 000002E2 C3                  <2>  ret
    15                              <2> %assign retOff %%_ret-$$
