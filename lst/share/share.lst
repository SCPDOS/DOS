    44                                  
    45                                  ;---------------------------
    46                                  ;       Share code seg
    47                                  ;---------------------------
    48                                  segment .text code private align=16 use64
    49                                  ;Place this explicit .text section to calm nasm down
    50                                  segment code$r code private align=16 use64
    51                                  %include "./src/share/text/shmain.asm"
     1                              <1> ;-------------------------------------------------------------------------
     2                              <1> ;This file contains the all the functions that have external linkage.
     3                              <1> ;
     4                              <1> ; Int 2Fh handler -> Handles share check calls.
     5                              <1> ; open -> Creates or assignes and MFT for a newly opened/created SFT.
     6                              <1> ; close -> Releases all share resources allocated to an SFT.
     7                              <1> ; closeAllByMID -> Releases all sharing resources for SFTs made 
     8                              <1> ;   by a particular machine.
     9                              <1> ; closeAllByPID -> Releases all sharing resources for SFTs made 
    10                              <1> ;   by a particular machine and process.
    11                              <1> ; closeAllByName -> Releases all sharing resources allocated to 
    12                              <1> ;   a particular MFT for a given FQ filename.
    13                              <1> ; lockFile -> Assigns a file lock to a file.
    14                              <1> ; unlockFile -> Releases a file lock from a file.
    15                              <1> ; checkRegionLock -> Checks that the region specified is not locked.
    16                              <1> ; getSFTShareInfo -> Gets sharing information about a particular SFT.
    17                              <1> ; updateFCB -> Unused and should not be touched.
    18                              <1> ; getFirstClustFCB -> Unused and should not be touched.
    19                              <1> ; closeDupNetFCB -> Collapses duplicate Net SFT-FCBs into a single SFT.
    20                              <1> ; closeCompatHdls -> Closes all compat mode and Net SFT-FCBs for a file.
    21                              <1> ; dirUpdate -> Updates directory information across all SFTs for a file.
    22                              <1> ;-------------------------------------------------------------------------
    23                              <1> 
    24                              <1> i2fHandler:
    25 00000000 80FC10              <1>     cmp ah, 10h ;Is this call for us?
    26 00000003 7508                <1>     jne .gotoNext
    27 00000005 84C0                <1>     test al, al ;Do we test presence of share?
    28 00000007 7502                <1>     jnz .exit   ;If not, probably badly behaved code. Let it return silently
    29 00000009 B0FF                <1>     mov al, -1  ;Else, indicate we are already installed
    30                              <1> .exit:
    31 0000000B 48CF                <1>     iretq
    32                              <1> .gotoNext:
    33 0000000D FF25(1E000000)      <1>     jmp qword [pOldI2Fh]
    34                              <1> 
    35                              <1> open:           
    36                              <1> ;Called on file create/open. Creates/Finds an MFT entry for the file
    37                              <1> ; being opened and adds the new SFT to the MFT chain.
    38                              <1> ;----------------------------------------------------------------------------
    39                              <1> ;Input: qword [fname1Ptr] -> Fully qualified pathname to open
    40                              <1> ;       qword [currentSFT] -> SFT that was just created/opened
    41                              <1> ;           This SFT needs the following fields filled in:
    42                              <1> ;               .wOpenMode
    43                              <1> ;               .bFileAttrib
    44                              <1> ;               .dMID
    45                              <1> ;               .qPID
    46                              <1> ;               .pMFT
    47                              <1> ;       qword [qPID] -> Process ID of the requesting task
    48                              <1> ;       dword [dMID] -> Machine ID of the requesting task
    49                              <1> ;Output: CF=NC: Proceed happily with SFT linked into the MFT for the file.
    50                              <1> ;        CF=CY: eax = Error code for request. Abort, free SFT.
    51                              <1> ;Use r8 as DOSSEG base
    52                              <1> ;----------------------------------------------------------------------------
    53 00000013 E8ED030000          <1>     call critEnter
    54 00000018 4150                <1>     push r8
    55 0000001A 4C8B05(26000000)    <1>     mov r8, qword [pDosseg]
    56 00000021 498BB050060000      <1>     mov rsi, qword [r8 + fname1Ptr] ;Get the filename pointer
    57 00000028 E8C5070000          <1>     call getMFT
    58 0000002D 720C                <1>     jc .exit
    59                              <1> ;rbx -> MFT for this file here.
    60 0000002F 498BB063070000      <1>     mov rsi, qword [r8 + currentSFT]    ;Get the current SFT now
    61 00000036 E879060000          <1>     call addSFTtoMFT    ;Bubble CF
    62                              <1> .exit:
    63 0000003B 4158                <1>     pop r8
    64 0000003D E8CD030000          <1>     call critExit
    65                              <1>     return
    13                              <2> %%_ret:
    14 00000042 C3                  <2>  ret
    15                              <2> %assign retOff %%_ret-$$
    66                              <1> 
    67                              <1> close:          
    68                              <1> ;Called on file close. Frees all locks associated with file if the 
    69                              <1> ; handle count is 0 or -1. If the last file on an MFT, frees the MFT too!
    70                              <1> ;Input: rdi -> SFT we are closing.
    71 00000043 E8BD030000          <1>     call critEnter
    72 00000048 488B5F4F            <1>     mov rbx, qword [rdi + sft.pMFT]
    73 0000004C 4885DB              <1>     test rbx, rbx   ;If this is an SFT from before Share loaded, do nothing!
    74 0000004F 741C                <1>     jz .exit        ;All functions expect there to be a MFT for this file
    75 00000051 0FBF07              <1>     movsx eax, word [rdi + sft.wNumHandles] ;Get the count
    76 00000054 85C0                <1>     test eax, eax   ;If count is zero, free all sharing data
    77 00000056 7404                <1>     jz .goClose
    78 00000058 FFC0                <1>     inc eax         ;If this handle is -1, also free any sharing data.
    79 0000005A 7511                <1>     jnz .exit       ;If not -1 or 0, then inc eax > 0 and so we just exit
    80                              <1> .goClose:
    81 0000005C E8FA050000          <1>     call freeLocks  ;Free all locks associated to this SFT
    82 00000061 E8A8050000          <1>     call removeSFTfromMFT ;Delink this SFT from the SFT link
    83 00000066 7505                <1>     jnz .exit       ;If not last SFT in MFT chain, dont free MFT
    84 00000068 E852050000          <1>     call freeMFT    ;If no more SFTs, free the MFT. Do small GC.
    85                              <1> .exit:
    86 0000006D E89D030000          <1>     call critExit
    87                              <1>     return
    13                              <2> %%_ret:
    14 00000072 C3                  <2>  ret
    15                              <2> %assign retOff %%_ret-$$
    88                              <1> 
    89                              <1> closeAllByMID:
    90                              <1> ;Close all files by MID
    91                              <1> ;Input: SDA dMID
    92 00000073 E88D030000          <1>     call critEnter
    93 00000078 31C9                <1>     xor ecx, ecx
    94 0000007A 48FFC9              <1>     dec rcx ;Get -1 into ecx to not check PIDs
    95                              <1> .go:
    96 0000007D E83C040000          <1>     call closeByID
    97 00000082 E888030000          <1>     call critExit
    98                              <1>     return
    13                              <2> %%_ret:
    14 00000087 C3                  <2>  ret
    15                              <2> %assign retOff %%_ret-$$
    99                              <1> 
   100                              <1> closeAllByPID:      
   101                              <1> ;Close all files for a single process by PID.
   102                              <1> ;A process is identified by its PID and MID since there 
   103                              <1> ; can be multiple process with the same PID across many machines.
   104                              <1> ;Input: SDA dMID
   105                              <1> ;       SDA qPID
   106 00000088 E878030000          <1>     call critEnter
   107 0000008D 31C9                <1>     xor ecx, ecx
   108 0000008F EBEC                <1>     jmp short closeAllByMID.go
   109                              <1> 
   110                              <1> closeAllByName:      
   111                              <1> ;Close all files by name.
   112                              <1> ;Input: rdx -> DPL (use rdx, dMID and qPID)
   113 00000091 E86F030000          <1>     call critEnter
   114 00000096 4150                <1>     push r8
   115 00000098 4C8B05(26000000)    <1>     mov r8, qword [pDosseg] ;Needed for the close handles call below
   116 0000009F 488B7218            <1>     mov rsi, qword [rdx + dpl.rdx]  ;Get the filename ptr in rsi
   117 000000A3 E834080000          <1>     call findMFT    ;Find the MFT for this file name
   118 000000A8 7225                <1>     jc .exitBad
   119 000000AA 488B7B0E            <1>     mov rdi, qword [rbx + mft.pSFT] ;Get the ptr to the first SFT
   120                              <1> .lp:
   121                              <1> ;Since we close by name, and each name has exactly one MFT, all we need
   122                              <1> ; to do is close all SFTs in the SFT chain of the MFT. We ensure we save
   123                              <1> ; the next SFT ptr before each close so that if the MFT gets reclaimed
   124                              <1> ; (which will happen during the close of the last SFT in the chain), 
   125                              <1> ; the MFT pointer becomes invalid. Thus, we save the next SFT ptr
   126                              <1> ; to detect when we closed all SFTs in the chain.
   127 000000AE 4885FF              <1>     test rdi, rdi   ;Is the SFT ptr null? Exit if so
   128 000000B1 7421                <1>     jz .exit
   129 000000B3 4989B863070000      <1>     mov qword [r8 + currentSFT], rdi    ;Else, set this SFT to be current
   130                              <1> ;Set this SFT count to 1, to make closeSFT clean up properly as we will
   131                              <1> ; close all jft entries across all processes
   132 000000BA 66C7070100          <1>     mov word [rdi + sft.wNumHandles], 1
   133 000000BF FF773B              <1>     push qword [rdi + sft.pNextSFT]     ;Save next SFT
   134                              <1> ;These two require currentSFT set.
   135 000000C2 E884040000          <1>     call closeHandlesForSFT ;Closes this SFT on all processes
   136 000000C7 E877040000          <1>     call closeSFT   ;Close this SFT
   137 000000CC 5F                  <1>     pop rdi         ;Get the ptr to the next SFT in rdi
   138 000000CD EBDF                <1>     jmp short .lp
   139                              <1> .exitBad:
   140 000000CF B803000000          <1>     mov eax, errPnf ;Set the error code
   141                              <1> .exit:
   142 000000D4 4158                <1>     pop r8
   143 000000D6 E834030000          <1>     call critExit
   144                              <1>     return
    13                              <2> %%_ret:
    14 000000DB C3                  <2>  ret
    15                              <2> %assign retOff %%_ret-$$
   145                              <1> 
   146                              <1> lockFile:       
   147                              <1> ;Lock a file region.
   148                              <1> ;Input: rdi -> SFT for file
   149                              <1> ;       ecx:edx = Start offset
   150                              <1> ;       esi:eax = Length of region
   151 000000DC E824030000          <1>     call critEnter
   152 000000E1 4150                <1>     push r8
   153 000000E3 4C8B05(26000000)    <1>     mov r8, qword [pDosseg]
   154 000000EA 48817F4F00000000    <1>     cmp qword [rdi + sft.pMFT], 0   ;If we don't have an MFT, fail
   155 000000F2 743A                <1>     je .exitBad
   156 000000F4 57                  <1>     push rdi    ;Save SFT ptr
   157 000000F5 E81F030000          <1>     call lockPreamble   ;Trashes rbx and rdi
   158 000000FA 5F                  <1>     pop rdi
   159 000000FB 7231                <1>     jc .exitBad         ;if lock overlap error, doesnt set lock violation.
   160 000000FD E89F030000          <1>     call getFreeLock    ;Get a free lock in rsi
   161 00000102 7222                <1>     jc .exit
   162                              <1> ;Here we have:
   163                              <1> ;   CF=NC
   164                              <1> ;   rbp -> MFT to add to
   165                              <1> ;   rax = Start of locked region
   166                              <1> ;   rdx = End of locked region
   167                              <1> ;   rdi -> SFT owning the lock
   168                              <1> ;   rsi -> Free lock we are creating
   169 00000104 48894608            <1>     mov qword [rsi + fileLock.qStart], rax
   170 00000108 48895610            <1>     mov qword [rsi + fileLock.qEnd], rdx
   171 0000010C 48897E18            <1>     mov qword [rsi + fileLock.pSFT], rdi
   172 00000110 498B804F040000      <1>     mov rax, qword [r8 + currentPSP]
   173 00000117 48894620            <1>     mov qword [rsi + fileLock.qPID], rax
   174 0000011B 488B4506            <1>     mov rax, qword [rbp + mft.pLock]    ;Get the head of the list
   175 0000011F 488906              <1>     mov qword [rsi + fileLock.pNext], rax   ;Link to the new file lock
   176 00000122 48897506            <1>     mov qword [rbp + mft.pLock], rsi    ;Add the lock to the head of the list
   177                              <1> .exit:    
   178 00000126 4158                <1>     pop r8
   179 00000128 E8E2020000          <1>     call critExit
   180                              <1>     return
    13                              <2> %%_ret:
    14 0000012D C3                  <2>  ret
    15                              <2> %assign retOff %%_ret-$$
   181                              <1> .exitBad:
   182 0000012E B821000000          <1>     mov eax, errLokVio
   183 00000133 F9                  <1>     stc
   184 00000134 EBF0                <1>     jmp short .exit
   185                              <1> 
   186                              <1> unlockFile:     
   187                              <1> ;Unlock file region. 
   188                              <1> ;Input: rdi -> SFT for file
   189                              <1> ;       ecx:edx = Start offset
   190                              <1> ;       esi:eax = Length of region
   191 00000136 E8CA020000          <1>     call critEnter
   192 0000013B 4150                <1>     push r8
   193 0000013D 4C8B05(26000000)    <1>     mov r8, qword [pDosseg]
   194 00000144 48817F4F00000000    <1>     cmp qword [rdi + sft.pMFT], 0   ;If we don't have an MFT, fail
   195 0000014C 74E0                <1>     je lockFile.exitBad
   196 0000014E 57                  <1>     push rdi    ;Save current SFT
   197 0000014F E8C5020000          <1>     call lockPreamble   ;Get rbx -> Matched lock, rdi -> Lock pointing to rbx
   198 00000154 5E                  <1>     pop rsi     ;Get back current SFT in rsi
   199 00000155 73D7                <1>     jnc lockFile.exitBad    ;If true, no match.
   200 00000157 75D5                <1>     jnz lockFile.exitBad    ;If true, not exact match.
   201                              <1> ;   rbp -> MFT to remove lock from
   202                              <1> ;   rsi -> SFT owning the lock
   203                              <1> ;   rbx -> Lock to free
   204                              <1> ;   rdi -> Lock pointing to rbx
   205 00000159 48397318            <1>     cmp qword [rbx + fileLock.pSFT], rsi    ;Check we own this lock
   206 0000015D 75CF                <1>     jne lockFile.exitBad
   207 0000015F 498B804F040000      <1>     mov rax, qword [r8 + currentPSP]
   208 00000166 48394320            <1>     cmp qword [rbx + fileLock.qPID], rax    ;Check this process can remove it
   209 0000016A 75C2                <1>     jne lockFile.exitBad
   210                              <1> ;Link over the lock we are freeing (pointed to by rbx), removing from mft list
   211 0000016C 488B03              <1>     mov rax, qword [rbx + fileLock.pNext]
   212 0000016F 488907              <1>     mov qword [rdi + fileLock.pNext], rax
   213                              <1> ;Add the lock (pointed to by rbx) to the head of the free list
   214 00000172 488B05(14000000)    <1>     mov rax, qword [pFreeLock]
