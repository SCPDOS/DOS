   293                              <1> ; ebx = dMID
   294                              <1> ; rsi -> our SFT
   295                              <1> ; rdi -> Filename to return
   296                              <1> ;Now count the number of locks this file has. 
   297 00000225 488B764F            <1>     mov rsi, qword [rsi + sft.pMFT] ;Point back to the MFT
   298 00000229 488B7606            <1>     mov rsi, qword [rsi + mft.pLock] ;Point to the lock list
   299                              <1> .lockLp:
