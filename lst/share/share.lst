   525                              <1> .gsLp:
   526                              <1> ;Always update filesize and start cluster info in rsi for growth/shrink
   527                              <1> ; to the filesize and start cluster of rdi
   528 0000039E 8B4717              <1>     mov eax, dword [rdi + sft.dFileSize]
   529 000003A1 894617              <1>     mov dword [rsi + sft.dFileSize], eax
   530 000003A4 8B470F              <1>     mov eax, dword [rdi + sft.dStartClust]
   531 000003A7 89460F              <1>     mov dword [rsi + sft.dStartClust], eax
   532 000003AA 81F902000000        <1>     cmp ecx, 2      ;Was this a shrink call?
   533 000003B0 7409                <1>     je .gsDoShrink  ;Reset the cluster info if so
   534                              <1> ;Here if we are a grow call. Check if the SFT in rsi was newly created.
   535                              <1> ;If not, skip the reset below. Else, we set the absolute cluster now to
   536                              <1> ; the start cluster to ensure that the SFTs all correctly have the same
   537                              <1> ; cluster info.  
