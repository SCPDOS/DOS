   801                              <1> ;Critical error handling
   802                              <1> errPrintAndHalt:
   803                              <1> ;This function is called such that the return address points to the 
   804                              <1> ; null terminated string to print. We never return from this.
   805                              <1> ;********************************************
   806                              <1> ;Consider requesting all disk buffers flush before entering infinite loop.
   807                              <1> ;********************************************
   808                              <1> ;Input: TOS -> Ptr to string to print after header.
   809                              <1> ;Output: Never return.
   810 00000949 488D3D56000000      <1>     lea rdi, .sHdr
   811 00000950 E80A000000          <1>     call .doWrite
   812 00000955 5F                  <1>     pop rdi         ;Get the passed in string
   813 00000956 E804000000          <1>     call .doWrite   ;Write the passed in ASCIIZ string.
   814                              <1> .halt:
   815 0000095B F390                <1>     pause           ;Hint the CPU to power down
   816 0000095D EBFC                <1>     jmp short .halt ;Infinite loop, await CTRL+ALT+DEL
   817                              <1> .doWrite:
   818                              <1> ;We write directly to the console driver completely bypassing any 
   819                              <1> ;redirection, without resorting to using BIOS functions.
   820                              <1> ;We use the PSP as the buffer for the ioReqPkt.
   821                              <1> ;We obviously do no error checking or Int 24 invokation if things
   822                              <1> ; go wrong with this. 
   823                              <1> ;Input: rdi -> String to print
   824                              <1> ;Output: Hopefully, string printed.
