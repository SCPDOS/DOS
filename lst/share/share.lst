   242                              <1> getSFTShareInfo:
   243                              <1> ;Get SFT sharing information about file.
   244                              <1> ;Input: rdx -> DPL (use ebx and ecx)
   245                              <1> ;       DPL.ebx = MFT Index (1 based)
   246                              <1> ;       DPL.ecx = SFT Index (1 based)
   247                              <1> ;Output:
   248                              <1> ;   CF=NC: File found 
   249                              <1> ;       rdi -> ASCIIZ filename
   250                              <1> ;       ebx = dMID for the SFT
   251                              <1> ;       ecx = Number of locks held by SFT
   252                              <1> ;   CF=CY: Either index is out of range.
   253                              <1> ;       eax = No more files
   254 000001DD E813020000          <1>     call critEnter
   255 000001E2 4150                <1>     push r8
   256 000001E4 8B5A08              <1>     mov ebx, dword [rdx + dpl.rbx]  ;Get the MFT index
   257 000001E7 8B4A10              <1>     mov ecx, dword [rdx + dpl.rcx]  ;Get the SFT index
   258 000001EA 488B35(00000000)    <1>     mov rsi, qword [pMftArena]
   259                              <1> .mftLp:
   260 000001F1 803E00              <1>     cmp byte [rsi + mft.bSig], mftFree
   261 000001F4 7406                <1>     jz .mftNext ;If its free, just goto next MFT
   262 000001F6 7242                <1>     jb .exitBad ;If we are at the end, exit error!
   263 000001F8 FFCB                <1>     dec ebx     ;Drop one from the count, if zero, we have arrived
   264 000001FA 7408                <1>     jz .goSft
   265                              <1> .mftNext:
   266 000001FC 8B4601              <1>     mov eax, dword [rsi + mft.dLen]
   267 000001FF 4801C6              <1>     add rsi, rax    ;Goto the next MFT
   268 00000202 EBED                <1>     jmp short .mftLp
   269                              <1> .goSft:
   270 00000204 488D7E16            <1>     lea rdi, qword [rsi + mft.sName]    ;Point to the name now
   271 00000208 488B760E            <1>     mov rsi, qword [rsi + mft.pSFT]     ;Point rsi to the first SFT
   272                              <1> .sftLp:
   273 0000020C 4885F6              <1>     test rsi, rsi   ;If no more SFTs, fail!
   274 0000020F 7429                <1>     jz .exitBad
   275 00000211 FFC9                <1>     dec ecx
   276 00000213 7406                <1>     jz .goEnd
   277 00000215 488B763B            <1>     mov rsi, qword [rsi + sft.pNextSFT]
   278 00000219 EBF1                <1>     jmp short .sftLp
   279                              <1> .goEnd:
   280 0000021B 8B5E43              <1>     mov ebx, dword [rsi + sft.dMID] ;Get the dMID
   281                              <1> ;Here we have: 
   282                              <1> ; ebx = dMID
   283                              <1> ; rsi -> our SFT
   284                              <1> ; rdi -> Filename to return
   285                              <1> ;Now count the number of locks this file has. 
   286 0000021E 488B764F            <1>     mov rsi, qword [rsi + sft.pMFT] ;Point back to the MFT
   287 00000222 488B7606            <1>     mov rsi, qword [rsi + mft.pLock] ;Point to the lock list
   288                              <1> .lockLp:
   289 00000226 4885F6              <1>     test rsi, rsi   ;Once rsi is zero, we are done
   290 00000229 7407                <1>     jz .exit
   291 0000022B FFC1                <1>     inc ecx         ;Else, increment the lock count
   292 0000022D 488B36              <1>     mov rsi, qword [rsi + fileLock.pNext]
   293 00000230 EBF4                <1>     jmp short .lockLp
   294                              <1> .exit:
   295 00000232 4158                <1>     pop r8
   296 00000234 E8C6010000          <1>     call critExit
