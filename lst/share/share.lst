   562                              <1> getMFT:
   563                              <1> ;Search for an MFT for a file. If one is not found, it creates it.
   564                              <1> ;Input: rsi -> Filename to search for
   565                              <1> ;Output: CF=NC: rbx -> MFT for this file.
   566                              <1> ;        CF=CY: eax = Error code.
   567                              <1> ;Start by working out the string length and checksum values
   568 000007BE E8E5000000          <1>     call findMFT        ;Sets dl for checksum and ecx for string length
   569                              <1>     retnc
    61                              <2> cret nc
    19                              <3> %%_base:
    20                              <3> %assign baseVar %%_base-$$
    21                              <3> 
    22                              <3> 
