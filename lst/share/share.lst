   311                              <1> closeNetworkFiles:   
   312                              <1> ;Close a newly created SFT-FCB handle for a procedure.
   313                              <1> ;Network SFT-FCBs handles are all collapsed into one SFT.
   314                              <1> ;----------------------------------------------------------------------------
   315                              <1> ;Input: rsi -> Newly created SFT
   316                              <1> ;       ax = SFTNdx for this newly created file
   317                              <1> ;Output: CF=NC: ax = SFTNdx for the SFT (Same as on input if not a SFT-FCB)
   318                              <1> ;        CF=CY: No SFT found
   319                              <1> ;----------------------------------------------------------------------------
   320                              <1> ;If
   321                              <1> ;   rsi -> SFT that is a network SFT-FCB (i.e. bit openNetFCBShr set 
   322                              <1> ;   in openmode), then we close any duplicate handles using a single
   323                              <1> ;   SFT to maintain the state (if there are none then we use this SFT
   324                              <1> ;   as the SFT-FCB). We increment the new main SFT refcount instead of 
   325                              <1> ;   having multiple SFTs.
   326                              <1> ;----------------------------------------------------------------------------
   327 00000245 4150                <1>     push r8
   328 00000247 4C8B05(26000000)    <1>     mov r8, qword [pDosseg]
   329 0000024E 0FB74602            <1>     movzx eax, word [rsi + sft.wOpenMode]
   330 00000252 25F0000000          <1>     and eax, 0F0h    ;Save the share bits
   331 00000257 3D70000000          <1>     cmp eax, openNetFCBShr
   332 0000025C 7573                <1>     jne .exitNormal
   333 0000025E 31DB                <1>     xor ebx, ebx
   334                              <1> .ptrLp:
   335 00000260 53                  <1>     push rbx
   336 00000261 B816120000          <1>     mov eax, 1216h  ;getSFTPtrfromSFTNdx -> Get in rdi the SFT for index bx
   337 00000266 CD2F                <1>     int 2Fh
   338 00000268 5B                  <1>     pop rbx
   339 00000269 726E                <1>     jc .exit
   340 0000026B 4839F7              <1>     cmp rdi, rsi    ;Skip ourselves
   341 0000026E 742D                <1>     je .ptrNext
   342 00000270 66813F0000          <1>     cmp word [rdi + sft.wNumHandles], 0 ;Handle must have empty count
   343 00000275 7426                <1>     je .ptrNext
   344 00000277 0FB74602            <1>     movzx eax, word [rsi + sft.wOpenMode]
   345 0000027B 663B4702            <1>     cmp ax, word [rdi + sft.wOpenMode]
   346 0000027F 751C                <1>     jne .ptrNext
   347 00000281 8B4643              <1>     mov eax, dword [rsi + sft.dMID]
   348 00000284 394743              <1>     cmp dword [rdi + sft.dMID], eax
   349 00000287 7514                <1>     jne .ptrNext
   350 00000289 488B4647            <1>     mov rax, qword [rsi + sft.qPID]
   351 0000028D 48394747            <1>     cmp qword [rdi + sft.qPID], rax
   352 00000291 750A                <1>     jne .ptrNext
   353 00000293 488B464F            <1>     mov rax, qword [rsi + sft.pMFT]
   354 00000297 4839474F            <1>     cmp qword [rdi + sft.pMFT], rax
   355 0000029B 7404                <1>     je .ptrFnd  ;If all this, then we have a duplicate net handle
   356                              <1> .ptrNext:
   357 0000029D FFC3                <1>     inc ebx
   358 0000029F EBBF                <1>     jmp short .ptrLp
   359                              <1> .ptrFnd:
   360                              <1> ;rsi is a duplicate of rdi for this process
   361 000002A1 66C7060000          <1>     mov word [rsi + sft.wNumHandles], 0 ;Free the handle we just allocated
   362 000002A6 57                  <1>     push rdi    ;rdi is the master FCB SFT 
   363 000002A7 53                  <1>     push rbx    ;Save the sftindex
   364 000002A8 4889F7              <1>     mov rdi, rsi
   365 000002AB E893FDFFFF          <1>     call close  ;Close the current SFT now
   366 000002B0 58                  <1>     pop rax     ;Get the sftindex into eax
   367 000002B1 5F                  <1>     pop rdi
   368 000002B2 66FF07              <1>     inc word [rdi + sft.wNumHandles]    ;Add one now
   369 000002B5 31DB                <1>     xor ebx, ebx
   370                              <1> .jftlp:
   371 000002B7 50                  <1>     push rax
   372 000002B8 B820120000          <1>     mov eax, 1220h  ;getJFTPtr -> Get ptr to this jft entry in psp in rdi
   373 000002BD CD2F                <1>     int 2Fh
   374 000002BF 58                  <1>     pop rax
   375 000002C0 7217                <1>     jc .exit
   376 000002C2 3807                <1>     cmp byte [rdi], al
   377 000002C4 7404                <1>     je .jftFnd
   378 000002C6 FFC3                <1>     inc ebx
   379 000002C8 EBED                <1>     jmp short .jftlp
   380                              <1> .jftFnd:
   381 000002CA C607FF              <1>     mov byte [rdi], -1
   382 000002CD 89D8                <1>     mov eax, ebx
   383 000002CF EB08                <1>     jmp short .exit
   384                              <1> .exitNormal:
   385 000002D1 410FB7806D070000    <1>     movzx eax, word [r8 + currentHdl]   ;Get the handle value to return
   386                              <1> .exit:
   387 000002D9 4158                <1>     pop r8
   388                              <1>     return
    13                              <2> %%_ret:
    14 000002DB C3                  <2>  ret
    15                              <2> %assign retOff %%_ret-$$
