   325                              <1> freeLocks:
   326                              <1> ;Frees all file locks associated to this rdi. 
   327                              <1> ;Input: rdi -> SFT for this file
   328                              <1> ;       edx = Flag for if we should free locks for process
   329                              <1> ;             -1 -> Free for process (on 5D04h calls)
   330                              <1> ;              0 -> Dont bother (otherwise)
   331                              <1> ;Output: All file locks owned by this process are delinked from the 
   332                              <1> ;        file chain and added to the free lock chain.
   333                              <1> ;Trashes rax, rbx, rsi.
   334 0000062A 488B5F4F            <1>     mov rbx, qword [rdi + sft.pMFT]     ;Get MFT ptr in rbx
   335 0000062E 488B7306            <1>     mov rsi, qword [rbx + mft.pLock]    ;Get the first lock of MFT in rsi 
   336 00000632 4881C306000000      <1>     add rbx, mft.pLock  ;Point rbx to the link field of the previous lock
   337                              <1> .lp:
   338 00000639 4885F6              <1>     test rsi, rsi   ;End of list? 
   339                              <1>     retz            ;Exit if so
