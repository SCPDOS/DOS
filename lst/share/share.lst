   254                              <1> freeMFT:
   255                              <1> ;Frees the MFT if it is safe to do so. Crashes otherwise. Combines 
   256                              <1> ; any adjacent free space too.
   257                              <1> ;Input: rbx -> MFT to free
   258                              <1> ;Output: MFT freed. Any adjacent free space is absorbed by this MFT too.
   259                              <1> ;Trashes rax, rbx and rsi
   260 0000059F 488B430E            <1>     mov rax, qword [rbx + mft.pSFT]
   261 000005A3 48094306            <1>     or qword [rbx + mft.pLock], rax ;If pLock or pSFT is non-zero, hard error
   262 000005A7 751A                <1>     jnz .crash
   263 000005A9 C60300              <1>     mov byte [rbx + mft.bSig], mftFree
   264                              <1> .lp:
   265                              <1> ;Checks the adjacent MFT. If it is free, we combine it to this free MFT.
   266 000005AC 4889DE              <1>     mov rsi, rbx
   267 000005AF 8B4301              <1>     mov eax, dword [rbx + mft.dLen]
   268 000005B2 4801C6              <1>     add rsi, rax    ;Point to next MFT
   269 000005B5 803E00              <1>     cmp byte [rsi + mft.bSig], mftFree
   270                              <1>     retne   ;If not free, we exit
    53                              <2> cret ne
