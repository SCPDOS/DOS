    52                                  %include "./src/share/text/shutils.asm"
     1                              <1> ;-----------------------------------------------------------------------------
     2                              <1> ;All utility functions go here, in order.
     3                              <1> ;-----------------------------------------------------------------------------
     4                              <1> ; critEnter -> Enters a DOS 1 critical section
     5                              <1> ; critExit -> Exits a DOS 1 critical section
     6                              <1> ; lockPreamble -> Sets up the registers for set/clear flock
     7                              <1> ; checkLockOverlap -> Checks if a lock with the given bounds exists
     8                              <1> ; getFreeLock -> Removes a free lock from the free lock list
     9                              <1> ; closeByID -> Closses all files according to IDs
    10                              <1> ; closeSFT -> Wrapper for Close SFT
    11                              <1> ; closeHandlesForSFT -> Closes handles referencing an SFT
    12                              <1> ; freeMFT -> Frees an MFT from the MFT arena
    13                              <1> ; removeSFTfromMFT -> Removes an SFT from an MFT's SFT chain
    14                              <1> ; freeLocks -> Frees all file locks associated to a SFT
    15                              <1> ; addSFTtoMFT -> Adds an SFT to its MFT chain.
    16                              <1> ; getMFT -> Gets an MFT for a given filename. Creates if it has to.
    17                              <1> ; defragMFTArena -> Defragments the MFT arena
    18                              <1> ; findFreeMFT -> Finds a free MFT for a given size
    19                              <1> ; findMFT -> Find an MFT for a given filename
    20                              <1> ; getNameMeta -> Computes the length and checksum of a filename
    21                              <1> ; closeJFTentries -> Closes all JFT entries pointing to a 
    22                              <1> ;                       particular SFT for a process.
    23                              <1> ; errPrintAndHalt -> Prints a formatted error message and halts the machine
    24                              <1> ;-----------------------------------------------------------------------------
    25                              <1> 
    26                              <1> 
    27                              <1> critEnter:
    28 000003F8 50                  <1>     push rax
    29 000003F9 B801800000          <1>     mov eax, 8001h  ;Enter DOS Level 1 critical section
    30 000003FE CD2A                <1>     int 2ah
    31 00000400 58                  <1>     pop rax
    32                              <1>     return
    13                              <2> %%_ret:
    14 00000401 C3                  <2>  ret
    15                              <2> %assign retOff %%_ret-$$
    33                              <1> critExit:
    34 00000402 50                  <1>     push rax
    35 00000403 B801810000          <1>     mov eax, 8101h  ;Exit DOS Level 1 critical section
    36 00000408 CD2A                <1>     int 2ah
    37 0000040A 58                  <1>     pop rax
    38                              <1>     return
    13                              <2> %%_ret:
    14 0000040B C3                  <2>  ret
    15                              <2> %assign retOff %%_ret-$$
    39                              <1> 
    40                              <1> lockPreamble:
    41                              <1> ;Sets up the regs for the lock/unlock operation
    42                              <1> ;Input: rdi -> SFT for file
    43                              <1> ;       ecx:edx = Start offset
    44                              <1> ;       esi:eax = Length of region
    45                              <1> ;Output:    CF=NC: Ok to proceed with locking
    46                              <1> ;               rax = Start byte of lock
    47                              <1> ;               rdx = End byte of lock
    48                              <1> ;               rbp -> MFT we are adding the lock to
    49                              <1> ;               rbx = rdi = Trashed
    50                              <1> ;           CF=CY: Error!
    51                              <1> ;               ZF=ZE: Lock equals a previous lock
    52                              <1> ;               ZF=NZ: Lock partially overlaps or of 0 length
    53                              <1> ;               rbx -> Lock that we overlap (if not length 0)
    54                              <1> ;               rdi -> Lock pointing to rbx (if not length 0)
    55                              <1> ;ecx and esi trashed. All other registers ok.
    56 0000040C 85D2                <1>     test edx, edx   ;Ensure the upper 32 bits of edx are zero
    57 0000040E 09C6                <1>     or esi, eax     ;Ditto rax but also check the length is not zero
    58 00000410 7424                <1>     jz .badExit
    59 00000412 48C1E120            <1>     shl rcx, 32     ;Move the argument high
    60 00000416 48C1E620            <1>     shl rsi, 32     ;Move the argument high
    61 0000041A 4809CA              <1>     or rdx, rcx     ;Stick the bits together (no overlap)
    62 0000041D 4809F0              <1>     or rax, rsi     ;Stick the bits together (no overlap)
    63 00000420 4801D0              <1>     add rax, rdx    ;Add the start byte to the length to get first byte free
    64 00000423 48FFC8              <1>     dec rax         ;And now point rax to the last byte in the lock
    65 00000426 4892                <1>     xchg rdx, rax   ;And swap em
    66                              <1> ;rax -> Start byte of lock
    67                              <1> ;rdx -> End byte of lock
    68 00000428 488B6F4F            <1>     mov rbp, qword [rdi + sft.pMFT] ;Set rbp to the mft to inspect
    69 0000042C 31C9                <1>     xor ecx, ecx
    70 0000042E FFC1                <1>     inc ecx     ;Check all locks for overlap
    71 00000430 E80A000000          <1>     call checkLockOverlap   ;Preserves everything, except rbx and rdi
    72                              <1>     return
    13                              <2> %%_ret:
    14 00000435 C3                  <2>  ret
    15                              <2> %assign retOff %%_ret-$$
    73                              <1> .badExit:
    74 00000436 B821000000          <1>     mov eax, errLokVio
    75 0000043B 85C0                <1>     test eax, eax   ;Clear the ZF flag
    76 0000043D F9                  <1>     stc             ;And set CF
    77                              <1>     return
    13                              <2> %%_ret:
    14 0000043E C3                  <2>  ret
    15                              <2> %assign retOff %%_ret-$$
    78                              <1> 
    79                              <1> checkLockOverlap:
    80                              <1> ;Input: rax = Start byte to check
    81                              <1> ;       rdx = End byte to check
    82                              <1> ;       rbp -> MFT to search on
    83                              <1> ;       ecx = 0: Do not check locks belonging to currentSFT, dMID, qPID
    84                              <1> ;           = 1: Check all locks
    85                              <1> ;Output: CF=NC: No overlap!
    86                              <1> ;           rbx = Trashed (Null)
    87                              <1> ;           rdi = Trashed 
    88                              <1> ;        CF=CY: Overlap!
    89                              <1> ;           ZF=ZE: Lock region matched exactly
    90                              <1> ;           ZF=NZ: Lock region not matched exactly
    91                              <1> ;           rbx -> Lock we matched to
    92                              <1> ;           rdi -> Lock pointing to rbx
    93                              <1> ;All other regs preserved
    94 0000043F 56                  <1>     push rsi
    95 00000440 488B5D06            <1>     mov rbx, qword [rbp + mft.pLock]
    96 00000444 488D7D06            <1>     lea rdi, qword [rbp + mft.pLock - fileLock.pNext]
    97                              <1> .lockLp:
    98 00000448 4885DB              <1>     test rbx, rbx
    99 0000044B 744D                <1>     jz .exit
   100 0000044D 85C9                <1>     test ecx, ecx   ;Check if we must do this lock?
   101 0000044F 7532                <1>     jnz .doLock
   102                              <1> ;Now we check that this lock isnt the same as the current SFT, qPID and dMID.
   103                              <1> ;If any are not equal, we do the lock. If they are all the same, skip.
   104                              <1> ;Check currentSFT
   105 00000451 498BB063070000      <1>     mov rsi, qword [r8 + currentSFT]
   106 00000458 483B7318            <1>     cmp rsi, qword [rbx + fileLock.pSFT]
   107 0000045C 7525                <1>     jne .doLock
   108                              <1> ;Check qPID
   109 0000045E 488B7320            <1>     mov rsi, qword [rbx + fileLock.qPID]    
   110 00000462 493BB06B040000      <1>     cmp rsi, qword [r8 + qPID]
   111 00000469 7518                <1>     jne .doLock
   112                              <1> ;Check dMID
   113 0000046B 488B7318            <1>     mov rsi, qword [rbx + fileLock.pSFT]
   114 0000046F 8B7643              <1>     mov esi, dword [rsi + sft.dMID]
   115 00000472 413BB073040000      <1>     cmp esi, dword [r8 + dMID]
   116 00000479 7508                <1>     jne .doLock
   117                              <1> ;If all three were equal, skip this lock!
   118                              <1> .nextLock:
   119 0000047B 4889DF              <1>     mov rdi, rbx    ;Save ptr to the trailing lock in rdi
   120 0000047E 488B1F              <1>     mov rbx, qword [rdi + fileLock.pNext]  ;Go to next lock in chain
   121 00000481 EBC5                <1>     jmp short .lockLp
   122                              <1> .doLock:
   123                              <1> ;Input: rbx -> filelock to check on
   124                              <1> ;       rax -> Start byte to check
   125                              <1> ;       rdx -> End byte to check
   126 00000483 483B4310            <1>     cmp rax, qword [rbx + fileLock.qEnd]
   127 00000487 77F2                <1>     ja .nextLock    ;If start is past the end, immediately check next!
   128 00000489 483B5308            <1>     cmp rdx, qword [rbx + fileLock.qStart]
   129 0000048D 72EC                <1>     jb .nextLock    ;If end is below the start, immediately check next!
   130                              <1> ;Thus there must be some overlap! Check if exact
   131 0000048F 483B4308            <1>     cmp rax, qword [rbx + fileLock.qStart]
   132 00000493 7504                <1>     jne .ovlpExit
   133 00000495 483B5310            <1>     cmp rdx, qword [rbx + fileLock.qEnd]    ;Keeps ZF set if equal  
   134                              <1> .ovlpExit:
   135 00000499 F9                  <1>     stc
   136                              <1> .exit:
   137 0000049A 5E                  <1>     pop rsi
   138                              <1>     return
    13                              <2> %%_ret:
    14 0000049B C3                  <2>  ret
    15                              <2> %assign retOff %%_ret-$$
   139                              <1> 
   140                              <1> getFreeLock:
   141                              <1> ;Gets a free lock.
   142                              <1> ;Output: CF=NC: rsi -> Lock
   143                              <1> ;        CF=CY: No more locks
   144 0000049C 488B35(14000000)    <1>     mov rsi, qword [pFreeLock]
   145 000004A3 4885F6              <1>     test rsi, rsi
   146 000004A6 740A                <1>     jz .noMoreLocks
   147 000004A8 FF36                <1>     push qword [rsi + fileLock.pNext]   ;Move next entry to the head
   148 000004AA 8F05(14000000)      <1>     pop qword [pFreeLock]
   149 000004B0 F8                  <1>     clc
   150                              <1>     return
    13                              <2> %%_ret:
    14 000004B1 C3                  <2>  ret
    15                              <2> %assign retOff %%_ret-$$
   151                              <1> .noMoreLocks:
   152 000004B2 B824000000          <1>     mov eax, errShrFul
   153 000004B7 F9                  <1>     stc
   154                              <1>     return
    13                              <2> %%_ret:
    14 000004B8 C3                  <2>  ret
    15                              <2> %assign retOff %%_ret-$$
