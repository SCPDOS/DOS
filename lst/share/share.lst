   752                              <1> findMFT:
   753                              <1> ;Searches for an MFT for the filename in rsi 
   754                              <1> ;Input: rsi -> Filename to search for
   755                              <1> ;       
   756                              <1> ;Output: ecx = String length
   757                              <1> ;        dl = Filename checksum
   758                              <1> ;        CF=NC: rbx -> MFT for file
   759                              <1> ;        CF=CY: No MFT found for this file. rbx -> End MFT
   760                              <1> ;Trashes rax. All other regs preserved.
   761 000008DC E82D000000          <1>     call getNameMeta    ;Sets ecx and dl
   762 000008E1 488B1D(00000000)    <1>     mov rbx, qword [pMftArena]
   763                              <1> .lp:
   764 000008E8 803B00              <1>     cmp byte [rbx + mft.bSig], mftFree  
   765 000008EB 7C1F                <1>     jl .noMFT   ;If below, bSig must be -1. End of arena!
   766 000008ED 7415                <1>     je .next    ;If this MFT is free, goto next entry
   767 000008EF 385305              <1>     cmp byte [rbx + mft.bCheckSum], dl  ;Compare checksums
   768 000008F2 7510                <1>     jne .next   ;If not equal, skip entry
   769 000008F4 57                  <1>     push rdi
   770 000008F5 488D7B16            <1>     lea rdi, qword [rbx + mft.sName] ;Point to mft filename
   771 000008F9 B81E120000          <1>     mov eax, 121Eh  ;Compare strings in rsi and rdi
   772 000008FE CD2F                <1>     int 2Fh         ;Doesnt modify string pointers
   773 00000900 5F                  <1>     pop rdi
   774                              <1>     retz    ;If ZF=ZE (also CF=NC), we have found the MFT! Return to caller.
    41                              <2> cret z
