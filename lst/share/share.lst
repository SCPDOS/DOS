   363                              <1> addSFTtoMFT:
   364                              <1> ;Adds an SFT to the MFT chain and finishes filling in it's share fields. 
   365                              <1> ;Checks for sharing conflicts before adding.
   366                              <1> ;Input: rsi -> SFT to add
   367                              <1> ;       rbx -> MFT to add SFT to
   368                              <1> ;       r8 -> DOSSEG
   369                              <1> ;Output: CF=NC: SFT Added to list
   370                              <1> ;        CF=CY: Sharing violation. eax has error code
   371 00000688 48817E4F00000000    <1>     cmp qword [rsi + sft.pMFT], 0   ;This SFT better not already be on a chain
   372 00000690 752E                <1>     jne .crash
   373                              <1> ;Add the networking ids now as we need them for permissions checking
   374 00000692 498B806B040000      <1>     mov rax, qword [r8 + qPID]
   375 00000699 48894647            <1>     mov qword [rsi + sft.qPID], rax
   376 0000069D 418B8073040000      <1>     mov eax, dword [r8 + dMID]
   377 000006A4 894643              <1>     mov dword [rsi + sft.dMID], eax
   378                              <1> ;Now we check if there are any sharing conflicts
   379 000006A7 E82E000000          <1>     call checkPermissions
   380                              <1>     retc
