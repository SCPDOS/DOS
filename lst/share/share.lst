   565                              <1> .gotoNextSFT:
   566                              <1> ;Returns in rsi the next SFT entry.
   567                              <1> ;Input: rdi -> SFT we are updating from.
   568                              <1> ;       rsi -> SFT we just updated.
   569                              <1> ;Output: ZF=NZ: rsi -> Next SFT in the chain.
   570                              <1> ;        ZF=ZE: End of SFT chain.
   571 000003E8 488B763B            <1>     mov rsi, qword [rsi + sft.pNextSFT]
   572 000003EC 4885F6              <1>     test rsi, rsi
   573                              <1>     retz
