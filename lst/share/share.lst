    15                              <2> %assign retOff %%_ret-$$
   795                              <1> .isPIDSpecial:
   796                              <1> ;Certain PIDs have special meaning and must be ignored.
   797                              <1> ;If free or a hole, ignore.
   798                              <1> ;If DOS or New DOS (should NEVER exist outside of a drivers init)
   799                              <1> ; we get return the DOS PSP address in rax and pretend it is not 
   800                              <1> ; special.
   801                              <1> ;Input: rax = PID to check
   802                              <1> ;Output: ZF=ZE: Special PID, don't operate on it
   803                              <1> ;        ZF=NZ: Normal PID, proceed.
   804 00000922 483D00000000        <1>     cmp rax, mcbOwnerFree   ;Bona-fide must be ignored
   805                              <1>     rete
