   527                              <1> .gsLp:
   528                              <1> ;Always update filesize and start cluster info in rsi for growth/shrink
   529                              <1> ; to the filesize and start cluster of rdi
   530 0000039A 8B4717              <1>     mov eax, dword [rdi + sft.dFileSize]
   531 0000039D 894617              <1>     mov dword [rsi + sft.dFileSize], eax
   532 000003A0 8B470F              <1>     mov eax, dword [rdi + sft.dStartClust]
   533 000003A3 89460F              <1>     mov dword [rsi + sft.dStartClust], eax
   534 000003A6 81F902000000        <1>     cmp ecx, 2      ;Was this a shrink call?
   535 000003AC 7409                <1>     je .gsDoShrink  ;Reset the cluster info if so
   536                              <1> ;Here if we are a grow call. Check if the SFT in rsi was newly created.
   537                              <1> ;If not, skip the reset below. Else, we set the absolute cluster now to
   538                              <1> ; the start cluster to ensure that the SFTs all correctly have the same
   539                              <1> ; cluster info.  
   540 000003AE 817E2300000000      <1>     cmp dword [rsi + sft.dAbsClust], 0 ;Is this sft just created?
   541 000003B5 750A                <1>     jne .gsNextFile   ;If not, and a grow call, skip the below
   542                              <1> .gsDoShrink:
   543                              <1> ;Set the cluster information back to the start of the file.
   544 000003B7 894623              <1>     mov dword [rsi + sft.dAbsClust], eax
   545 000003BA C7461F00000000      <1>     mov dword [rsi + sft.dRelClust], 0  ;Reset the file rel cluster ptr
   546                              <1> .gsNextFile:
   547 000003C1 E822000000          <1>     call .gotoNextSFT
   548 000003C6 75D2                <1>     jnz .gsLp
   549 000003C8 EBC0                <1>     jmp short .exit 
