   323                              <1> ;A lock is ours if the SFT pointer of the lock matches our SFT pointer in rdi
   324 0000063C 48397E18            <1>     cmp qword [rsi + fileLock.pSFT], rdi    ;Is the SFT ours?
   325 00000640 7536                <1>     jne .nextLock   ;If not, skip
   326 00000642 85D2                <1>     test edx, edx   ;If it is but we dont care for process ID, skip this
   327 00000644 7418                <1>     jz .skipProcess
   328                              <1> ;Now check this lock belongs to this process too
   329 00000646 4150                <1>     push r8
   330 00000648 4C8B05(26000000)    <1>     mov r8, qword [pDosseg]
   331 0000064F 498B806B040000      <1>     mov rax, qword [r8 + qPID]  ;Get the process id
   332 00000656 48394620            <1>     cmp qword [rsi + fileLock.qPID], rax    ;And compare them
   333 0000065A 4158                <1>     pop r8
   334 0000065C 751A                <1>     jne .nextLock
   335                              <1> .skipProcess:
   336                              <1> ;Here we delink the flock. We move it from the MFT list to the Free list
   337                              <1> ; and cross link.
   338                              <1> ;Registers on entry
   339                              <1> ;rdi -> Our SFT
   340                              <1> ;rsi -> Lock
   341                              <1> ;rbx -> The previous lock in the file chain (only first qword valid)
   342                              <1> ;edx = Flag, do not use.
   343 0000065E 488B06              <1>     mov rax, qword [rsi + fileLock.pNext]   ;Unlink rsi by linking the prev...
   344 00000661 488903              <1>     mov qword [rbx + fileLock.pNext], rax   ;... flock to the flock after rsi
   345 00000664 488B05(14000000)    <1>     mov rax, qword [pFreeLock]              ;Get head of the free lock list
   346 0000066B 488906              <1>     mov qword [rsi + fileLock.pNext], rax   ;Link rsi to the head of free list
   347 0000066E 488935(14000000)    <1>     mov qword [pFreeLock], rsi              ;Make rsi the head of the free list
   348 00000675 4889DE              <1>     mov rsi, rbx    ;Start from previous lock in the list again.
   349                              <1> .nextLock:
   350 00000678 4889F3              <1>     mov rbx, rsi    ;Point rsi to this filelock
   351 0000067B 488B36              <1>     mov rsi, qword [rsi + fileLock.pNext]   ;Get next file lock
   352 0000067E EBB6                <1>     jmp short .lp
   353                              <1> 
   354                              <1> addSFTtoMFT:
   355                              <1> ;Adds an SFT to the MFT chain and finishes filling in it's share fields. 
   356                              <1> ;Checks for sharing conflicts before adding.
   357                              <1> ;Input: rsi -> SFT to add
   358                              <1> ;       rbx -> MFT to add SFT to
   359                              <1> ;       r8 -> DOSSEG
   360                              <1> ;Output: CF=NC: SFT Added to list
   361                              <1> ;        CF=CY: Sharing violation. eax has error code
   362 00000680 48817E4F00000000    <1>     cmp qword [rsi + sft.pMFT], 0   ;This SFT better not already be on a chain
   363 00000688 752E                <1>     jne .crash
   364                              <1> ;Add the networking ids now as we need them for permissions checking
   365 0000068A 498B806B040000      <1>     mov rax, qword [r8 + qPID]
   366 00000691 48894647            <1>     mov qword [rsi + sft.qPID], rax
   367 00000695 418B8073040000      <1>     mov eax, dword [r8 + dMID]
   368 0000069C 894643              <1>     mov dword [rsi + sft.dMID], eax
   369                              <1> ;Now we check if there are any sharing conflicts
   370 0000069F E82E000000          <1>     call checkPermissions
   371                              <1>     retc
