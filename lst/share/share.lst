   458                              <1> dirUpdate:      
   459                              <1> ;Update dir info across all SFTs for a file. 
   460                              <1> ;----------------------------------------------------------------------------
   461                              <1> ;Input: rdi -> SFT to update dir entry from
   462                              <1> ;       eax = 0: Update the date/time fields only
   463                              <1> ;           = 1: Update size fields for growth
   464                              <1> ;           = 2: Update size fields for shrink (i.e. truncate/open calls)
   465                              <1> ;           = 3: Update all fields
   466                              <1> ;Output: Nothing, all SFTs in MFT chain updated.
   467                              <1> ;        rax and rcx trashed.
   468                              <1> ;----------------------------------------------------------------------------
   469                              <1> ; If rdi is a chardev or a redir file, return
   470                              <1> ; Get MFT pointer. 
   471                              <1> ; If 
   472                              <1> ;   MFT pointer is null, return.
   473                              <1> ; Else
   474                              <1> ;   Get first SFT pointer from MFT into rsi   
   475                              <1> ; If eax = 0:
   476                              <1> ;   Walk the SFT chain along rsi updating date/time fields except for us.
   477                              <1> ; Else if eax = 1:
   478                              <1> ;   Walk the SFT chain along rsi updating dFileSize and dStartClust fields 
   479                              <1> ;   except for us.
   480                              <1> ; Else if eax = 2:
   481                              <1> ;   Walk the SFT chain along rsi updating dFileSize, dStartClust and 
   482                              <1> ;   setting dRelClust to 0 and dAbsClust to dStartClust except for us.
   483                              <1> ; Else if eax = 3:
   484                              <1> ;   Update date/time and dFileSize, dStartClust, dRelClust and dAbsClust 
   485                              <1> ;   fields for us from the oldest SFT in the SFT chain for this MFT. 
   486                              <1> ;   
   487                              <1> ; Return.
   488                              <1> ;**** Note ****
   489                              <1> ;In open and shrink we reset dRelClust to 0 and dAbsClust to dStartClust
   490                              <1> ;to signify that all file IO should start from the start of the file.
   491                              <1> ;This is a future optimisation as right now, the DOS kernel never depends 
   492                              <1> ;on these values. These values are however correctly synchronised on each
   493                              <1> ;read/write so in the future, we can relatively easily add a check to make
   494                              <1> ;use of these values, unless they are at the start of the file at which
   495                              <1> ;case we use the current algorithms.
   496                              <1> ;----------------------------------------------------------------------------
   497 0000035D 66F747058080        <1>     test word [rdi + sft.wDeviceInfo], devCharDev | devRedir
   498                              <1>     retnz
    45                              <2> cret nz
