    32                              <1> open:           
    33                              <1> ;Called on file create/open. Creates/Finds an MFT entry for the file
    34                              <1> ; being opened and adds the new SFT to the MFT chain.
    35                              <1> ;----------------------------------------------------------------------------
    36                              <1> ;Input: qword [fname1Ptr] -> Fully qualified pathname to open
    37                              <1> ;       qword [currentSFT] -> SFT that was just created/opened
    38                              <1> ;           This SFT needs the following fields filled in:
    39                              <1> ;               .wOpenMode
    40                              <1> ;               .bFileAttrib
    41                              <1> ;               .dMID
    42                              <1> ;               .qPID
    43                              <1> ;               .pMFT
    44                              <1> ;       qword [qPID] -> Process ID of the requesting task
    45                              <1> ;       dword [dMID] -> Machine ID of the requesting task
    46                              <1> ;Output: CF=NC: Proceed happily with SFT linked into the MFT for the file.
    47                              <1> ;        CF=CY: eax = Error code for request. Abort, free SFT.
    48                              <1> ;Use r8 as DOSSEG base
    49                              <1> ;----------------------------------------------------------------------------
    50 00000013 E8DD030000          <1>     call critEnter
    51 00000018 4150                <1>     push r8
    52 0000001A 4C8B05(26000000)    <1>     mov r8, qword [pDosseg]
    53 00000021 498BB050060000      <1>     mov rsi, qword [r8 + fname1Ptr] ;Get the filename pointer
    54 00000028 E891070000          <1>     call getMFT
    55 0000002D 720C                <1>     jc .exit
    56                              <1> ;rbx -> MFT for this file here.
    57 0000002F 498BB063070000      <1>     mov rsi, qword [r8 + currentSFT]    ;Get the current SFT now
    58 00000036 E845060000          <1>     call addSFTtoMFT    ;Bubble CF
    59                              <1> .exit:
    60 0000003B 4158                <1>     pop r8
    61 0000003D E8BD030000          <1>     call critExit
    62                              <1>     return
    13                              <2> %%_ret:
    14 00000042 C3                  <2>  ret
    15                              <2> %assign retOff %%_ret-$$
    63                              <1> 
    64                              <1> close:          
    65                              <1> ;Called on file close. Frees all sharing information associated with
    66                              <1> ; a file.
    67                              <1> ;Input: rdi -> SFT we are closing.
    68 00000043 E8AD030000          <1>     call critEnter
    69 00000048 488B5F4F            <1>     mov rbx, qword [rdi + sft.pMFT]
    70 0000004C 4885DB              <1>     test rbx, rbx   ;If this is an SFT from before Share loaded, do nothing!
    71 0000004F 741C                <1>     jz .exit
    72 00000051 0FBF07              <1>     movsx eax, word [rdi + sft.wNumHandles] ;Get the count
    73 00000054 85C0                <1>     test eax, eax   ;If count is zero, free all sharing data
    74 00000056 7404                <1>     jz .goClose
    75 00000058 FFC0                <1>     inc eax         ;If this handle is -1, also free any sharing data.
    76 0000005A 7511                <1>     jnz .exit       ;If not -1 or 0, then inc eax > 0 and so we just exit
    77                              <1> .goClose:
    78 0000005C E8C6050000          <1>     call freeLocks  ;Free all locks associated to this SFT
    79 00000061 E874050000          <1>     call removeSFTfromMFT ;Delink this SFT from the SFT link
    80 00000066 7505                <1>     jnz .exit       ;If not last SFT in MFT chain, dont free MFT
    81 00000068 E832050000          <1>     call freeMFT    ;If no more SFTs, free the MFT. Do small GC.
    82                              <1> .exit:
    83 0000006D E88D030000          <1>     call critExit
    84                              <1>     return
    13                              <2> %%_ret:
    14 00000072 C3                  <2>  ret
    15                              <2> %assign retOff %%_ret-$$
    85                              <1> 
    86                              <1> closeAllByMachine:      
    87                              <1> ;Close all files for a machine.
    88                              <1> ;Input: rdx -> DPL (use dMID only)
    89 00000073 E87D030000          <1>     call critEnter
    90 00000078 31C9                <1>     xor ecx, ecx
    91 0000007A 48FFC9              <1>     dec rcx ;Get -1 into ecx to indicate not to use this
    92 0000007D 488B5218            <1>     mov rdx, qword [rdx + dpl.rdx]  ;Get the MID
    93 00000081 E831040000          <1>     call closeByID
    94 00000086 E874030000          <1>     call critExit
    95                              <1>     return
    13                              <2> %%_ret:
    14 0000008B C3                  <2>  ret
    15                              <2> %assign retOff %%_ret-$$
    96                              <1> 
    97                              <1> closeAllByProcess:      
    98                              <1> ;Close all files for a task.
    99                              <1> ;Input: rdx -> DPL (use dMID and qPID)
   100 0000008C E864030000          <1>     call critEnter
   101 00000091 488B4A18            <1>     mov rcx, qword [rdx + dpl.rdx]  ;Get the PID
   102 00000095 488B5218            <1>     mov rdx, qword [rdx + dpl.rdx]  ;Get the MID
   103 00000099 E819040000          <1>     call closeByID
   104 0000009E E85C030000          <1>     call critExit
   105                              <1>     return
    13                              <2> %%_ret:
    14 000000A3 C3                  <2>  ret
    15                              <2> %assign retOff %%_ret-$$
   106                              <1> 
   107                              <1> closeAllByName:      
   108                              <1> ;Close all files by name.
   109                              <1> ;Input: rdx -> DPL (use rdx, dMID and qPID)
   110 000000A4 E84C030000          <1>     call critEnter
   111 000000A9 4150                <1>     push r8
   112 000000AB 4C8B05(26000000)    <1>     mov r8, qword [pDosseg] ;Needed for the close handles call below
   113 000000B2 488B7218            <1>     mov rsi, qword [rdx + dpl.rdx]  ;Get the filename ptr in rsi
   114 000000B6 E8ED070000          <1>     call findMFT    ;Find the MFT for this file name
   115 000000BB 7224                <1>     jc .exit
   116 000000BD 488B7B0E            <1>     mov rdi, qword [rbx + mft.pSFT] ;Get the ptr to the first SFT
   117                              <1> .lp:
   118                              <1> ;We work by looking ahead an SFT in the chain. This is because closeSFT
   119                              <1> ; might free the MFT so instead of having to search for it each time
   120                              <1> ; we look for the condition on which it will be freed, i.e. the sft we are at
   121                              <1> ; being the last SFT open on that MFT.
   122 000000C1 4885FF              <1>     test rdi, rdi   ;Is the SFT ptr null? Exit if so
   123 000000C4 741B                <1>     jz .exit
   124 000000C6 4989B863070000      <1>     mov qword [r8 + currentSFT], rdi    ;Else, set this SFT to be current
   125 000000CD 498B703B            <1>     mov rsi, qword [r8 + sft.pNextSFT]  ;Get the next SFT
   126 000000D1 56                  <1>     push rsi    ;Preserve next SFT across the next two calls
   127 000000D2 57                  <1>     push rdi    ;Preserve rdi across this call
   128 000000D3 E853040000          <1>     call closeHandlesForSFT ;Closes this SFT on all processes
   129 000000D8 5F                  <1>     pop rdi     ;Get back the ptr to current SFT
   130 000000D9 E845040000          <1>     call closeSFT   ;Close this SFT
   131 000000DE 5F                  <1>     pop rdi     ;Get the ptr to the next SFT in rdi
   132 000000DF EBE0                <1>     jmp short .lp
   133                              <1> .exit:
   134 000000E1 4158                <1>     pop r8
   135 000000E3 E817030000          <1>     call critExit
   136                              <1>     return
    13                              <2> %%_ret:
    14 000000E8 C3                  <2>  ret
    15                              <2> %assign retOff %%_ret-$$
   137                              <1> 
   138                              <1> lockFile:       
   139                              <1> ;Lock a file region.
   140                              <1> ;Input: rdi -> SFT for file
   141                              <1> ;       ecx:edx = Start offset
   142                              <1> ;       esi:eax = Length of region
   143 000000E9 E807030000          <1>     call critEnter
   144 000000EE 4150                <1>     push r8
   145 000000F0 4C8B05(26000000)    <1>     mov r8, qword [pDosseg]
   146 000000F7 48817F4F00000000    <1>     cmp qword [rdi + sft.pMFT], 0   ;If we don't have an MFT, fail
   147 000000FF 7438                <1>     je .exitBad
   148 00000101 E803030000          <1>     call lockPreamble
   149 00000106 7229                <1>     jc .exit
   150 00000108 E88B030000          <1>     call getFreeLock    ;Get a free lock in rsi
   151 0000010D 7222                <1>     jc .exit
   152                              <1> ;Here we have:
   153                              <1> ;   CF=NC
   154                              <1> ;   rbp -> MFT to add to
   155                              <1> ;   rax = Start of locked region
   156                              <1> ;   rdx = End of locked region
   157                              <1> ;   rdi -> SFT owning the lock
   158                              <1> ;   rsi -> Free lock we are creating
   159 0000010F 48894608            <1>     mov qword [rsi + fileLock.qStart], rax
   160 00000113 48895610            <1>     mov qword [rsi + fileLock.qEnd], rdx
   161 00000117 48897E18            <1>     mov qword [rsi + fileLock.pSFT], rdi
   162 0000011B 498B804F040000      <1>     mov rax, qword [r8 + currentPSP]
   163 00000122 48894620            <1>     mov qword [rsi + fileLock.qPID], rax
   164 00000126 488B4506            <1>     mov rax, qword [rbp + mft.pLock]    ;Add the lock to the head of the list
   165 0000012A 488907              <1>     mov qword [rdi + fileLock.pNext], rax   
   166 0000012D 48897B06            <1>     mov qword [rbx + mft.pLock], rdi
   167                              <1> .exit:    
   168 00000131 4158                <1>     pop r8
   169 00000133 E8C7020000          <1>     call critExit
   170                              <1>     return
    13                              <2> %%_ret:
    14 00000138 C3                  <2>  ret
    15                              <2> %assign retOff %%_ret-$$
   171                              <1> .exitBad:
   172 00000139 B821000000          <1>     mov eax, errLokVio
   173 0000013E F9                  <1>     stc
   174 0000013F EBF0                <1>     jmp short .exit
   175                              <1>     
   176                              <1> unlockFile:     
   177                              <1> ;Unlock file region. 
   178                              <1> ;Input: rdi -> SFT for file
   179                              <1> ;       ecx:edx = Start offset
   180                              <1> ;       esi:eax = Length of region
   181 00000141 E8AF020000          <1>     call critEnter
   182 00000146 4150                <1>     push r8
   183 00000148 4C8B05(26000000)    <1>     mov r8, qword [pDosseg]
   184 0000014F 48817F4F00000000    <1>     cmp qword [rdi + sft.pMFT], 0   ;If we don't have an MFT, fail
   185 00000157 74E0                <1>     je lockFile.exitBad
   186 00000159 E8AB020000          <1>     call lockPreamble
   187 0000015E 73D9                <1>     jnc lockFile.exitBad
   188 00000160 75D7                <1>     jnz lockFile.exitBad
   189                              <1> ;   rbp -> MFT to remove lock from
   190                              <1> ;   rdi -> SFT owning the lock
   191                              <1> ;   rbx -> Lock to free
   192 00000162 48397B18            <1>     cmp qword [rbx + fileLock.pSFT], rdi
   193 00000166 75D1                <1>     jne lockFile.exitBad
   194 00000168 498B804F040000      <1>     mov rax, qword [r8 + currentPSP]
   195 0000016F 48394320            <1>     cmp qword [rbx + fileLock.qPID], rax
   196 00000173 75C4                <1>     jne lockFile.exitBad
   197 00000175 488B03              <1>     mov rax, qword [rbx + fileLock.pNext]
   198 00000178 48894506            <1>     mov qword [rbp + mft.pLock], rax
   199 0000017C 488B05(14000000)    <1>     mov rax, qword [pFreeLock]
   200 00000183 488903              <1>     mov qword [rbx + fileLock.pNext], rax
   201 00000186 48891D(14000000)    <1>     mov qword [pFreeLock], rbx
   202 0000018D EBA2                <1>     jmp short lockFile.exit
   203                              <1> 
   204                              <1> 
   205                              <1> checkRegionLock:  
   206                              <1> ;Check file region locked.
   207                              <1> ;Input: rdi -> SFT for current file
   208                              <1> ;       ecx = Length of region from current position in file
   209                              <1> ;       dword [currByteF] set up with current position in file
   210                              <1> ;Get the mft ptr, walk the lock list and check that the range specified
   211                              <1> ; in between current offset and current offset + ecx is not within any range
   212 0000018F E861020000          <1>     call critEnter
   213 00000194 51                  <1>     push rcx
   214 00000195 55                  <1>     push rbp
   215 00000196 4150                <1>     push r8
   216 00000198 4C8B05(26000000)    <1>     mov r8, qword [pDosseg]
   217 0000019F 48817F4F00000000    <1>     cmp qword [rdi + sft.pMFT], 0   ;If we don't have an MFT, exit immediately
   218 000001A7 742A                <1>     je .exit
   219 000001A9 488B6D4F            <1>     mov rbp, qword [rbp + sft.pMFT] ;Get the MFT ptr
   220 000001AD 48817D0600000000    <1>     cmp qword [rbp + mft.pLock], 0  ;If we have no locks, exit immediately
   221 000001B5 741C                <1>     je .exit
   222 000001B7 418B8098070000      <1>     mov eax, dword [r8 + currByteF] ;Get the current byte count
   223 000001BE FFC9                <1>     dec ecx ;Reduce count by 1 to get last byte in range and clear upper dword
   224 000001C0 F5                  <1>     cmc     ;If carry clear here, exit (it means ecx was zero)
   225 000001C1 7310                <1>     jnc .exit
   226 000001C3 488D1408            <1>     lea rdx, qword [rax + rcx]  ;Add the read length to curroffset
   227 000001C7 31C9                <1>     xor ecx, ecx    ;Set to ignore locks rdi owns
   228                              <1> ;Below needs:  
   229                              <1> ;       rax = Start byte to check
   230                              <1> ;       rdx = End byte to check
   231                              <1> ;       rbp -> MFT to start searching 
   232                              <1> ;       ecx = 0: Do not check locks belonging to currentSFT, dMID, qPID
   233 000001C9 E86C020000          <1>     call checkLockOverlap
