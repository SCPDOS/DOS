   332                              <1> ;A lock is ours if the SFT pointer of the lock matches our SFT pointer in rdi
   333 00000644 48397E18            <1>     cmp qword [rsi + fileLock.pSFT], rdi    ;Is the SFT ours?
   334 00000648 7536                <1>     jne .nextLock   ;If not, skip
   335 0000064A 85D2                <1>     test edx, edx   ;If it is but we dont care for process ID, skip this
