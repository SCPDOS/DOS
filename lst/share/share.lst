   570                              <1> ;We get here if this file has no MFT.
   571                              <1> ;Create an MFT entry. dl and ecx are always preserved in functions below
   572 000007C6 81C116000000        <1>     add ecx, mft_size   ;ecx now has the full MFT entry size
   573 000007CC E8BB000000          <1>     call findFreeMFT
   574 000007D1 730F                <1>     jnc .buildMFT
   575 000007D3 E847000000          <1>     call defragMFTArena ;Returns rbx -> Free MFT, eax = Free MFT size
   576 000007D8 39C8                <1>     cmp eax, ecx        ;Do we fit in this free space?
   577 000007DA 7306                <1>     jnc .buildMFT
   578                              <1> ;Here if CF=CY. Return Sharing buffer full error!
   579 000007DC B824000000          <1>     mov eax, errShrFul
   580                              <1>     return
