   344                              <1> .skipProcess:
   345                              <1> ;Here we delink the flock. We move it from the MFT list to the Free list
   346                              <1> ; and cross link.
   347                              <1> ;Registers on entry
   348                              <1> ;rdi -> Our SFT
   349                              <1> ;rsi -> Lock
   350                              <1> ;rbx -> The previous lock in the file chain (only first qword valid)
   351                              <1> ;edx = Flag, do not use.
   352 00000666 488B06              <1>     mov rax, qword [rsi + fileLock.pNext]   ;Unlink rsi by linking the prev...
   353 00000669 488903              <1>     mov qword [rbx + fileLock.pNext], rax   ;... flock to the flock after rsi
   354 0000066C 488B05(14000000)    <1>     mov rax, qword [pFreeLock]              ;Get head of the free lock list
   355 00000673 488906              <1>     mov qword [rsi + fileLock.pNext], rax   ;Link rsi to the head of free list
   356 00000676 488935(14000000)    <1>     mov qword [pFreeLock], rsi              ;Make rsi the head of the free list
   357 0000067D 4889DE              <1>     mov rsi, rbx    ;Start from previous lock in the list again.
   358                              <1> .nextLock:
   359 00000680 4889F3              <1>     mov rbx, rsi    ;Point rsi to this filelock
   360 00000683 488B36              <1>     mov rsi, qword [rsi + fileLock.pNext]   ;Get next file lock
   361 00000686 EBB6                <1>     jmp short .lp
