   697                              <1> findFreeMFT:
   698                              <1> ;Searches for a free MFT of a particular size or greater.
   699                              <1> ;Input: ecx = Minimum MFT size 
   700                              <1> ;Output: CF=NC: rbx -> MFT of appropriate size
   701                              <1> ;        CF=CY: No MFT found of this size. rbx -> End MFT
   702                              <1> ;Trashes rax. All other regs preserved.
   703 0000088F 488B1D(00000000)    <1>     mov rbx, qword [pMftArena]
   704                              <1> .lp:
   705 00000896 803B00              <1>     cmp byte [rbx + mft.bSig], mftFree
   706 00000899 7840                <1>     js findMFT.noMFT    ;If sign bit set, must be mftEnd. Exit error!
   707 0000089B 7506                <1>     jne .next           ;If not equal, must be mftAlloc. Goto next MFT
   708 0000089D 394B01              <1>     cmp dword [rbx + mft.dLen], ecx ;Is this MFT ok sizewise?
   709                              <1>     retnc   ;Not carry means dLen is geq eax, as required
    61                              <2> cret nc
