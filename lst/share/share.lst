   738                              <1> getNameMeta:
   739                              <1> ;Gets the string length and checksum value
   740                              <1> ;Input: rsi -> String to search on
   741                              <1> ;Output: ecx = String length
   742                              <1> ;        edx = Checksum value
   743                              <1> ;Trashes eax.
   744 000008E2 56                  <1>     push rsi
   745 000008E3 31C9                <1>     xor ecx, ecx    ;Use for string length (zero inclusive)
   746 000008E5 31D2                <1>     xor edx, edx    ;Use for checksum value (dl)
   747                              <1> .metalp:
   748 000008E7 AC                  <1>     lodsb
   749 000008E8 00C2                <1>     add dl, al
   750 000008EA 80D200              <1>     adc dl, 0       ;Add 1 if this rolls over
   751 000008ED FFC1                <1>     inc ecx
   752 000008EF 84C0                <1>     test al, al
   753 000008F1 75F4                <1>     jnz .metalp
   754 000008F3 5E                  <1>     pop rsi
   755                              <1>     return
