   237 000001C8 31C9                <1>     xor ecx, ecx    ;Set to ignore locks currentSFT owns (i.e. rdi)
   238                              <1> ;Below needs:  
   239                              <1> ;       rax = Start byte to check
   240                              <1> ;       rdx = End byte to check
   241                              <1> ;       rbp -> MFT to start searching 
   242                              <1> ;       ecx = 0: Do not check locks belonging to currentSFT, dMID, qPID
   243 000001CA E870020000          <1>     call checkLockOverlap   ;Trashes rbx and rdi
