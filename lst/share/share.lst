   571                              <1> getMFT:
   572                              <1> ;Search for an MFT for a file. If one is not found, it creates it.
   573                              <1> ;Input: rsi -> Filename to search for
   574                              <1> ;Output: CF=NC: rbx -> MFT for this file.
   575                              <1> ;        CF=CY: eax = Error code.
   576                              <1> ;Start by working out the string length and checksum values
   577 000007C6 E8E5000000          <1>     call findMFT        ;Sets dl for checksum and ecx for string length
   578                              <1>     retnc
    61                              <2> cret nc
