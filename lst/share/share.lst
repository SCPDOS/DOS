   305                              <1> ;Now count the number of locks this file has. 
   306 0000021C 488B764F            <1>     mov rsi, qword [rsi + sft.pMFT] ;Point back to the MFT
   307 00000220 488B7606            <1>     mov rsi, qword [rsi + mft.pLock] ;Point to the lock list
   308                              <1> .lockLp:
