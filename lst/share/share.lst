   707                              <1> findMFT:
   708                              <1> ;Searches for an MFT for the filename in rsi 
   709                              <1> ;Input: rsi -> Filename to search for
   710                              <1> ;       
   711                              <1> ;Output: ecx = String length
   712                              <1> ;        dl = Filename checksum
   713                              <1> ;        CF=NC: rbx -> MFT for file
   714                              <1> ;        CF=CY: No MFT found for this file. rbx -> End MFT
   715                              <1> ;Trashes rax. All other regs preserved.
   716 000008B0 E82D000000          <1>     call getNameMeta    ;Sets ecx and dl
   717 000008B5 488B1D(00000000)    <1>     mov rbx, qword [pMftArena]
   718                              <1> .lp:
   719 000008BC 803B00              <1>     cmp byte [rbx + mft.bSig], mftFree  
   720 000008BF 781F                <1>     js .noMFT   ;If sign bit is set, bSig must be -1. End of arena!
   721 000008C1 7415                <1>     je .next    ;If this MFT is free, goto next entry
   722 000008C3 385305              <1>     cmp byte [rbx + mft.bCheckSum], dl  ;Compare checksums
   723 000008C6 7510                <1>     jne .next   ;If not equal, skip entry
   724 000008C8 57                  <1>     push rdi
   725 000008C9 488D7B16            <1>     lea rdi, qword [rbx + mft.sName] ;Point to mft filename
   726 000008CD B81E120000          <1>     mov eax, 121Eh  ;Compare strings in rsi and rdi
   727 000008D2 CD2F                <1>     int 2Fh         ;Doesnt modify string pointers
   728 000008D4 5F                  <1>     pop rdi
   729                              <1>     retz    ;If ZF=ZE (also CF=NC), we have found the MFT! Return to caller.
    41                              <2> cret z
