   331                              <1> closeDupNetFCB:   
   332                              <1> ;Close a newly created SFT-FCB handle for a procedure.
   333                              <1> ;Network SFT-FCBs handles are all collapsed into one SFT.
   334                              <1> ;----------------------------------------------------------------------------
   335                              <1> ;Input: rsi -> Newly created SFT.
   336                              <1> ;       SDA curHdlPtr must point to JFN entry with the SFTNdx for SFT in rsi 
   337                              <1> ;Output: CF=NC: eax = Handle to use
   338                              <1> ;        CF=CY: No SFT found
   339                              <1> ;----------------------------------------------------------------------------
   340                              <1> ;If
   341                              <1> ;   rsi -> SFT that is a network SFT-FCB (i.e. bit openNetFCBShr set 
   342                              <1> ;   in openmode), then we close any duplicate handles using a single
   343                              <1> ;   SFT to maintain the state (if there are none then we use this SFT
   344                              <1> ;   as the SFT-FCB). We increment the new main SFT refcount instead of 
   345                              <1> ;   having multiple SFTs.
   346                              <1> ;----------------------------------------------------------------------------
   347 00000243 4150                <1>     push r8
   348 00000245 4C8B05(26000000)    <1>     mov r8, qword [pDosseg]
   349 0000024C 0FB74602            <1>     movzx eax, word [rsi + sft.wOpenMode]
   350 00000250 25F0000000          <1>     and eax, 0F0h    ;Save the share bits
   351 00000255 3D70000000          <1>     cmp eax, openNetFCBShr
   352 0000025A 757A                <1>     jne .exitNormal
   353                              <1> ;Search for a NetFCB SFT open by this process/machine.
   354 0000025C 31DB                <1>     xor ebx, ebx    ;Search the SFT tables from index 0.
   355                              <1> .ptrLp:
   356 0000025E 53                  <1>     push rbx    ;Save the SFTNdx we are searching for
   357 0000025F B816120000          <1>     mov eax, 1216h  ;getSFTPtrfromSFTNdx -> Get in rdi the SFT for index bx
   358 00000264 CD2F                <1>     int 2Fh
   359 00000266 5B                  <1>     pop rbx
   360 00000267 726D                <1>     jc .exitNormal  ;If none found, return original handle
   361 00000269 4839F7              <1>     cmp rdi, rsi    ;Skip ourselves
   362 0000026C 742D                <1>     je .ptrNext
   363 0000026E 66813F0000          <1>     cmp word [rdi + sft.wNumHandles], 0 ;Skip if the handle is free
   364 00000273 7426                <1>     je .ptrNext
   365 00000275 0FB74602            <1>     movzx eax, word [rsi + sft.wOpenMode]
   366 00000279 663B4702            <1>     cmp ax, word [rdi + sft.wOpenMode]
   367 0000027D 751C                <1>     jne .ptrNext
   368 0000027F 8B4643              <1>     mov eax, dword [rsi + sft.dMID]
   369 00000282 394743              <1>     cmp dword [rdi + sft.dMID], eax
   370 00000285 7514                <1>     jne .ptrNext
   371 00000287 488B4647            <1>     mov rax, qword [rsi + sft.qPID]
   372 0000028B 48394747            <1>     cmp qword [rdi + sft.qPID], rax
   373 0000028F 750A                <1>     jne .ptrNext
   374 00000291 488B464F            <1>     mov rax, qword [rsi + sft.pMFT]
   375 00000295 4839474F            <1>     cmp qword [rdi + sft.pMFT], rax
   376 00000299 7404                <1>     je .ptrFnd  ;If all this holds, then we have a duplicate net handle
   377                              <1> .ptrNext:
   378 0000029B FFC3                <1>     inc ebx
   379 0000029D EBBF                <1>     jmp short .ptrLp
   380                              <1> .ptrFnd:
   381                              <1> ;Duplicate SFT found!
   382                              <1> ;rsi, the newly created SFT, is a duplicate of rdi, for this process.
   383                              <1> ;We will close rsi.
   384                              <1> ;We will keep rdi.
   385 0000029F 57                  <1>     push rdi        ;Save ptr to the SFT we will keep
   386 000002A0 89D8                <1>     mov eax, ebx    ;Save the SFTNdx of the SFT we will keep
   387                              <1> ;Now get the handle for the SFT we will keep.
   388 000002A2 31DB                <1>     xor ebx, ebx    ;Start from handle 0
   389                              <1> .jftlp:
   390 000002A4 50                  <1>     push rax
   391 000002A5 B820120000          <1>     mov eax, 1220h  ;getJFTPtr -> Get ptr to this jft entry in psp in rdi
   392 000002AA CD2F                <1>     int 2Fh
   393 000002AC 58                  <1>     pop rax
   394 000002AD 7227                <1>     jc .exitNormal  ;This should never happen... not a problem now though.
   395 000002AF 3807                <1>     cmp byte [rdi], al  ;Is this JFT entry pointing to the SFT we will keep?
   396 000002B1 7404                <1>     je .jftFnd
   397 000002B3 FFC3                <1>     inc ebx
   398 000002B5 EBED                <1>     jmp short .jftlp
   399                              <1> .jftFnd:
   400                              <1> ;Since the duplicate SFT has a valid JFT entry, we can now close the newly 
   401                              <1> ; created SFT and free its JFT entry too.
   402 000002B7 53                  <1>     push rbx    ;Save the handle for the SFT we will keep
   403 000002B8 4889F7              <1>     mov rdi, rsi    ;Set rdi to point to the copy SFT
   404 000002BB 66C7070000          <1>     mov word [rdi + sft.wNumHandles], 0 ;Free the handle we just allocated
   405 000002C0 E87EFDFFFF          <1>     call close  ;And close the newly created duplicate SFT
   406 000002C5 58                  <1>     pop rax     ;Return the handle to the still open SFT now
   407 000002C6 5F                  <1>     pop rdi     ;Return the pointer to the still open SFT now
   408 000002C7 66FF07              <1>     inc word [rdi + sft.wNumHandles]    ;Inc ref cnt of the still open SFT
   409                              <1>     
   410 000002CA 498BB05B070000      <1>     mov rsi, qword [r8 + curHdlPtr] ;Get ptr to JFT entry for closed SFT
   411 000002D1 C606FF              <1>     mov byte [rsi], -1              ;Free the old JFT entry
   412 000002D4 EB08                <1>     jmp short .exit
   413                              <1> .exitNormal:
   414 000002D6 410FB7806D070000    <1>     movzx eax, word [r8 + currentHdl]   ;Return the original handle value
   415                              <1> .exit:
   416 000002DE 4158                <1>     pop r8
   417                              <1>     return
    13                              <2> %%_ret:
    14 000002E0 C3                  <2>  ret
    15                              <2> %assign retOff %%_ret-$$
