   281                              <1> .goSft:
   282 00000207 488D7E16            <1>     lea rdi, qword [rsi + mft.sName]    ;Point to the name now
   283 0000020B 488B760E            <1>     mov rsi, qword [rsi + mft.pSFT]     ;Point rsi to the first SFT
   284                              <1> .sftLp:
   285 0000020F 4885F6              <1>     test rsi, rsi   ;If no more SFTs, fail!
   286 00000212 7429                <1>     jz .exitBad
   287 00000214 FFC9                <1>     dec ecx
   288 00000216 7406                <1>     jz .goEnd
   289 00000218 488B763B            <1>     mov rsi, qword [rsi + sft.pNextSFT]
   290 0000021C EBF1                <1>     jmp short .sftLp
