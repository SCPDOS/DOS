   566                              <1> .gsLp:
   567                              <1> ;Always update filesize and start cluster info in rsi for growth/shrink
   568                              <1> ; to the filesize and start cluster of rdi
   569 000003A7 8B4717              <1>     mov eax, dword [rdi + sft.dFileSize]
   570 000003AA 894617              <1>     mov dword [rsi + sft.dFileSize], eax
   571 000003AD 8B470F              <1>     mov eax, dword [rdi + sft.dStartClust]
   572 000003B0 89460F              <1>     mov dword [rsi + sft.dStartClust], eax
   573 000003B3 81F902000000        <1>     cmp ecx, 2      ;Was this a shrink call?
   574 000003B9 7409                <1>     je .gsDoShrink  ;Reset the cluster info if so
   575                              <1> ;Here if we are a grow call. Check if the SFT in rsi was newly created.
   576                              <1> ;If not, skip the reset below. Else, we set the absolute cluster now to
   577                              <1> ; the start cluster to ensure that the SFTs all correctly have the same
   578                              <1> ; cluster info.  
   579 000003BB 817E2300000000      <1>     cmp dword [rsi + sft.dAbsClust], 0 ;Is this sft just created?
   580 000003C2 750A                <1>     jne .gsNextFile   ;If not, and a grow call, skip the below
   581                              <1> .gsDoShrink:
   582                              <1> ;Set the cluster information back to the start of the file.
   583 000003C4 894623              <1>     mov dword [rsi + sft.dAbsClust], eax
   584 000003C7 C7461F00000000      <1>     mov dword [rsi + sft.dRelClust], 0  ;Reset the file rel cluster ptr
   585                              <1> .gsNextFile:
   586 000003CE E822000000          <1>     call .gotoNextSFT
   587 000003D3 75D2                <1>     jnz .gsLp
   588 000003D5 EBC0                <1>     jmp short .exit 
