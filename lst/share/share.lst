   680                              <1> findFreeMFT:
   681                              <1> ;Searches for a free MFT of a particular size or greater.
   682                              <1> ;Input: ecx = Minimum MFT size 
   683                              <1> ;Output: CF=NC: rbx -> MFT of appropriate size
   684                              <1> ;        CF=CY: No MFT found of this size. rbx -> End MFT
   685                              <1> ;Trashes rax. All other regs preserved.
   686 0000088C 488B1D(00000000)    <1>     mov rbx, qword [pMftArena]
   687                              <1> .lp:
   688 00000893 803B00              <1>     cmp byte [rbx + mft.bSig], mftFree
   689 00000896 7840                <1>     js findMFT.noMFT    ;If sign bit set, must be mftEnd. Exit error!
   690 00000898 7506                <1>     jne .next           ;If not equal, must be mftAlloc. Goto next MFT
   691 0000089A 394B01              <1>     cmp dword [rbx + mft.dLen], ecx ;Is this MFT ok sizewise?
   692                              <1>     retnc   ;Not carry means dLen is geq eax, as required
