   689                              <1> findFreeMFT:
   690                              <1> ;Searches for a free MFT of a particular size or greater.
   691                              <1> ;Input: ecx = Minimum MFT size 
   692                              <1> ;Output: CF=NC: rbx -> MFT of appropriate size
   693                              <1> ;        CF=CY: No MFT found of this size. rbx -> End MFT
   694                              <1> ;Trashes rax. All other regs preserved.
   695 00000894 488B1D(00000000)    <1>     mov rbx, qword [pMftArena]
   696                              <1> .lp:
   697 0000089B 803B00              <1>     cmp byte [rbx + mft.bSig], mftFree
   698 0000089E 7840                <1>     js findMFT.noMFT    ;If sign bit set, must be mftEnd. Exit error!
   699 000008A0 7506                <1>     jne .next           ;If not equal, must be mftAlloc. Goto next MFT
   700 000008A2 394B01              <1>     cmp dword [rbx + mft.dLen], ecx ;Is this MFT ok sizewise?
   701                              <1>     retnc   ;Not carry means dLen is geq eax, as required
