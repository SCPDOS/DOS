   399                              <1> checkPermissions:
   400                              <1> ;Checks for sharing conflicts of the new SFT against all
   401                              <1> ; other SFTs in the chain. 
   402                              <1> ;If both new SFT and SFT on chain are compatibility 
   403                              <1> ; then check machine id. If they are equal, goto next SFT on chain.
   404                              <1> ;Else do table logic as described below.
   405                              <1> ;
   406                              <1> ;Input: rsi -> New SFT, with machine id field set
   407                              <1> ;       rbx -> MFT for this file.
   408                              <1> ;Output: CF=NC: No sharing conflicts.
   409                              <1> ;        CF=CY: Sharing conflict, eax has error code
   410 000006D5 53                  <1>     push rbx
   411 000006D6 4889F7              <1>     mov rdi, rsi        ;Save new SFT ptr in rdi
   412 000006D9 E8A5000000          <1>     call getOpenMode    ;Get the adjusted sharing mode in eax
   413 000006DE 89C2                <1>     mov edx, eax        ;Use edx as the marker for if compat or not
   414 000006E0 81E2F0000000        <1>     and edx, 0F0h       ;Are the share bits 0?
   415 000006E6 7405                <1>     jz .compat
   416 000006E8 BAF0000000          <1>     mov edx, 0F0h       ;Set to indicate no compat mode
   417                              <1> .compat:
   418 000006ED E86C000000          <1>     call getTableIndex  ;Get table index in eax for new SFT. Use as row index
   419 000006F2 D1E0                <1>     shl eax, 1          ;Multiply by two, each row is a word
   420 000006F4 488D3545000000      <1>     lea rsi, .tbl
   421 000006FB 0FB72C06            <1>     movzx ebp, word [rsi + rax] ;Get the table entry (bit row) into ebp
   422 000006FF 488B730E            <1>     mov rsi, qword [rbx + mft.pSFT] ;Get the first SFT in chain
   423                              <1> .lp:
   424 00000703 4885F6              <1>     test rsi, rsi       ;Are we at the end of the chain?
   425 00000706 7433                <1>     jz .exit            ;If so, all ok!
   426 00000708 E876000000          <1>     call getOpenMode    ;Else, get the adjusted open mode in eax for this sft
   427 0000070D 89C1                <1>     mov ecx, eax
   428 0000070F 81E10F000000        <1>     and ecx, 0Fh        ;Get the share bits
   429 00000715 09D1                <1>     or ecx, edx         ;Check if both new and old files are in compat mode
   430 00000717 7508                <1>     jnz .notBothCompat
   431                              <1> ;Both in compat mode means we do machine id check instead.
   432                              <1> ;If they match, we skip.
   433 00000719 8B5E43              <1>     mov ebx, dword [rsi + sft.dMID]
   434 0000071C 395F43              <1>     cmp dword [rdi + sft.dMID], ebx
   435 0000071F 740F                <1>     je .gotoNext
   436                              <1> .notBothCompat:
   437 00000721 E838000000          <1>     call getTableIndex  ;Get table index but use as a column (bit) index
   438 00000726 678D4802            <1>     lea ecx, dword [eax + 2]    ;+2 to drop the x bit and push our bit into CF
   439 0000072A 89E8                <1>     mov eax, ebp        ;Move row we are interested in into eax
   440 0000072C D3E8                <1>     shr eax, cl         ;Shift the bit we are interested into CF to check
   441 0000072E 7206                <1>     jc .exitBad
   442                              <1> .gotoNext:
   443 00000730 488B763B            <1>     mov rsi, qword [rsi + sft.pNextSFT] ;Goto next SFT
   444 00000734 EBCD                <1>     jmp short .lp
   445                              <1> .exitBad:
   446                              <1> ;We come here with CF=CY
   447 00000736 B820000000          <1>     mov eax, errShrVio
   448                              <1> .exit:
   449 0000073B 4889FE              <1>     mov rsi, rdi        ;Point rsi back to the new SFT
   450 0000073E 5B                  <1>     pop rbx             ;Get back MFT pointer
   451                              <1>     return
    13                              <2> %%_ret:
    14 0000073F C3                  <2>  ret
    15                              <2> %assign retOff %%_ret-$$
   452                              <1> 
   453                              <1> .tbl:          
   454                              <1> ;Each word is a packed entry of 15 meaningful bits with the 
   455                              <1> ; lower most bit always set and meaningless.
   456                              <1> ;That is, each word is 5 lots of 3(share mode) bits.
   457                              <1> ;The bits of each word are interpreted as follows:
   458                              <1> ;     0NNNRRRWWWAAACCCxb 
   459                              <1> ; where: 
   460                              <1> ; NNN = Deny None permissions
   461                              <1> ; RRR = Deny Read permissions 
   462                              <1> ; WWW = Deny Write permissions
   463                              <1> ; AAA = Deny All permissions
   464                              <1> ; CCC = Compat permissions
   465                              <1> ; x   = Set and ignored.
   466                              <1> ;In each triple:
   467                              <1> ;   0LMNb 
   468                              <1> ; the bits are interpreted as:
   469                              <1> ; L = What to do on Read/Write access. 
   470                              <1> ; M = What to do on Write access. 
   471                              <1> ; N = What to do on Read access.
   472                              <1> ;If a bit is set, it means this combination is not allowed.
   473                              <1> ;
   474                              <1> ;We get the word we are interested in based on the open mode of
   475                              <1> ; the new SFT. This gives us a row. We then use the open mode of
   476                              <1> ; every SFT on the MFT's SFT chain, to get a bit offset into this word.
   477                              <1> ;If for every element of the SFT chain the bit in the word is 0,
   478                              <1> ; we are ok. If ever this bit is 1, we have a sharing violation.
   479                              <1> ;
   480                              <1> ;The values of this table obtained from the matrix of the the DOS 3.3 
   481                              <1> ; programmers guide (p. 6-121), where N=1 and Y=0, with the following changes
   482                              <1> ; to make implementation easier (as the numbers are ordered as so):
   483                              <1> ;1) We swap the order of the openRWAcc and openWrAcc columns/rows
   484                              <1> ;    putting RW always at the left/bottom most part. 
   485                              <1> ;2) Each row of the table below is for "subsequent IO" where each
   486                              <1> ;    bit of the entry is the column.
   487                              <1> ;3) We duplicate Deny all as for Compat
   488                              <1> 
   489                              <1> ;Table annotated as follows: 
   490                              <1> ;N=Deny none
   491                              <1> ;R=Deny read
   492                              <1> ;W=Deny write
   493                              <1> ;A=Deny all
   494                              <1> ;C=Compat
   495                              <1> ;B=Open Read/Write (both)
   496                              <1> ;O=Open Write (output)
   497                              <1> ;I=Open Read (input)
   498                              <1> ;
   499                              <1> ;        Initial Open modes
   500                              <1> ;       N   R   W   A   C  x    ;Subsequent opens
   501                              <1> ;      BOI BOI BOI BOI BOI x    
   502 00000740 FFFF                <1>     dw 111_111_111_111_111_1b   ;I        openCompat|openRdAcc
   503 00000742 FFFF                <1>     dw 111_111_111_111_111_1b   ;O C      openCompat|openWrAcc
   504 00000744 FFFF                <1>     dw 111_111_111_111_111_1b   ;B        openCompat|openRWAcc
   505                              <1> 
   506 00000746 FFFF                <1>     dw 111_111_111_111_111_1b   ;I      openDenRWShr|openRdAcc
   507 00000748 FFFF                <1>     dw 111_111_111_111_111_1b   ;O A    openDenRWShr|openWrAcc
   508 0000074A FFFF                <1>     dw 111_111_111_111_111_1b   ;B      openDenRWShr|openRWAcc
   509                              <1> 
   510 0000074C 7FDF                <1>     dw 110_111_110_111_111_1b   ;I      openDenWrShr|openRdAcc
   511 0000074E FFDB                <1>     dw 110_110_111_111_111_1b   ;O W    openDenWrShr|openWrAcc
   512 00000750 FFDF                <1>     dw 110_111_111_111_111_1b   ;B      openDenWrShr|openRWAcc
   513                              <1> 
   514 00000752 FFBE                <1>     dw 101_111_101_111_111_1b   ;I      openDenRdShr|openRdAcc
   515 00000754 FFB7                <1>     dw 101_101_111_111_111_1b   ;O R    openDenRdShr|openWrAcc
   516 00000756 FFBF                <1>     dw 101_111_111_111_111_1b   ;B      openDenRdShr|openRWAcc
   517                              <1> 
   518 00000758 7F1C                <1>     dw 000_111_000_111_111_1b   ;I      openDenNoShr|openRdAcc
   519 0000075A FF03                <1>     dw 000_000_111_111_111_1b   ;O N    openDenNoShr|openWrAcc
   520 0000075C FF1F                <1>     dw 000_111_111_111_111_1b   ;B      openDenNoShr|openWRAcc
   521                              <1> 
   522                              <1> getTableIndex:
   523                              <1> ;Turns the adjusted open mode into a table index value
   524                              <1> ;Input: eax = Adjusted open mode
   525                              <1> ;Output: eax = Index into the table (Number 0-14)
   526                              <1> ;        ecx = Share group (0-4)
   527                              <1> ;All other regs preserved
   528 0000075E 89C1                <1>     mov ecx, eax
   529 00000760 250F000000          <1>     and eax, 0Fh    ;Isolate the open mode bits only
   530 00000765 81E1F0000000        <1>     and ecx, 0F0h   ;Isolate the share bits only
   531 0000076B 81F970000000        <1>     cmp ecx, openNetFCBShr  ;Is this a net FCB share?
   532 00000771 7502                <1>     jnz .notNetFCB
   533 00000773 31C9                <1>     xor ecx, ecx    ;Compatibility share in this case
   534                              <1> .notNetFCB:
   535                              <1> ;We want ecx <- (ecx >> 4)*3 to get the share group
   536 00000775 C1E904              <1>     shr ecx, 4      ;Get the share group
   537 00000778 52                  <1>     push rdx
   538 00000779 89CA                <1>     mov edx, ecx    ;Save it in edx
   539 0000077B D1E2                <1>     shl edx, 1      ;Multiply by 2
   540 0000077D 01CA                <1>     add edx, ecx    ;Add to get it multiplied by three
   541 0000077F 01D0                <1>     add eax, edx    ;Add share group*3 to the offset into the group
   542 00000781 5A                  <1>     pop rdx
   543                              <1>     return
    13                              <2> %%_ret:
    14 00000782 C3                  <2>  ret
    15                              <2> %assign retOff %%_ret-$$
   544                              <1> 
   545                              <1> getOpenMode:
   546                              <1> ;Gets the adjusted open mode.
   547                              <1> ;--------------------------------------------------------------------
   548                              <1> ;Input: rsi -> SFT to get adjusted open mode for
   549                              <1> ;Output: eax = Adjusted open mode.
   550                              <1> ;All other registers preserved.
   551                              <1> ;--------------------------------------------------------------------
   552                              <1> ;If not an FCB of any kind, then everything is ok. 
   553                              <1> ;If an SFTFCB then we put it into openCompat | openRW.
   554                              <1> ;If a NETFCB then we put it into openCompat.
   555                              <1> ;If RO file opened in openCompat, make into openDenWrShr | openRdAcc.
   556 00000783 53                  <1>     push rbx
   557 00000784 0FB74602            <1>     movzx eax, word [rsi + sft.wOpenMode]
   558 00000788 66A90080            <1>     test ax, openSFTFCB ;Is this a local FCB?
   559 0000078C 7405                <1>     jz .notFCB
   560 0000078E B802000000          <1>     mov eax, openCompat | openRWAcc  ;FCBs have r/w access in compat mode
   561                              <1> .notFCB:
   562 00000793 89C3                <1>     mov ebx, eax
   563 00000795 81E3F0000000        <1>     and ebx, 0F0h           ;Mask off the access bits
   564 0000079B 81FB70000000        <1>     cmp ebx, openNetFCBShr  ;Is this a net FCB?
   565 000007A1 7505                <1>     jne .notNetFCB
   566 000007A3 250F000000          <1>     and eax, 0Fh        ;Mask off the share bits, turn into compat share
   567                              <1> .notNetFCB:
   568                              <1> ;Now al has the real open mode for this file. Do RO check now
   569 000007A8 89C3                <1>     mov ebx, eax
   570 000007AA 81E3F0000000        <1>     and ebx, 0F0h   ;Isolate possibly adjusted share bits
   571 000007B0 5B                  <1>     pop rbx
   572                              <1>     retnz           ;If not zero, not in compat mode
    45                              <2> cret nz
