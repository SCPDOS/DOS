   287                              <1> removeSFTfromMFT:
   288                              <1> ;Removes the SFT from the MFT's SFT chain.
   289                              <1> ;Input: rdi -> SFT we are closing.
   290                              <1> ;Output: ZF=ZE: No more files on MFT
   291                              <1> ;        ZF=NZ: More files on MFT.
   292                              <1> ;           rbx -> MFT for this file
   293                              <1> ;Trashes rax and rsi.
   294 000005E2 488B5F4F            <1>     mov rbx, qword [rdi + sft.pMFT] ;Get the MFT pointer
   295                              <1> ;Point rsi to the such that it is one sft.pNextSFT away from the pointer to
   296                              <1> ; the next SFT
   297 000005E6 488D73D3            <1>     lea rsi, qword [rbx + mft.pSFT - sft.pNextSFT]
   298                              <1> .lp:
   299 000005EA 4885F6              <1>     test rsi, rsi   ;If we dont find rdi, something has gone terribly wrong
   300 000005ED 7425                <1>     jz .crash
   301 000005EF 48397E3B            <1>     cmp qword [rsi + sft.pNextSFT], rdi    ;Is the next SFT us?
   302 000005F3 7406                <1>     je .found
   303 000005F5 488B763B            <1>     mov rsi, qword [rsi + sft.pNextSFT] ;Go to next SFT
   304 000005F9 EBEF                <1>     jmp short .lp
   305                              <1> .found:
   306                              <1> ;rsi -> Points to the previous SFT in the chain 
   307 000005FB 488B473B            <1>     mov rax, qword [rdi + sft.pNextSFT] ;Get our next SFT value
   308 000005FF 4889463B            <1>     mov qword [rsi + sft.pNextSFT], rax ;And set the prev SFT to link over us
   309 00000603 48C7474F00000000    <1>     mov qword [rdi + sft.pMFT], 0   ;Set pMFT to zero to mean we are done!
   310 0000060B 48817B0E00000000    <1>     cmp qword [rbx + mft.pSFT], 0   ;Is the MFT SFT chain ptr 0?
   311                              <1>     return
