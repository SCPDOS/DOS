   715                              <1> findMFT:
   716                              <1> ;Searches for an MFT for the filename in rsi 
   717                              <1> ;Input: rsi -> Filename to search for
   718                              <1> ;       
   719                              <1> ;Output: ecx = String length
   720                              <1> ;        dl = Filename checksum
   721                              <1> ;        CF=NC: rbx -> MFT for file
   722                              <1> ;        CF=CY: No MFT found for this file. rbx -> End MFT
   723                              <1> ;Trashes rax. All other regs preserved.
   724 000008AB E82D000000          <1>     call getNameMeta    ;Sets ecx and dl
   725 000008B0 488B1D(00000000)    <1>     mov rbx, qword [pMftArena]
   726                              <1> .lp:
   727 000008B7 803B00              <1>     cmp byte [rbx + mft.bSig], mftFree  
   728 000008BA 781F                <1>     js .noMFT   ;If sign bit is set, bSig must be -1. End of arena!
   729 000008BC 7415                <1>     je .next    ;If this MFT is free, goto next entry
   730 000008BE 385305              <1>     cmp byte [rbx + mft.bCheckSum], dl  ;Compare checksums
   731 000008C1 7510                <1>     jne .next   ;If not equal, skip entry
   732 000008C3 57                  <1>     push rdi
   733 000008C4 488D7B16            <1>     lea rdi, qword [rbx + mft.sName] ;Point to mft filename
   734 000008C8 B81E120000          <1>     mov eax, 121Eh  ;Compare strings in rsi and rdi
   735 000008CD CD2F                <1>     int 2Fh         ;Doesnt modify string pointers
   736 000008CF 5F                  <1>     pop rdi
   737                              <1>     retz    ;If ZF=ZE (also CF=NC), we have found the MFT! Return to caller.
    41                              <2> cret z
