   698                              <1> findMFT:
   699                              <1> ;Searches for an MFT for the filename in rsi 
   700                              <1> ;Input: rsi -> Filename to search for
   701                              <1> ;       
   702                              <1> ;Output: ecx = String length
   703                              <1> ;        dl = Filename checksum
   704                              <1> ;        CF=NC: rbx -> MFT for file
   705                              <1> ;        CF=CY: No MFT found for this file. rbx -> End MFT
   706                              <1> ;Trashes rax. All other regs preserved.
   707 000008A8 E82D000000          <1>     call getNameMeta    ;Sets ecx and dl
   708 000008AD 488B1D(00000000)    <1>     mov rbx, qword [pMftArena]
   709                              <1> .lp:
   710 000008B4 803B00              <1>     cmp byte [rbx + mft.bSig], mftFree  
   711 000008B7 781F                <1>     js .noMFT   ;If sign bit is set, bSig must be -1. End of arena!
   712 000008B9 7415                <1>     je .next    ;If this MFT is free, goto next entry
   713 000008BB 385305              <1>     cmp byte [rbx + mft.bCheckSum], dl  ;Compare checksums
   714 000008BE 7510                <1>     jne .next   ;If not equal, skip entry
   715 000008C0 57                  <1>     push rdi
   716 000008C1 488D7B16            <1>     lea rdi, qword [rbx + mft.sName] ;Point to mft filename
   717 000008C5 B81E120000          <1>     mov eax, 121Eh  ;Compare strings in rsi and rdi
   718 000008CA CD2F                <1>     int 2Fh         ;Doesnt modify string pointers
   719 000008CC 5F                  <1>     pop rdi
   720                              <1>     retz    ;If ZF=ZE (also CF=NC), we have found the MFT! Return to caller.
    41                              <2> cret z
