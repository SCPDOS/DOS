    36                              <3> %%a:
    37                              <3> 
   249                              <1> ;Else, goto next block
   250 0000056B 8B4F09              <1>     mov ecx, dword [rdi + mcb.blockSize]    ;Get size of block in paras
   251 0000056E 48C1E104            <1>     shl rcx, 4      ;Turn into bytes
   252 00000572 4881C110000000      <1>     add rcx, mcb_size
   253 00000579 4801CF              <1>     add rdi, rcx    ;Go to next MCB
   254                              <1> .checkMCB:
   255 0000057C 8A0F                <1>     mov cl, byte [rdi + mcb.marker] ;Now check the new MCB is valid
   256 0000057E 80F95A              <1>     cmp cl, mcbMarkEnd
   257 00000581 74D3                <1>     je .mcbLp
   258 00000583 80F94D              <1>     cmp cl, mcbMarkCtn
   259 00000586 74CE                <1>     je .mcbLp
   260 00000588 E8C4030000          <1>     call errPrintAndHalt    ;Wasn't a end or cont block, error!
   261 0000058D 4D434220434F525255- <1>     db "MCB CORRUPTION DETECTED",CR,LF,NUL
