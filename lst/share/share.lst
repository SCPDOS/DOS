    29 00000037 48817B4B00000000    <1>     cmp qword [rbx + sftHeadPtr], 0    ;Check if no SFT ptr
    30 0000003F 74CC                <1>     je badVerExit
    31 00000041 B800100000          <1>     mov eax, 1000h              ;SHARE Int 2f check
    32 00000046 CD2F                <1>     int 2Fh
