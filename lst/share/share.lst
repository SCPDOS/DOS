   378                              <1> .crash:
   379 000006B8 E88C020000          <1>     call errPrintAndHalt
   380 000006BD 53465420414C524541- <1>     db "SFT ALREADY IN USE",CR,LF,NUL
   380 000006C6 445920494E20555345- <1>
   380 000006CF 0D0A00              <1>
   381                              <1> 
   382                              <1> checkPermissions:
   383                              <1> ;Checks for sharing conflicts of the new SFT against all
   384                              <1> ; other SFTs in the chain. 
   385                              <1> ;If both new SFT and SFT on chain are compatibility 
   386                              <1> ; then check machine id. If they are equal, goto next SFT on chain.
   387                              <1> ;Else do table logic as described below.
   388                              <1> ;
   389                              <1> ;Input: rsi -> New SFT, with machine id field set
   390                              <1> ;       rbx -> MFT for this file.
   391                              <1> ;Output: CF=NC: No sharing conflicts.
   392                              <1> ;        CF=CY: Sharing conflict, eax has error code
   393 000006D2 53                  <1>     push rbx
   394 000006D3 4889F7              <1>     mov rdi, rsi        ;Save new SFT ptr in rdi
   395 000006D6 E8A5000000          <1>     call getOpenMode    ;Get the adjusted sharing mode in eax
   396 000006DB 89C2                <1>     mov edx, eax        ;Use edx as the marker for if compat or not
   397 000006DD 81E2F0000000        <1>     and edx, 0F0h       ;Are the share bits 0?
   398 000006E3 7405                <1>     jz .compat
   399 000006E5 BAF0000000          <1>     mov edx, 0F0h       ;Set to indicate no compat mode
   400                              <1> .compat:
   401 000006EA E86C000000          <1>     call getTableIndex  ;Get table index in eax for new SFT. Use as row index
   402 000006EF D1E0                <1>     shl eax, 1          ;Multiply by two, each row is a word
   403 000006F1 488D3545000000      <1>     lea rsi, .tbl
   404 000006F8 0FB72C06            <1>     movzx ebp, word [rsi + rax] ;Get the table entry (bit row) into ebp
   405 000006FC 488B730E            <1>     mov rsi, qword [rbx + mft.pSFT] ;Get the first SFT in chain
   406                              <1> .lp:
   407 00000700 4885F6              <1>     test rsi, rsi       ;Are we at the end of the chain?
   408 00000703 7433                <1>     jz .exit            ;If so, all ok!
   409 00000705 E876000000          <1>     call getOpenMode    ;Else, get the adjusted open mode in eax for this sft
   410 0000070A 89C1                <1>     mov ecx, eax
   411 0000070C 81E10F000000        <1>     and ecx, 0Fh        ;Get the share bits
   412 00000712 09D1                <1>     or ecx, edx         ;Check if both new and old files are in compat mode
   413 00000714 7508                <1>     jnz .notBothCompat
   414                              <1> ;Both in compat mode means we do machine id check instead.
   415                              <1> ;If they match, we skip.
   416 00000716 8B5E43              <1>     mov ebx, dword [rsi + sft.dMID]
   417 00000719 395F43              <1>     cmp dword [rdi + sft.dMID], ebx
   418 0000071C 740F                <1>     je .gotoNext
   419                              <1> .notBothCompat:
   420 0000071E E838000000          <1>     call getTableIndex  ;Get table index but use as a column (bit) index
   421 00000723 678D4802            <1>     lea ecx, dword [eax + 2]    ;+2 to drop the x bit and push our bit into CF
   422 00000727 89E8                <1>     mov eax, ebp        ;Move row we are interested in into eax
   423 00000729 D3E8                <1>     shr eax, cl         ;Shift the bit we are interested into CF to check
   424 0000072B 7206                <1>     jc .exitBad
   425                              <1> .gotoNext:
   426 0000072D 488B763B            <1>     mov rsi, qword [rsi + sft.pNextSFT] ;Goto next SFT
   427 00000731 EBCD                <1>     jmp short .lp
   428                              <1> .exitBad:
   429                              <1> ;We come here with CF=CY
   430 00000733 B820000000          <1>     mov eax, errShrVio
   431                              <1> .exit:
   432 00000738 4889FE              <1>     mov rsi, rdi        ;Point rsi back to the new SFT
   433 0000073B 5B                  <1>     pop rbx             ;Get back MFT pointer
   434                              <1>     return
    13                              <2> %%_ret:
    14 0000073C C3                  <2>  ret
    15                              <2> %assign retOff %%_ret-$$
   435                              <1> 
   436                              <1> .tbl:          
   437                              <1> ;Each word is a packed entry of 15 meaningful bits with the 
   438                              <1> ; lower most bit always set and meaningless.
   439                              <1> ;That is, each word is 5 lots of 3(share mode) bits.
   440                              <1> ;The bits of each word are interpreted as follows:
   441                              <1> ;     0NNNRRRWWWAAACCCxb 
   442                              <1> ; where: 
   443                              <1> ; NNN = Deny None permissions
   444                              <1> ; RRR = Deny Read permissions 
   445                              <1> ; WWW = Deny Write permissions
   446                              <1> ; AAA = Deny All permissions
   447                              <1> ; CCC = Compat permissions
   448                              <1> ; x   = Set and ignored.
   449                              <1> ;In each triple:
   450                              <1> ;   0LMNb 
   451                              <1> ; the bits are interpreted as:
   452                              <1> ; L = What to do on Read/Write access. 
   453                              <1> ; M = What to do on Write access. 
   454                              <1> ; N = What to do on Read access.
   455                              <1> ;If a bit is set, it means this combination is not allowed.
   456                              <1> ;
   457                              <1> ;We get the word we are interested in based on the open mode of
   458                              <1> ; the new SFT. This gives us a row. We then use the open mode of
   459                              <1> ; every SFT on the MFT's SFT chain, to get a bit offset into this word.
   460                              <1> ;If for every element of the SFT chain the bit in the word is 0,
   461                              <1> ; we are ok. If ever this bit is 1, we have a sharing violation.
   462                              <1> ;
   463                              <1> ;The values of this table obtained from the matrix of the the DOS 3.3 
   464                              <1> ; programmers guide (p. 6-121), where N=1 and Y=0, with the following changes
   465                              <1> ; to make implementation easier (as the numbers are ordered as so):
   466                              <1> ;1) We swap the order of the openRWAcc and openWrAcc columns/rows
   467                              <1> ;    putting RW always at the left/bottom most part. 
   468                              <1> ;2) Each row of the table below is for "subsequent IO" where each
   469                              <1> ;    bit of the entry is the column.
   470                              <1> ;3) We duplicate Deny all as for Compat
   471                              <1> 
   472                              <1> ;Table annotated as follows: 
   473                              <1> ;N=Deny none
   474                              <1> ;R=Deny read
   475                              <1> ;W=Deny write
   476                              <1> ;A=Deny all
   477                              <1> ;C=Compat
   478                              <1> ;B=Open Read/Write (both)
   479                              <1> ;O=Open Write (output)
   480                              <1> ;I=Open Read (input)
   481                              <1> ;
   482                              <1> ;        Initial Open modes
   483                              <1> ;       N   R   W   A   C  x    ;Subsequent opens
   484                              <1> ;      BOI BOI BOI BOI BOI x    
   485 0000073D FFFF                <1>     dw 111_111_111_111_111_1b   ;I        openCompat|openRdAcc
   486 0000073F FFFF                <1>     dw 111_111_111_111_111_1b   ;O C      openCompat|openWrAcc
   487 00000741 FFFF                <1>     dw 111_111_111_111_111_1b   ;B        openCompat|openRWAcc
   488                              <1> 
   489 00000743 FFFF                <1>     dw 111_111_111_111_111_1b   ;I      openDenRWShr|openRdAcc
   490 00000745 FFFF                <1>     dw 111_111_111_111_111_1b   ;O A    openDenRWShr|openWrAcc
   491 00000747 FFFF                <1>     dw 111_111_111_111_111_1b   ;B      openDenRWShr|openRWAcc
   492                              <1> 
   493 00000749 7FDF                <1>     dw 110_111_110_111_111_1b   ;I      openDenWrShr|openRdAcc
   494 0000074B FFDB                <1>     dw 110_110_111_111_111_1b   ;O W    openDenWrShr|openWrAcc
   495 0000074D FFDF                <1>     dw 110_111_111_111_111_1b   ;B      openDenWrShr|openRWAcc
   496                              <1> 
   497 0000074F FFBE                <1>     dw 101_111_101_111_111_1b   ;I      openDenRdShr|openRdAcc
   498 00000751 FFB7                <1>     dw 101_101_111_111_111_1b   ;O R    openDenRdShr|openWrAcc
   499 00000753 FFBF                <1>     dw 101_111_111_111_111_1b   ;B      openDenRdShr|openRWAcc
   500                              <1> 
   501 00000755 7F1C                <1>     dw 000_111_000_111_111_1b   ;I      openDenNoShr|openRdAcc
   502 00000757 FF03                <1>     dw 000_000_111_111_111_1b   ;O N    openDenNoShr|openWrAcc
   503 00000759 FF1F                <1>     dw 000_111_111_111_111_1b   ;B      openDenNoShr|openWRAcc
   504                              <1> 
   505                              <1> getTableIndex:
   506                              <1> ;Turns the adjusted open mode into a table index value
   507                              <1> ;Input: eax = Adjusted open mode
   508                              <1> ;Output: eax = Index into the table (Number 0-14)
   509                              <1> ;        ecx = Share group (0-4)
   510                              <1> ;All other regs preserved
   511 0000075B 89C1                <1>     mov ecx, eax
   512 0000075D 250F000000          <1>     and eax, 0Fh    ;Isolate the open mode bits only
   513 00000762 81E1F0000000        <1>     and ecx, 0F0h   ;Isolate the share bits only
   514 00000768 81F970000000        <1>     cmp ecx, openNetFCBShr  ;Is this a net FCB share?
   515 0000076E 7502                <1>     jnz .notNetFCB
   516 00000770 31C9                <1>     xor ecx, ecx    ;Compatibility share in this case
   517                              <1> .notNetFCB:
   518                              <1> ;We want ecx <- (ecx >> 4)*3 to get the share group
   519 00000772 C1E904              <1>     shr ecx, 4      ;Get the share group
   520 00000775 52                  <1>     push rdx
   521 00000776 89CA                <1>     mov edx, ecx    ;Save it in edx
   522 00000778 D1E2                <1>     shl edx, 1      ;Multiply by 2
   523 0000077A 01CA                <1>     add edx, ecx    ;Add to get it multiplied by three
   524 0000077C 01D0                <1>     add eax, edx    ;Add share group*3 to the offset into the group
   525 0000077E 5A                  <1>     pop rdx
   526                              <1>     return
    13                              <2> %%_ret:
    14 0000077F C3                  <2>  ret
    15                              <2> %assign retOff %%_ret-$$
   527                              <1> 
   528                              <1> getOpenMode:
   529                              <1> ;Gets the adjusted open mode.
   530                              <1> ;--------------------------------------------------------------------
   531                              <1> ;Input: rsi -> SFT to get adjusted open mode for
   532                              <1> ;Output: eax = Adjusted open mode.
   533                              <1> ;All other registers preserved.
   534                              <1> ;--------------------------------------------------------------------
   535                              <1> ;If not an FCB of any kind, then everything is ok. 
   536                              <1> ;If an SFTFCB then we put it into openCompat | openRW.
   537                              <1> ;If a NETFCB then we put it into openCompat.
   538                              <1> ;If RO file opened in openCompat, make into openDenWrShr | openRdAcc.
   539 00000780 53                  <1>     push rbx
   540 00000781 0FB74602            <1>     movzx eax, word [rsi + sft.wOpenMode]
   541 00000785 66A90080            <1>     test ax, openSFTFCB ;Is this a local FCB?
   542 00000789 7405                <1>     jz .notFCB
   543 0000078B B802000000          <1>     mov eax, openCompat | openRWAcc  ;FCBs have r/w access in compat mode
   544                              <1> .notFCB:
   545 00000790 89C3                <1>     mov ebx, eax
   546 00000792 81E3F0000000        <1>     and ebx, 0F0h           ;Mask off the access bits
   547 00000798 81FB70000000        <1>     cmp ebx, openNetFCBShr  ;Is this a net FCB?
   548 0000079E 7505                <1>     jne .notNetFCB
   549 000007A0 250F000000          <1>     and eax, 0Fh        ;Mask off the share bits, turn into compat share
   550                              <1> .notNetFCB:
   551                              <1> ;Now al has the real open mode for this file. Do RO check now
   552 000007A5 89C3                <1>     mov ebx, eax
   553 000007A7 81E3F0000000        <1>     and ebx, 0F0h   ;Isolate possibly adjusted share bits
   554 000007AD 5B                  <1>     pop rbx
   555                              <1>     retnz           ;If not zero, not in compat mode
    45                              <2> cret nz
