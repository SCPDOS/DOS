   371                              <1> addSFTtoMFT:
   372                              <1> ;Adds an SFT to the MFT chain and finishes filling in it's share fields. 
   373                              <1> ;Checks for sharing conflicts before adding.
   374                              <1> ;Input: rsi -> SFT to add
   375                              <1> ;       rbx -> MFT to add SFT to
   376                              <1> ;       r8 -> DOSSEG
   377                              <1> ;Output: CF=NC: SFT Added to list
   378                              <1> ;        CF=CY: Sharing violation. eax has error code
   379 00000683 48817E4F00000000    <1>     cmp qword [rsi + sft.pMFT], 0   ;This SFT better not already be on a chain
   380 0000068B 752E                <1>     jne .crash
   381                              <1> ;Add the networking ids now as we need them for permissions checking
   382 0000068D 498B806B040000      <1>     mov rax, qword [r8 + qPID]
   383 00000694 48894647            <1>     mov qword [rsi + sft.qPID], rax
   384 00000698 418B8073040000      <1>     mov eax, dword [r8 + dMID]
   385 0000069F 894643              <1>     mov dword [rsi + sft.dMID], eax
   386                              <1> ;Now we check if there are any sharing conflicts
   387 000006A2 E82E000000          <1>     call checkPermissions
   388                              <1>     retc
