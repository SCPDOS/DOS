    37                              <3> 
   587                              <1> ;We get here if this file has no MFT.
   588                              <1> ;Create an MFT entry. dl and ecx are always preserved in functions below
   589 000007C9 81C116000000        <1>     add ecx, mft_size   ;ecx now has the full MFT entry size
   590 000007CF E8BB000000          <1>     call findFreeMFT
   591 000007D4 730F                <1>     jnc .buildMFT
   592 000007D6 E847000000          <1>     call defragMFTArena ;Returns rbx -> Free MFT, eax = Free MFT size
   593 000007DB 39C8                <1>     cmp eax, ecx        ;Do we fit in this free space?
   594 000007DD 7306                <1>     jnc .buildMFT
   595                              <1> ;Here if CF=CY. Return Sharing buffer full error!
   596 000007DF B824000000          <1>     mov eax, errShrFul
   597                              <1>     return
    13                              <2> %%_ret:
    14 000007E4 C3                  <2>  ret
    15                              <2> %assign retOff %%_ret-$$
   598                              <1> .buildMFT:
   599                              <1> ;Here we have the following values:
   600                              <1> ;rsi -> String to copy in
   601                              <1> ;rbx -> Space to allocate the MFT in. rbx points to a free MFT.
   602                              <1> ;ecx = New MFT full size
   603                              <1> ;dl = String checksum 
   604                              <1> 
   605                              <1> ;Work out if we want to split space into two MFTs or keep it as one.
   606                              <1> ;Check if the MFT we are pointing at has enough space for a minimum mft and
   607                              <1> ; our MFT. If there is more than enough space, we split into two MFTs. 
   608                              <1> ;Else, we just allocate the whole space and waste the few extra bytes.
   609 000007E5 8B4301              <1>     mov eax, dword [rbx + mft.dLen] ;Get the current size of the free MFT
   610 000007E8 29C8                <1>     sub eax, ecx        ;Remove our own allocation from the free MFT size
   611 000007EA 3D26000000          <1>     cmp eax, MIN_MFT_SIZE
   612 000007EF 760D                <1>     jbe .alloc   ;If this is beq, we just use this mft entry as is.
   613                              <1> ;eax has the size of the new free block
   614 000007F1 488D3C0B            <1>     lea rdi, qword [rbx + rcx]  ;Point rdi past the end of our new mft
   615 000007F5 C60700              <1>     mov byte [rdi + mft.bSig], mftFree  ;Make the new free block
   616 000007F8 894701              <1>     mov dword [rdi + mft.dLen], eax     ;Set the new free block's size
   617 000007FB 894B01              <1>     mov dword [rbx + mft.dLen], ecx     ;Set the newly allocated block's size
   618                              <1> .alloc:
   619                              <1> ;Finally, allocate the MFT. The size, if modified, is done already.
   620 000007FE C60301              <1>     mov byte [rbx + mft.bSig], mftAlloc
   621 00000801 48C7430600000000    <1>     mov qword [rbx + mft.pLock], 0
   622 00000809 48C7430E00000000    <1>     mov qword [rbx + mft.pSFT], 0
   623 00000811 885305              <1>     mov byte [rbx + mft.bCheckSum], dl  ;Set the checksum immediately.
   624 00000814 81E916000000        <1>     sub ecx, mft_size   ;Now get just the string length
   625 0000081A 488D7B16            <1>     lea rdi, qword [rbx + mft.sName] 
   626 0000081E F3A4                <1>     rep movsb   ;Move the string over
   627 00000820 F8                  <1>     clc
   628                              <1>     return
    13                              <2> %%_ret:
    14 00000821 C3                  <2>  ret
    15                              <2> %assign retOff %%_ret-$$
   629                              <1> 
   630                              <1> defragMFTArena:
   631                              <1> ;Defragments the MFT arena. Moves all allocated MFTs to the start.
   632                              <1> ;Creates a single large free MFT from all the free space.
   633                              <1> ;Input: Nothing
   634                              <1> ;Output: MFT defragged. rbx -> New free MFT, eax = New Free MFT size
   635                              <1> ; All other regs preserved.
   636 00000822 51                  <1>     push rcx
   637 00000823 52                  <1>     push rdx
   638 00000824 56                  <1>     push rsi
   639 00000825 57                  <1>     push rdi
   640                              <1> ;rsi = Read pointer
   641                              <1> ;rdi = Write pointer
   642                              <1> ;edx = Free space accumulator
   643 00000826 488B35(00000000)    <1>     mov rsi, qword [pMftArena]
   644 0000082D 4889F7              <1>     mov rdi, rsi
   645 00000830 31D2                <1>     xor edx, edx
   646                              <1> .lp:
   647                              <1> ;If we encounter an allocated mft, we move it over, moving the 
   648                              <1> ; the read and write pointers. If we encounter a free mft, we add its
   649                              <1> ; size and move the read pointer.
   650 00000832 803E00              <1>     cmp byte [rsi + mft.bSig], mftFree
   651 00000835 7826                <1>     js .exit    ;At this point, all compression is done. Goto end
   652 00000837 741A                <1>     je .free
   653                              <1> ;Here we copy over. Before we do, we walk down the SFT chain
   654                              <1> ; updating the MFT pointer in each SFT.
   655                              <1> ;rsi -> Allocated MFT
   656                              <1> ;rdi -> Where this MFT will be moved to
   657 00000839 488B5E0E            <1>     mov rbx, qword [rsi + mft.pSFT]     ;Point rbx to the first SFT in chain.
   658                              <1> .sftLp:
   659 0000083D 4885DB              <1>     test rbx, rbx   ;End of SFT chain?
   660 00000840 740A                <1>     jz .sftEnd
   661 00000842 48897B4F            <1>     mov qword [rbx + sft.pMFT], rdi     ;Update the SFT's MFT pointer
   662 00000846 488B5B3B            <1>     mov rbx, qword [rbx + sft.pNextSFT]
   663 0000084A EBF1                <1>     jmp short .sftLp
   664                              <1> .sftEnd:
   665                              <1> ;All SFTs updated, now we copy the MFT up.
   666 0000084C 8B4E01              <1>     mov ecx, dword [rsi + mft.dLen] ;Get the length of this MFT
   667 0000084F F3A4                <1>     rep movsb   ;Moves both pointers to the end of the MFT
   668                              <1> ;Now rdi points to the next write space and rsi points to the next MFT
   669 00000851 EBDF                <1>     jmp short .lp
   670                              <1> .free:
   671                              <1> ;Dont worry about overflow. Max dLen is 1Mb, way less than 32 bit max.
   672 00000853 8B4601              <1>     mov eax, dword [rsi + mft.dLen] ;Get the length
   673 00000856 01C2                <1>     add edx, eax    ;Add to the free space accumulator
   674 00000858 4801C6              <1>     add rsi, rax    ;Move the read pointer past this free space
   675 0000085B EBD5                <1>     jmp short .lp
   676                              <1> .exit:
   677                              <1> ;Now we must make a single free MFT at the write pointer with the 
   678                              <1> ; correct size and assert it is correct
   679                              <1> ;rdi -> Where to make this MFT
   680                              <1> ;edx = Accumulated free space
   681 0000085D C60700              <1>     mov byte [rdi + mft.bSig], mftFree
   682 00000860 895701              <1>     mov dword [rdi + mft.dLen], edx
   683 00000863 89D0                <1>     mov eax, edx    ;Get the free MFT size into eax
   684 00000865 4889FB              <1>     mov rbx, rdi    ;Get the free MFT pointer into rbx
   685 00000868 4801D7              <1>     add rdi, rdx    ;Now check the MFT chain is not corrupted
   686 0000086B 803FFF              <1>     cmp byte [rdi + mft.bSig], mftEnd
   687 0000086E 7505                <1>     jne .crash
   688 00000870 5F                  <1>     pop rdi
   689 00000871 5E                  <1>     pop rsi
   690 00000872 5A                  <1>     pop rdx
   691 00000873 59                  <1>     pop rcx
   692                              <1>     return
    13                              <2> %%_ret:
    14 00000874 C3                  <2>  ret
    15                              <2> %assign retOff %%_ret-$$
   693                              <1> .crash:
   694 00000875 E8D2000000          <1>     call errPrintAndHalt    ;No return. Use call to push string ptr to stack
   695 0000087A 4D4654204445465241- <1>     db "MFT DEFRAG FAILURE",CR,LF,NUL
   695 00000883 47204641494C555245- <1>
   695 0000088C 0D0A00              <1>
