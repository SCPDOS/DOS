   272 000001FB 7406                <1>     jz .mftNext ;If its free, just goto next MFT
   273 000001FD 7242                <1>     jb .exitBad ;If we are at the end, exit error!
   274 000001FF FFCB                <1>     dec ebx     ;Drop one from the count, if zero, we have arrived
   275 00000201 7408                <1>     jz .goSft
   276                              <1> .mftNext:
   277 00000203 8B4601              <1>     mov eax, dword [rsi + mft.dLen]
   278 00000206 4801C6              <1>     add rsi, rax    ;Goto the next MFT
   279 00000209 EBED                <1>     jmp short .mftLp
   280                              <1> .goSft:
   281 0000020B 488D7E16            <1>     lea rdi, qword [rsi + mft.sName]    ;Point to the name now
   282 0000020F 488B760E            <1>     mov rsi, qword [rsi + mft.pSFT]     ;Point rsi to the first SFT
   283                              <1> .sftLp:
   284 00000213 4885F6              <1>     test rsi, rsi   ;If no more SFTs, fail!
   285 00000216 7429                <1>     jz .exitBad
   286 00000218 FFC9                <1>     dec ecx
   287 0000021A 7406                <1>     jz .goEnd
   288 0000021C 488B763B            <1>     mov rsi, qword [rsi + sft.pNextSFT]
   289 00000220 EBF1                <1>     jmp short .sftLp
