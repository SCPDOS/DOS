   386                              <1> .skipProcess:
   387                              <1> ;Here we delink the flock. We move it from the MFT list to the Free list
   388                              <1> ; and cross link.
   389                              <1> ;Registers on entry
   390                              <1> ;rdi -> Our SFT
   391                              <1> ;rsi -> Lock
   392                              <1> ;rbx -> The previous lock in the file chain (only first qword valid)
   393                              <1> ;edx = Flag, do not use.
   394 00000692 488B06              <1>     mov rax, qword [rsi + fileLock.pNext]   ;Unlink rsi by linking the prev...
