   402                              <1> closeRenDel:
   403                              <1> ;On rename/delete/setattr, this function is called to check we can proceed
   404                              <1> ; with the operation.
   405                              <1> ;Finds MFT based on the filename in fname1Ptr in the dosseg
   406                              <1> ;----------------------------------------------------------------------------
   407                              <1> ;Input: fname1Ptr -> Filename to do check on
   408                              <1> ;Output: Nothing
   409                              <1> ;----------------------------------------------------------------------------
   410                              <1> ;If 
   411                              <1> ;   the file is not open, then we return ok.
   412                              <1> ;Else if 
   413                              <1> ;   the file is opened by us uniquely and is open in compatibility mode,
   414                              <1> ;   then close the file and return ok.
   415                              <1> ;Else, we fail.
   416                              <1> ;----------------------------------------------------------------------------
   417 000002DF 4150                <1>     push r8
   418 000002E1 4C8B05(26000000)    <1>     mov r8, qword [pDosseg]
   419 000002E8 E80B010000          <1>     call critEnter
   420                              <1> .again:
   421 000002ED 498BB050060000      <1>     mov rsi, qword [r8 + fname1Ptr] ;Get the filename pointer
   422 000002F4 E8B2050000          <1>     call findMFT    ;Looks for this file
   423 000002F9 7237                <1>     jc .exit    ;If the file doesn't exist, exit
   424                              <1> ;File MFT found. rbx -> MFT. 
   425                              <1> ; Now check that all the files on this chain have the mid and pid of 
   426                              <1> ; the requester and (are in compatibility mode or a net SFT).
   427 000002FB 488B730E            <1>     mov rsi, qword [rbx + mft.pSFT] ;This cant be empty so it must be an SFT
   428 000002FF 4889F7              <1>     mov rdi, rsi    ;Save this SFT pointer in rdi
   429                              <1> .scanLp:
   430 00000302 418B8073040000      <1>     mov eax, dword [r8 + dMID]
   431 00000309 3B4643              <1>     cmp eax, dword [rsi + sft.dMID]
   432 0000030C 7524                <1>     jne .exit
   433 0000030E 498B806B040000      <1>     mov rax, qword [r8 + qPID]
   434 00000315 483B4647            <1>     cmp rax, qword [rsi + sft.qPID]
   435 00000319 7517                <1>     jne .exit
   436 0000031B 0FB74602            <1>     movzx eax, word [rsi + sft.wOpenMode]
   437 0000031F 25F0000000          <1>     and eax, 0F0h    ;Get the sharing mode
   438                              <1> ;If compatibility mode or net fcb, proceed with close
   439 00000324 3D70000000          <1>     cmp eax, openNetFCBShr
   440 00000329 740F                <1>     je .next
   441 0000032B 3D00000000          <1>     cmp eax, openCompat
   442 00000330 7408                <1>     je .next
   443                              <1> .exit:
   444 00000332 E8CB000000          <1>     call critExit
   445 00000337 4158                <1>     pop r8
   446                              <1>     return
    13                              <2> %%_ret:
    14 00000339 C3                  <2>  ret
    15                              <2> %assign retOff %%_ret-$$
   447                              <1> .next:
   448 0000033A 488B763B            <1>     mov rsi, qword [rsi + sft.pNextSFT]
   449 0000033E 4885F6              <1>     test rsi, rsi
   450 00000341 75BF                <1>     jnz .scanLp
   451                              <1> ;Here we must close all the handles referring to this SFT
   452                              <1> ;rdi -> First SFT 
   453 00000343 4989B863070000      <1>     mov qword [r8 + currentSFT], rdi    ;Set this SFT as current SFT
   454                              <1> ;These two require currentSFT set
   455 0000034A E8DF010000          <1>     call closeHandlesForSFT
   456 0000034F E8D2010000          <1>     call closeSFT
   457 00000354 E994FFFFFF          <1>     jmp .again  ;Now do this again until no more files
   458                              <1> 
