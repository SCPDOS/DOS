   778                              <1> .isPIDSpecial:
   779                              <1> ;Certain PIDs have special meaning and must be ignored.
   780                              <1> ;If free or a hole, ignore.
   781                              <1> ;If DOS or New DOS (should NEVER exist outside of a drivers init)
   782                              <1> ; we get return the DOS PSP address in rax and pretend it is not 
   783                              <1> ; special.
   784                              <1> ;Input: rax = PID to check
   785                              <1> ;Output: ZF=ZE: Special PID, don't operate on it
   786                              <1> ;        ZF=NZ: Normal PID, proceed.
   787 0000091F 483D00000000        <1>     cmp rax, mcbOwnerFree   ;Bona-fide must be ignored
   788                              <1>     rete
