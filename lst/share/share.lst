    42                                  segment bss$r bss private align=16
    43                                  %include "./src/share/data/shbss.asm"
     1                              <1> ;All BSS variables go here
     2                              <1> 
     3 00000000 ????????????????    <1> pMftArena   dq ?
     4 00000008 ????????            <1> dMftArenaSz dd ?    ;Size of MFT arena in bytes (max 1048576 bytes i.e. 1 Mb)
     5 0000000C ????????????????    <1> pLockArena  dq ?
     6 00000014 ????????????????    <1> pFreeLock   dq ?    ;Ptr to head of Free lock chain. 0 means no free locks left
     7 0000001C ????                <1> wNumLocks   dw ?    ;Store number of locks here (max 9999)
     8 0000001E ????????????????    <1> pOldI2Fh    dq ?    ;Ptr to old Int 2Fh for chaining
     9 00000026 ????????????????    <1> pDosseg     dq ?    ;Ptr to the DOSSEG
    10 0000002E ????????????????    <1> pPSP        dq ?    ;Ptr to share psp. Used as scratch space once resident.
    44                                  
    45                                  ;---------------------------
    46                                  ;       Share code seg
    47                                  ;---------------------------
    48                                  segment .text code private align=16 use64
    49                                  ;Place this explicit .text section to calm nasm down
    50                                  segment code$r code private align=16 use64
    51                                  %include "./src/share/text/shmain.asm"
     1                              <1> ;-------------------------------------------------------------------------
     2                              <1> ;This file contains the all the functions that have external linkage.
     3                              <1> ;
     4                              <1> ; Int 2Fh handler -> Handles share check calls.
     5                              <1> ; open -> Creates or assignes and MFT for a newly opened/created SFT.
     6                              <1> ; close -> Releases all share resources allocated to an SFT.
     7                              <1> ; closeAllByMachine -> Releases all sharing resources for SFTs made 
     8                              <1> ;   by a particular machine.
     9                              <1> ; closeAllByProcess -> Releases all sharing resources for SFTs made 
    10                              <1> ;   by a particular machine and process.
    11                              <1> ; closeAllByName -> Releases all sharing resources allocated to 
    12                              <1> ;   a particular MFT for a given FQ filename.
    13                              <1> ; lockFile -> Assigns a file lock to a file.
    14                              <1> ; unlockFile -> Releases a file lock from a file.
    15                              <1> ; checkRegionLock -> Checks that the region specified is not locked.
    16                              <1> ; getSFTShareInfo -> Gets sharing information about a particular SFT.
    17                              <1> ; updateFCB -> Unused and should not be touched.
    18                              <1> ; getFirstClusterFCB -> Unused and should not be touched.
    19                              <1> ; closeNetworkFiles -> Collapses duplicate Net SFT-FCBs into a single SFT.
    20                              <1> ; closeRenDel -> Closes all compat mode and Net SFT-FCBs for a file.
    21                              <1> ; dirUpdate -> Updates directory information across all SFTs for a file.
    22                              <1> ;-------------------------------------------------------------------------
    23                              <1> 
    24                              <1> i2fHandler:
    25 00000000 80FC10              <1>     cmp ah, 10h ;Is this call for us?
    26 00000003 7508                <1>     jne .gotoNext
    27 00000005 84C0                <1>     test al, al ;Do we test presence of share?
    28 00000007 7502                <1>     jnz .exit   ;If not, probably badly behaved code. Let it return silently
    29 00000009 B0FF                <1>     mov al, -1  ;Else, indicate we are already installed
    30                              <1> .exit:
    31 0000000B 48CF                <1>     iretq
    32                              <1> .gotoNext:
    33 0000000D FF25(1E000000)      <1>     jmp qword [pOldI2Fh]
    34                              <1> 
    35                              <1> open:           
    36                              <1> ;Called on file create/open. Creates/Finds an MFT entry for the file
    37                              <1> ; being opened and adds the new SFT to the MFT chain.
    38                              <1> ;----------------------------------------------------------------------------
    39                              <1> ;Input: qword [fname1Ptr] -> Fully qualified pathname to open
    40                              <1> ;       qword [currentSFT] -> SFT that was just created/opened
    41                              <1> ;           This SFT needs the following fields filled in:
    42                              <1> ;               .wOpenMode
    43                              <1> ;               .bFileAttrib
    44                              <1> ;               .dMID
    45                              <1> ;               .qPID
    46                              <1> ;               .pMFT
    47                              <1> ;       qword [qPID] -> Process ID of the requesting task
    48                              <1> ;       dword [dMID] -> Machine ID of the requesting task
    49                              <1> ;Output: CF=NC: Proceed happily with SFT linked into the MFT for the file.
    50                              <1> ;        CF=CY: eax = Error code for request. Abort, free SFT.
    51                              <1> ;Use r8 as DOSSEG base
    52                              <1> ;----------------------------------------------------------------------------
    53 00000013 E8E0030000          <1>     call critEnter
    54 00000018 4150                <1>     push r8
    55 0000001A 4C8B05(26000000)    <1>     mov r8, qword [pDosseg]
    56 00000021 498BB050060000      <1>     mov rsi, qword [r8 + fname1Ptr] ;Get the filename pointer
    57 00000028 E894070000          <1>     call getMFT
    58 0000002D 720C                <1>     jc .exit
    59                              <1> ;rbx -> MFT for this file here.
    60 0000002F 498BB063070000      <1>     mov rsi, qword [r8 + currentSFT]    ;Get the current SFT now
    61 00000036 E848060000          <1>     call addSFTtoMFT    ;Bubble CF
    62                              <1> .exit:
    63 0000003B 4158                <1>     pop r8
    64 0000003D E8C0030000          <1>     call critExit
    65                              <1>     return
    13                              <2> %%_ret:
    14 00000042 C3                  <2>  ret
    15                              <2> %assign retOff %%_ret-$$
    66                              <1> 
    67                              <1> close:          
    68                              <1> ;Called on file close. Frees all sharing information associated with
    69                              <1> ; a file.
    70                              <1> ;Input: rdi -> SFT we are closing.
    71 00000043 E8B0030000          <1>     call critEnter
    72 00000048 488B5F4F            <1>     mov rbx, qword [rdi + sft.pMFT]
    73 0000004C 4885DB              <1>     test rbx, rbx   ;If this is an SFT from before Share loaded, do nothing!
    74 0000004F 741C                <1>     jz .exit
    75 00000051 0FBF07              <1>     movsx eax, word [rdi + sft.wNumHandles] ;Get the count
    76 00000054 85C0                <1>     test eax, eax   ;If count is zero, free all sharing data
    77 00000056 7404                <1>     jz .goClose
    78 00000058 FFC0                <1>     inc eax         ;If this handle is -1, also free any sharing data.
    79 0000005A 7511                <1>     jnz .exit       ;If not -1 or 0, then inc eax > 0 and so we just exit
    80                              <1> .goClose:
    81 0000005C E8C9050000          <1>     call freeLocks  ;Free all locks associated to this SFT
    82 00000061 E877050000          <1>     call removeSFTfromMFT ;Delink this SFT from the SFT link
    83 00000066 7505                <1>     jnz .exit       ;If not last SFT in MFT chain, dont free MFT
    84 00000068 E835050000          <1>     call freeMFT    ;If no more SFTs, free the MFT. Do small GC.
    85                              <1> .exit:
    86 0000006D E890030000          <1>     call critExit
    87                              <1>     return
    13                              <2> %%_ret:
    14 00000072 C3                  <2>  ret
    15                              <2> %assign retOff %%_ret-$$
    88                              <1> 
    89                              <1> closeAllByMachine:      
    90                              <1> ;Close all files for a machine.
    91                              <1> ;Input: rdx -> DPL (use dMID only)
    92 00000073 E880030000          <1>     call critEnter
    93 00000078 31C9                <1>     xor ecx, ecx
    94 0000007A 48FFC9              <1>     dec rcx ;Get -1 into ecx to indicate not to use this
    95 0000007D 488B5218            <1>     mov rdx, qword [rdx + dpl.rdx]  ;Get the MID
    96 00000081 E833040000          <1>     call closeByID
    97 00000086 E877030000          <1>     call critExit
    98                              <1>     return
    13                              <2> %%_ret:
    14 0000008B C3                  <2>  ret
    15                              <2> %assign retOff %%_ret-$$
    99                              <1> 
   100                              <1> closeAllByProcess:      
   101                              <1> ;Close all files for a task.
   102                              <1> ;Input: rdx -> DPL (use dMID and qPID)
   103 0000008C E867030000          <1>     call critEnter
   104 00000091 488B4A18            <1>     mov rcx, qword [rdx + dpl.rdx]  ;Get the PID
   105 00000095 488B5218            <1>     mov rdx, qword [rdx + dpl.rdx]  ;Get the MID
   106 00000099 E81B040000          <1>     call closeByID
   107 0000009E E85F030000          <1>     call critExit
   108                              <1>     return
    13                              <2> %%_ret:
    14 000000A3 C3                  <2>  ret
    15                              <2> %assign retOff %%_ret-$$
   109                              <1> 
   110                              <1> closeAllByName:      
   111                              <1> ;Close all files by name.
   112                              <1> ;Input: rdx -> DPL (use rdx, dMID and qPID)
   113 000000A4 E84F030000          <1>     call critEnter
   114 000000A9 4150                <1>     push r8
   115 000000AB 4C8B05(26000000)    <1>     mov r8, qword [pDosseg] ;Needed for the close handles call below
   116 000000B2 488B7218            <1>     mov rsi, qword [rdx + dpl.rdx]  ;Get the filename ptr in rsi
   117 000000B6 E8F0070000          <1>     call findMFT    ;Find the MFT for this file name
   118 000000BB 7220                <1>     jc .exit
   119 000000BD 488B7B0E            <1>     mov rdi, qword [rbx + mft.pSFT] ;Get the ptr to the first SFT
   120                              <1> .lp:
   121                              <1> ;We work by looking ahead an SFT in the chain. This is because closeSFT
   122                              <1> ; might free the MFT so instead of having to search for it each time
   123                              <1> ; we look for the condition on which it will be freed, i.e. the sft we are at
   124                              <1> ; being the last SFT open on that MFT.
   125 000000C1 4885FF              <1>     test rdi, rdi   ;Is the SFT ptr null? Exit if so
   126 000000C4 7417                <1>     jz .exit
   127 000000C6 4989B863070000      <1>     mov qword [r8 + currentSFT], rdi    ;Else, set this SFT to be current
   128 000000CD FF773B              <1>     push qword [rdi + sft.pNextSFT]     ;Save next SFT
   129                              <1> ;These two require currentSFT set
   130 000000D0 E859040000          <1>     call closeHandlesForSFT ;Closes this SFT on all processes
   131 000000D5 E84C040000          <1>     call closeSFT   ;Close this SFT
   132 000000DA 5F                  <1>     pop rdi         ;Get the ptr to the next SFT in rdi
   133 000000DB EBE4                <1>     jmp short .lp
   134                              <1> .exit:
   135 000000DD 4158                <1>     pop r8
   136 000000DF E81E030000          <1>     call critExit
   137                              <1>     return
    13                              <2> %%_ret:
    14 000000E4 C3                  <2>  ret
    15                              <2> %assign retOff %%_ret-$$
   138                              <1> 
   139                              <1> lockFile:       
   140                              <1> ;Lock a file region.
   141                              <1> ;Input: rdi -> SFT for file
   142                              <1> ;       ecx:edx = Start offset
   143                              <1> ;       esi:eax = Length of region
   144 000000E5 E80E030000          <1>     call critEnter
   145 000000EA 4150                <1>     push r8
   146 000000EC 4C8B05(26000000)    <1>     mov r8, qword [pDosseg]
   147 000000F3 48817F4F00000000    <1>     cmp qword [rdi + sft.pMFT], 0   ;If we don't have an MFT, fail
   148 000000FB 743A                <1>     je .exitBad
   149 000000FD 57                  <1>     push rdi    ;Save SFT ptr
   150 000000FE E809030000          <1>     call lockPreamble   ;Trashes rbx and rdi
   151 00000103 5F                  <1>     pop rdi
   152 00000104 7229                <1>     jc .exit
   153 00000106 E891030000          <1>     call getFreeLock    ;Get a free lock in rsi
   154 0000010B 7222                <1>     jc .exit
   155                              <1> ;Here we have:
   156                              <1> ;   CF=NC
   157                              <1> ;   rbp -> MFT to add to
   158                              <1> ;   rax = Start of locked region
   159                              <1> ;   rdx = End of locked region
   160                              <1> ;   rdi -> SFT owning the lock
   161                              <1> ;   rsi -> Free lock we are creating
   162 0000010D 48894608            <1>     mov qword [rsi + fileLock.qStart], rax
   163 00000111 48895610            <1>     mov qword [rsi + fileLock.qEnd], rdx
   164 00000115 48897E18            <1>     mov qword [rsi + fileLock.pSFT], rdi
   165 00000119 498B804F040000      <1>     mov rax, qword [r8 + currentPSP]
   166 00000120 48894620            <1>     mov qword [rsi + fileLock.qPID], rax
   167 00000124 488B4506            <1>     mov rax, qword [rbp + mft.pLock]    ;Get the head of the list
   168 00000128 488906              <1>     mov qword [rsi + fileLock.pNext], rax   ;Link to the new file lock
   169 0000012B 48897306            <1>     mov qword [rbx + mft.pLock], rsi    ;Add the lock to the head of the list
   170                              <1> .exit:    
   171 0000012F 4158                <1>     pop r8
   172 00000131 E8CC020000          <1>     call critExit
   173                              <1>     return
    13                              <2> %%_ret:
    14 00000136 C3                  <2>  ret
    15                              <2> %assign retOff %%_ret-$$
   174                              <1> .exitBad:
   175 00000137 B821000000          <1>     mov eax, errLokVio
   176 0000013C F9                  <1>     stc
   177 0000013D EBF0                <1>     jmp short .exit
   178                              <1> 
   179                              <1> unlockFile:     
   180                              <1> ;Unlock file region. 
   181                              <1> ;Input: rdi -> SFT for file
   182                              <1> ;       ecx:edx = Start offset
   183                              <1> ;       esi:eax = Length of region
   184 0000013F E8B4020000          <1>     call critEnter
   185 00000144 4150                <1>     push r8
   186 00000146 4C8B05(26000000)    <1>     mov r8, qword [pDosseg]
   187 0000014D 48817F4F00000000    <1>     cmp qword [rdi + sft.pMFT], 0   ;If we don't have an MFT, fail
   188 00000155 74E0                <1>     je lockFile.exitBad
   189 00000157 57                  <1>     push rdi    ;Save current SFT
   190 00000158 E8AF020000          <1>     call lockPreamble   ;Get rbx -> Matched lock, rdi -> Lock pointing to rbx
   191 0000015D 5E                  <1>     pop rsi     ;Get back current SFT in rsi
   192 0000015E 73D7                <1>     jnc lockFile.exitBad    ;If true, no match, rdi and rbx meaningless.
   193 00000160 75D5                <1>     jnz lockFile.exitBad    ;If true, not exact match.
   194                              <1> ;   rbp -> MFT to remove lock from
   195                              <1> ;   rsi -> SFT owning the lock
   196                              <1> ;   rbx -> Lock to free
   197                              <1> ;   rdi -> Lock pointed to by rbx
   198 00000162 48397318            <1>     cmp qword [rbx + fileLock.pSFT], rsi    ;Check we own this lock
   199 00000166 75CF                <1>     jne lockFile.exitBad
   200 00000168 498B804F040000      <1>     mov rax, qword [r8 + currentPSP]
   201 0000016F 48394320            <1>     cmp qword [rbx + fileLock.qPID], rax    ;Check this process can remove it
   202 00000173 75C2                <1>     jne lockFile.exitBad
   203                              <1> ;Link over the lock we are freeing (pointed to by rbx), removing from mft list
   204 00000175 488B03              <1>     mov rax, qword [rbx + fileLock.pNext]
   205 00000178 488907              <1>     mov qword [rdi + fileLock.pNext], rax
   206                              <1> ;Add the lock (pointed to by rbx) to the head of the free list
   207 0000017B 488B05(14000000)    <1>     mov rax, qword [pFreeLock]
   208 00000182 488903              <1>     mov qword [rbx + fileLock.pNext], rax
   209 00000185 48891D(14000000)    <1>     mov qword [pFreeLock], rbx
   210 0000018C EBA1                <1>     jmp short lockFile.exit
   211                              <1> 
   212                              <1> 
   213                              <1> checkRegionLock:  
   214                              <1> ;Check file region locked.
   215                              <1> ;Input: rdi -> SFT for current file
   216                              <1> ;       ecx = Length of region from current position in file
   217                              <1> ;       dword [currByteF] set up with current position in file
   218                              <1> ;Get the mft ptr, walk the lock list and check that the range specified
   219                              <1> ; in between current offset and current offset + ecx is not within any range
   220 0000018E E865020000          <1>     call critEnter
   221 00000193 53                  <1>     push rbx
   222 00000194 51                  <1>     push rcx
   223 00000195 57                  <1>     push rdi
   224 00000196 55                  <1>     push rbp
   225 00000197 4150                <1>     push r8
