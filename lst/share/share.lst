   329                              <1> removeSFTfromMFT:
   330                              <1> ;Removes the SFT from the MFT's SFT chain.
   331                              <1> ;Input: rdi -> SFT we are closing.
   332                              <1> ;Output: ZF=ZE: No more files on MFT
   333                              <1> ;        ZF=NZ: More files on MFT.
   334                              <1> ;           rbx -> MFT for this file
   335                              <1> ;Trashes rax and rsi.
