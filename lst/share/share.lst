   729                              <1> getNameMeta:
   730                              <1> ;Gets the string length and checksum value
   731                              <1> ;Input: rsi -> String to search on
   732                              <1> ;Output: ecx = String length
   733                              <1> ;        edx = Checksum value
   734                              <1> ;Trashes eax.
   735 000008DA 56                  <1>     push rsi
   736 000008DB 31C9                <1>     xor ecx, ecx    ;Use for string length (zero inclusive)
   737 000008DD 31D2                <1>     xor edx, edx    ;Use for checksum value (dl)
   738                              <1> .metalp:
   739 000008DF AC                  <1>     lodsb
   740 000008E0 00C2                <1>     add dl, al
   741 000008E2 80D200              <1>     adc dl, 0       ;Add 1 if this rolls over
   742 000008E5 FFC1                <1>     inc ecx
   743 000008E7 84C0                <1>     test al, al
   744 000008E9 75F4                <1>     jnz .metalp
   745 000008EB 5E                  <1>     pop rsi
   746                              <1>     return
