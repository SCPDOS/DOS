   139 00000184 89CB                <1>     mov ebx, ecx
   140 00000186 81C30F000000        <1>     add ebx, 0Fh    ;Round up
   141 0000018C C1EB04              <1>     shr ebx, 4      ;Get number of paras
   142 0000018F B800480000          <1>     mov eax, 4800h
