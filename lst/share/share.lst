   221                              <1> closeSFT:
   222                              <1> ;Closes current SFT
   223                              <1> ;Input: qword [currentSFT] = SFT to close
   224 00000526 B801120000          <1>     mov eax, 1201h ;Close the currentSFT
   225 0000052B CD2F                <1>     int 2Fh
   226                              <1>     return
    13                              <2> %%_ret:
    14 0000052D C3                  <2>  ret
    15                              <2> %assign retOff %%_ret-$$
   227                              <1> 
   228                              <1> closeHandlesForSFT:
   229                              <1> ;Closes all handles referencing the current SFT
   230                              <1> ;Input: r8 -> DOSSEG
   231                              <1> ;       qword [currentSFT] = SFT to close handles for
   232                              <1> ;rdx, rbp and r8 saved. All other regs trashed.
   233 0000052E 498BB063070000      <1>     mov rsi, qword [r8 + currentSFT]
   234 00000535 31DB                <1>     xor ebx, ebx
   235                              <1> .sftIndxLp:
   236 00000537 53                  <1>     push rbx
   237 00000538 B816120000          <1>     mov eax, 1216h  ;Get SFT Ptr from SFT Index into rdi
   238 0000053D CD2F                <1>     int 2Fh
   239 0000053F 5B                  <1>     pop rbx
   240 00000540 FFC3                <1>     inc ebx
   241 00000542 4839FE              <1>     cmp rsi, rdi    ;Was this index correct?
   242 00000545 75F0                <1>     jne .sftIndxLp
   243 00000547 FFCB                <1>     dec ebx         ;Decrement it back, we are looking for this number
   244                              <1> ;Now we walk the Arena Chain to find every task ID and close the
   245                              <1> ; JFT entry for this file if the SFTIndex exists in that task's JFT
   246 00000549 31C0                <1>     xor eax, eax    ;Zero to give a PID that will not be at the start
   247 0000054B 498B783B            <1>     mov rdi, qword [r8 + mcbChainPtr]   ;Get the MCB chain header in rdi
   248 0000054F EB26                <1>     jmp short .checkMCB ;Make sure this MCB is a valid MCB
   249                              <1> .mcbLp:
   250 00000551 483B4701            <1>     cmp rax, qword [rdi + mcb.owner]    ;If new PID same as before, skip
   251 00000555 7409                <1>     je .getNextMCB
   252 00000557 488B4701            <1>     mov rax, qword [rdi + mcb.owner]    ;Else, get the new PID
   253 0000055B E890030000          <1>     call closeJFTEntries    ;Close all JFT entries for this process
   254                              <1> .getNextMCB:
   255 00000560 803F5A              <1>     cmp byte [rdi + mcb.marker], mcbMarkEnd ;If we processed end block, exit
   256                              <1>     rete
    49                              <2> cret e
