   549                              <1> .open:
   550                              <1> ;Here we handle new file opens! Copies data from the 
   551                              <1> ; topmost (earliest opened) SFT (rsi) of the SFT chain into 
   552                              <1> ; the newly opened SFT (rdi)
   553 000003CE 8B4613              <1>     mov eax, dword [rsi + sft.dTimeDate]
   554 000003D1 894713              <1>     mov dword [rdi + sft.dTimeDate], eax
   555 000003D4 8B4617              <1>     mov eax, dword [rsi + sft.dFileSize]
   556 000003D7 894717              <1>     mov dword [rdi + sft.dFileSize], eax
   557 000003DA 8B460F              <1>     mov eax, dword [rsi + sft.dStartClust]
   558 000003DD 89470F              <1>     mov dword [rdi + sft.dStartClust], eax
   559 000003E0 894723              <1>     mov dword [rdi + sft.dAbsClust], eax
   560 000003E3 C7471F00000000      <1>     mov dword [rdi + sft.dRelClust], 0
   561 000003EA EBA2                <1>     jmp short .exit
