   487                              <1> 
   488                              <1> .tbl:          
   489                              <1> ;Each word is a packed entry of 15 meaningful bits with the 
   490                              <1> ; lower most bit always set and meaningless.
   491                              <1> ;That is, each word is 5 lots of 3(share mode) bits.
   492                              <1> ;The bits of each word are interpreted as follows:
   493                              <1> ;     0NNNRRRWWWAAACCCxb 
   494                              <1> ; where: 
   495                              <1> ; NNN = Deny None permissions
   496                              <1> ; RRR = Deny Read permissions 
   497                              <1> ; WWW = Deny Write permissions
   498                              <1> ; AAA = Deny All permissions
   499                              <1> ; CCC = Compat permissions
   500                              <1> ; x   = Set and ignored.
   501                              <1> ;In each triple:
   502                              <1> ;   0LMNb 
   503                              <1> ; the bits are interpreted as:
   504                              <1> ; L = What to do on Read/Write access. 
   505                              <1> ; M = What to do on Write access. 
   506                              <1> ; N = What to do on Read access.
   507                              <1> ;If a bit is set, it means this combination is not allowed.
   508                              <1> ;
   509                              <1> ;We get the word we are interested in based on the open mode of
   510                              <1> ; the new SFT. This gives us a row. We then use the open mode of
   511                              <1> ; every SFT on the MFT's SFT chain, to get a bit offset into this word.
   512                              <1> ;If for every element of the SFT chain the bit in the word is 0,
   513                              <1> ; we are ok. If ever this bit is 1, we have a sharing violation.
   514                              <1> ;
   515                              <1> ;The values of this table obtained from the matrix of the the DOS 3.3 
   516                              <1> ; programmers guide (p. 6-135), where N=1 and Y=0, with the following changes
   517                              <1> ; to make implementation easier (as the numbers are ordered as so):
   518                              <1> ;1) We swap the order of the openRWAcc and openWrAcc columns/rows
   519                              <1> ;    putting RW always at the left/bottom most part. 
   520                              <1> ;2) Each row of the table below is for "subsequent IO" where each
   521                              <1> ;    bit of the entry is the column.
   522                              <1> ;3) We duplicate Deny all as for Compat
   523                              <1> 
   524                              <1> ;Table annotated as follows: 
   525                              <1> ;N=Deny none
   526                              <1> ;R=Deny read
   527                              <1> ;W=Deny write
   528                              <1> ;A=Deny all
   529                              <1> ;C=Compat
   530                              <1> ;B=Open Read/Write (both)
   531                              <1> ;O=Open Write (output)
   532                              <1> ;I=Open Read (input)
   533                              <1> ;
   534                              <1> ;        Initial Open modes
   535                              <1> ;       N   R   W   A   C  x    ;Subsequent opens
   536                              <1> ;      BOI BOI BOI BOI BOI x    
   537 00000771 FFFF                <1>     dw 111_111_111_111_111_1b   ;I        openCompat|openRdAcc
   538 00000773 FFFF                <1>     dw 111_111_111_111_111_1b   ;O C      openCompat|openWrAcc
   539 00000775 FFFF                <1>     dw 111_111_111_111_111_1b   ;B        openCompat|openRWAcc
   540                              <1> 
   541 00000777 FFFF                <1>     dw 111_111_111_111_111_1b   ;I      openDenRWShr|openRdAcc
   542 00000779 FFFF                <1>     dw 111_111_111_111_111_1b   ;O A    openDenRWShr|openWrAcc
   543 0000077B FFFF                <1>     dw 111_111_111_111_111_1b   ;B      openDenRWShr|openRWAcc
   544                              <1> 
   545 0000077D 7FDF                <1>     dw 110_111_110_111_111_1b   ;I      openDenWrShr|openRdAcc
   546 0000077F FFDB                <1>     dw 110_110_111_111_111_1b   ;O W    openDenWrShr|openWrAcc
   547 00000781 FFDF                <1>     dw 110_111_111_111_111_1b   ;B      openDenWrShr|openRWAcc
   548                              <1> 
   549 00000783 FFBE                <1>     dw 101_111_101_111_111_1b   ;I      openDenRdShr|openRdAcc
   550 00000785 FFB7                <1>     dw 101_101_111_111_111_1b   ;O R    openDenRdShr|openWrAcc
   551 00000787 FFBF                <1>     dw 101_111_111_111_111_1b   ;B      openDenRdShr|openRWAcc
   552                              <1> 
   553 00000789 7F1C                <1>     dw 000_111_000_111_111_1b   ;I      openDenNoShr|openRdAcc
   554 0000078B FF03                <1>     dw 000_000_111_111_111_1b   ;O N    openDenNoShr|openWrAcc
   555 0000078D FF1F                <1>     dw 000_111_111_111_111_1b   ;B      openDenNoShr|openWRAcc
   556                              <1> 
   557                              <1> getTableIndex:
   558                              <1> ;Turns the adjusted open mode into a table index value
   559                              <1> ;Input: eax = Adjusted open mode
   560                              <1> ;Output: eax = Index into the table (Number 0-14)
   561                              <1> ;        ecx = Share group (0-4) [Never used, do not rely on!]
   562                              <1> ;All other regs preserved
   563 0000078F 89C1                <1>     mov ecx, eax
   564 00000791 250F000000          <1>     and eax, 0Fh    ;Isolate the open mode bits only
   565 00000796 81E1F0000000        <1>     and ecx, 0F0h   ;Isolate the share bits only
   566 0000079C 81F970000000        <1>     cmp ecx, openNetFCBShr  ;Is this a net FCB share?
   567 000007A2 7502                <1>     jne .notNetFCB
   568 000007A4 31C9                <1>     xor ecx, ecx    ;Compatibility share in this case
   569                              <1> .notNetFCB:
   570                              <1> ;We want ecx <- (ecx >> 4)*3 to get the share group
   571 000007A6 C1E904              <1>     shr ecx, 4      ;Get the share group
   572 000007A9 52                  <1>     push rdx
   573 000007AA 89CA                <1>     mov edx, ecx    ;Save it in edx
   574 000007AC D1E2                <1>     shl edx, 1      ;Multiply by 2
   575 000007AE 01CA                <1>     add edx, ecx    ;Add to get it multiplied by three
   576 000007B0 01D0                <1>     add eax, edx    ;Add share group*3 to the offset into the group
   577 000007B2 5A                  <1>     pop rdx
   578                              <1>     return
    13                              <2> %%_ret:
    14 000007B3 C3                  <2>  ret
    15                              <2> %assign retOff %%_ret-$$
   579                              <1> 
   580                              <1> getOpenMode:
   581                              <1> ;Gets the adjusted open mode.
   582                              <1> ;--------------------------------------------------------------------
   583                              <1> ;Input: rsi -> SFT to get adjusted open mode for
   584                              <1> ;Output: eax = Adjusted open mode.
   585                              <1> ;All other registers preserved.
   586                              <1> ;--------------------------------------------------------------------
   587                              <1> ;If not an FCB of any kind, then everything is ok. 
   588                              <1> ;If an SFTFCB then we put it into openCompat | openRW.
   589                              <1> ;If a NETFCB then we put it into openCompat.
   590                              <1> ;If RO file opened in openCompat, make into openDenWrShr | openRdAcc.
   591 000007B4 53                  <1>     push rbx
   592 000007B5 0FB74602            <1>     movzx eax, word [rsi + sft.wOpenMode]
   593 000007B9 66A90080            <1>     test ax, openSFTFCB ;Is this a local FCB?
   594 000007BD 7405                <1>     jz .notFCB
   595 000007BF B802000000          <1>     mov eax, openCompat | openRWAcc  ;FCBs have r/w access in compat mode
   596                              <1> .notFCB:
   597 000007C4 89C3                <1>     mov ebx, eax
   598 000007C6 81E3F0000000        <1>     and ebx, 0F0h           ;Isolate the share bits
   599 000007CC 81FB70000000        <1>     cmp ebx, openNetFCBShr  ;Is this a net FCB?
   600 000007D2 7505                <1>     jne .notNetFCB
   601 000007D4 250F000000          <1>     and eax, 0Fh            ;Clear the share bits, turn into compat share
   602                              <1> .notNetFCB:
   603                              <1> ;Now al has the real open mode for this file. Do RO check now
   604 000007D9 89C3                <1>     mov ebx, eax
   605 000007DB 81E3F0000000        <1>     and ebx, 0F0h   ;Get actual share bits to check if in compat share
   606 000007E1 5B                  <1>     pop rbx
   607                              <1>     retnz           ;If not zero, not in compat mode
    45                              <2> cret nz
