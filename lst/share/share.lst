   609                              <1> ;        ZF=ZE: End of SFT chain.
   610 000003F5 488B763B            <1>     mov rsi, qword [rsi + sft.pNextSFT]
   611 000003F9 4885F6              <1>     test rsi, rsi
   612                              <1>     retz
