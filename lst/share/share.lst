   834 0000096C CD2F                <1>     int 2Fh         ;Get length of string pointed to by rdi in ecx
   835 0000096E FFC9                <1>     dec ecx ;Drop the terminating null from the count
   836                              <1>     retz    ;If this is zero, forget the error
