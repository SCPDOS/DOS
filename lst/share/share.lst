   419                              <1> closeCompatHdls:
   420                              <1> ;Checks if all the SFTs for a filename are in compatibility mode (or netFCB) 
   421                              <1> ; for the current machine and process and closes them all if they are. 
   422                              <1> ;This is done because in on rename/delete/setattr, we check if we can proceed
   423                              <1> ; with the operation. These operations will fail if handles are open for this 
   424                              <1> ; file, unless all the handles for this file are in compatibility mode, in 
   425                              <1> ; which case we then allow for "shareless" DOS behaviour, i.e. the operation
   426                              <1> ; proceeding.
   427                              <1> ;----------------------------------------------------------------------------
   428                              <1> ;Input: fname1Ptr -> Filename to find MFT for for
   429                              <1> ;Output: Nothing
   430                              <1> ;----------------------------------------------------------------------------
   431                              <1> ;If 
   432                              <1> ;   the file is not open, then we return ok.
   433                              <1> ;Else if 
   434                              <1> ;   the file is opened by us uniquely and is open in compatibility mode,
   435                              <1> ;   then close the file and return ok.
   436                              <1> ;Else, we fail.
   437                              <1> ;----------------------------------------------------------------------------
   438 000002E1 4150                <1>     push r8
   439 000002E3 4C8B05(26000000)    <1>     mov r8, qword [pDosseg]
   440 000002EA E816010000          <1>     call critEnter
   441                              <1> ;.again:
   442 000002EF 498BB050060000      <1>     mov rsi, qword [r8 + fname1Ptr] ;Get the filename pointer
   443 000002F6 E8E1050000          <1>     call findMFT    ;Looks for this file
   444 000002FB 7237                <1>     jc .exit    ;If the file doesn't exist, exit
   445                              <1> ;File MFT found. rbx -> MFT. 
   446                              <1> ; Now check that all the files on this chain have the mid and pid of 
   447                              <1> ; the requester and (are in compatibility mode or a net SFT).
   448 000002FD 488B730E            <1>     mov rsi, qword [rbx + mft.pSFT] ;This cant be empty so it must be an SFT
   449 00000301 4889F7              <1>     mov rdi, rsi    ;Save this pSFT for closing later (if we are closing)
   450                              <1> .scanLp:
   451 00000304 418B8073040000      <1>     mov eax, dword [r8 + dMID]
   452 0000030B 3B4643              <1>     cmp eax, dword [rsi + sft.dMID]
   453 0000030E 7524                <1>     jne .exit
   454 00000310 498B806B040000      <1>     mov rax, qword [r8 + qPID]
   455 00000317 483B4647            <1>     cmp rax, qword [rsi + sft.qPID]
   456 0000031B 7517                <1>     jne .exit
   457 0000031D 0FB74602            <1>     movzx eax, word [rsi + sft.wOpenMode]
   458 00000321 25F0000000          <1>     and eax, 0F0h    ;Get the sharing mode
   459                              <1> ;If compatibility mode or net fcb, proceed with close
   460 00000326 3D70000000          <1>     cmp eax, openNetFCBShr
   461 0000032B 740F                <1>     je .next
   462 0000032D 3D00000000          <1>     cmp eax, openCompat
   463 00000332 7408                <1>     je .next
   464                              <1> .exit:
   465 00000334 E8D6000000          <1>     call critExit
   466 00000339 4158                <1>     pop r8
   467                              <1>     return
    13                              <2> %%_ret:
    14 0000033B C3                  <2>  ret
    15                              <2> %assign retOff %%_ret-$$
   468                              <1> .next:
   469 0000033C 488B763B            <1>     mov rsi, qword [rsi + sft.pNextSFT]
   470 00000340 4885F6              <1>     test rsi, rsi
   471 00000343 75BF                <1>     jnz .scanLp
   472                              <1> .closeLp:
   473                              <1> ;Here we must close all the handles referring to this SFT
   474                              <1> ;rdi -> First SFT 
   475                              <1> ;************************
   476                              <1> ;LINES MARKED WITH *** ARE EXPERIMENTAL. THEY SHOULD SPEED UP THE CLOSE PROCESS
   477                              <1> ;This algorithm is ok as we dont need to check every SFT on the MFT repeatedly
   478                              <1> ; after closing one SFT as we already have checked that all SFTs on the MFT 
   479                              <1> ; chain meet the criterion starting for closing. Since there is only one MFT
   480                              <1> ; for the filename, we can therefore close each SFT on the chain by
   481                              <1> ; simply following the SFT link pointers. This process ends when the link ptr
   482                              <1> ; is a NULL pointer. Note, we can't trust the MFT ptr as in the last case
   483                              <1> ; the MFT gets freed. Also, there exists at least one SFT on chain so we dont 
   484                              <1> ; start by checking that rdi is null.
   485                              <1> ;************************
   486 00000345 4989B863070000      <1>     mov qword [r8 + currentSFT], rdi    ;Set this SFT as current SFT
   487 0000034C 66C7070100          <1>     mov word [rdi + sft.wNumHandles], 1 ;Set count to 1 for proper cleanup***
   488 00000351 FF773B              <1>     push qword [rdi + sft.pNextSFT]     ;Save next SFT on stack***
   489                              <1> ;These two require currentSFT set
   490 00000354 E8F2010000          <1>     call closeHandlesForSFT
   491 00000359 E8E5010000          <1>     call closeSFT
   492 0000035E 5F                  <1>     pop rdi             ;Get next file in chain back***
   493 0000035F 4885FF              <1>     test rdi, rdi       ;Is this file null?***
   494 00000362 74D0                <1>     jz .exit            ;Exit if so***
   495 00000364 EBDF                <1>     jmp short .closeLp  ;Else, keep closing***
   496                              <1>     ;jmp .again  ;Now do this again until no more files
   497                              <1> 
   498                              <1> 
   499                              <1> dirUpdate:      
   500                              <1> ;Update dir info across all SFTs for a file. 
   501                              <1> ;----------------------------------------------------------------------------
   502                              <1> ;Input: rdi -> SFT to update dir entry from
   503                              <1> ;       eax = 0: Update the date/time fields only
   504                              <1> ;           = 1: Update size fields for growth
   505                              <1> ;           = 2: Update size fields for shrink (i.e. truncate/open calls)
   506                              <1> ;           = 3: Update all fields
   507                              <1> ;Output: Nothing, all SFTs in MFT chain updated.
   508                              <1> ;        rax and rcx trashed.
   509                              <1> ;----------------------------------------------------------------------------
   510                              <1> ; If rdi is a chardev or a redir file, return
   511                              <1> ; Get MFT pointer. 
   512                              <1> ; If 
   513                              <1> ;   MFT pointer is null, return.
   514                              <1> ; Else
   515                              <1> ;   Get first SFT pointer from MFT into rsi   
   516                              <1> ; If eax = 0:
   517                              <1> ;   Walk the SFT chain along rsi updating date/time fields except for us.
   518                              <1> ; Else if eax = 1:
   519                              <1> ;   Walk the SFT chain along rsi updating dFileSize and dStartClust fields 
   520                              <1> ;   except for us.
   521                              <1> ; Else if eax = 2:
   522                              <1> ;   Walk the SFT chain along rsi updating dFileSize, dStartClust and 
   523                              <1> ;   setting dRelClust to 0 and dAbsClust to dStartClust except for us.
   524                              <1> ; Else if eax = 3:
   525                              <1> ;   Update date/time and dFileSize, dStartClust, dRelClust and dAbsClust 
   526                              <1> ;   fields for us from the oldest SFT in the SFT chain for this MFT. 
   527                              <1> ;   
   528                              <1> ; Return.
   529                              <1> ;**** Note ****
   530                              <1> ;In open and shrink we reset dRelClust to 0 and dAbsClust to dStartClust
   531                              <1> ;to signify that all file IO should start from the start of the file.
   532                              <1> ;This is a future optimisation as right now, the DOS kernel never depends 
   533                              <1> ;on these values. These values are however correctly synchronised on each
   534                              <1> ;read/write so in the future, we can relatively easily add a check to make
   535                              <1> ;use of these values, unless they are at the start of the file at which
   536                              <1> ;case we use the current algorithms.
   537                              <1> ;----------------------------------------------------------------------------
   538 00000366 66F747058080        <1>     test word [rdi + sft.wDeviceInfo], devCharDev | devRedir
   539                              <1>     retnz
    45                              <2> cret nz
    19                              <3> %%_base:
    20                              <3> %assign baseVar %%_base-$$
