   590                              <1> .buildMFT:
   591                              <1> ;Here we have the following values:
   592                              <1> ;rsi -> String to copy in
   593                              <1> ;rbx -> Space to allocate the MFT in. rbx points to a free MFT.
   594                              <1> ;ecx = New MFT full size
   595                              <1> ;dl = String checksum 
   596                              <1> 
   597                              <1> ;Work out if we want to split space into two MFTs or keep it as one.
   598                              <1> ;Check if the MFT we are pointing at has enough space for a minimum mft and
   599                              <1> ; our MFT. If there is more than enough space, we split into two MFTs. 
   600                              <1> ;Else, we just allocate the whole space and waste the few extra bytes.
   601 000007EA 8B4301              <1>     mov eax, dword [rbx + mft.dLen] ;Get the current size of the free MFT
   602 000007ED 29C8                <1>     sub eax, ecx        ;Remove our own allocation from the free MFT size
   603 000007EF 3D26000000          <1>     cmp eax, MIN_MFT_SIZE
   604 000007F4 760D                <1>     jbe .alloc   ;If this is beq, we just use this mft entry as is.
   605                              <1> ;eax has the size of the new free block
   606 000007F6 488D3C0B            <1>     lea rdi, qword [rbx + rcx]  ;Point rdi past the end of our new mft
   607 000007FA C60700              <1>     mov byte [rdi + mft.bSig], mftFree  ;Make the new free block
   608 000007FD 894701              <1>     mov dword [rdi + mft.dLen], eax     ;Set the new free block's size
   609 00000800 894B01              <1>     mov dword [rbx + mft.dLen], ecx     ;Set the newly allocated block's size
   610                              <1> .alloc:
   611                              <1> ;Finally, allocate the MFT. The size, if modified, is done already.
   612 00000803 C60301              <1>     mov byte [rbx + mft.bSig], mftAlloc
   613 00000806 48C7430600000000    <1>     mov qword [rbx + mft.pLock], 0
   614 0000080E 48C7430E00000000    <1>     mov qword [rbx + mft.pSFT], 0
   615 00000816 885305              <1>     mov byte [rbx + mft.bCheckSum], dl  ;Set the checksum immediately.
   616 00000819 81E916000000        <1>     sub ecx, mft_size   ;Now get just the string length
   617 0000081F 488D7B16            <1>     lea rdi, qword [rbx + mft.sName] 
   618 00000823 F3A4                <1>     rep movsb   ;Move the string over
   619 00000825 F8                  <1>     clc
   620                              <1>     return
    13                              <2> %%_ret:
    14 00000826 C3                  <2>  ret
    15                              <2> %assign retOff %%_ret-$$
