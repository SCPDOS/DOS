   710                              <1> .next:
   711 000008A3 8B4301              <1>     mov eax, dword [rbx + mft.dLen]
   712 000008A6 4801C3              <1>     add rbx, rax    ;Point to the next MFT
   713 000008A9 EBEB                <1>     jmp short .lp
