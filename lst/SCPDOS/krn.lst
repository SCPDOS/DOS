  1430                              <1> checkExclusiveOwnFile:
  1431                              <1> ;We check that the program carrying out this action owns the file exclusively. 
  1432                              <1> ; This function will fail IF there are handles open, and thus makes it an 
  1433                              <1> ; ideal candidate for checking in RENAME, for both filenames, DELETE and 
  1434                              <1> ; SETFILEATTRIBS if we have any open files. If we do, then we should get 
  1435                              <1> ; a Share error and thus it would prevent us from proceeding.
  1436                              <1> ;
  1437                              <1> ;If SHARE not loaded, ALL handles should be closed manually before 
  1438                              <1> ; Rename or Delete.
  1439                              <1> ;Input: SDA fname1Ptr -> Filename we want to consider
  1440                              <1> ;       currDirCopy = Directory entry for the file
  1441                              <1> ;Output: Clobbers rcx, rdx, qword [currentSFT]
  1442 000044D8 50                  <1>     push rax
  1443 000044D9 53                  <1>     push rbx
  1444 000044DA 56                  <1>     push rsi
  1445 000044DB 57                  <1>     push rdi
  1446 000044DC 55                  <1>     push rbp
  1447                              <1> 
  1448                              <1> ;The below in DOS is passed in by the caller, here we preserve the 
  1449                              <1> ; caller's regs and proceed to set the ptrs ourselves.
  1450 000044DD 488D1D(8C060000)    <1>     lea rbx, curDirCopy
  1451 000044E4 488D731A            <1>     lea rsi, qword [rbx + fatDirEntry.fstClusLo]
  1452                              <1> ;At this point, the filename is fully normalised due to the 
  1453                              <1> ; way we do path parsing. Thus, we can proceed safely.
  1454                              <1> ;The following closes compat mode handles referencing file on this machine
  1455 000044E8 FF15(2F010000)      <1>     call qword [shCloseCompatHdls]    
  1456                              <1> ;The close of the handle will only happen if there is 1 file referring to it
  1457 000044EE 488D3D(500D0000)    <1>     lea rdi, scratchSFT
  1458 000044F5 E8750E0000          <1>     call setCurrentSFT
  1459 000044FA B802000000          <1>     mov eax, openRWAcc  ;Set open mode
  1460 000044FF C605(38070000)00    <1>     mov byte [openCreate], 0    ;We test by opening.
  1461 00004506 57                  <1>     push rdi    ;Save the scratch SFT ptr
  1462 00004507 E853030000          <1>     call buildSFTEntry  ;This doesn't fail as we are opening it and it exists
  1463 0000450C 5F                  <1>     pop rdi
  1464                              <1> ;Now we share open exclusively. If any other non-compat mode handles are still
  1465                              <1> ; open, this will fail and we fail the action.
  1466 0000450D 66C7070100          <1>     mov word [rdi + sft.wNumHandles], 1   ;One "reference"
  1467 00004512 66C747021000        <1>     mov word [rdi + sft.wOpenMode], openDenRWShr ;Open exclusively
  1468 00004518 E8DE400000          <1>     call shareFile
  1469 0000451D 7210                <1>     jc .exit
  1470 0000451F E8530E0000          <1>     call getCurrentSFT
  1471 00004524 66C7070000          <1>     mov word [rdi + sft.wNumHandles], 0 ;Now free it and close it
  1472 00004529 E861400000          <1>     call closeShareCallWrapper 
  1473 0000452E F8                  <1>     clc
  1474                              <1> .exit:
  1475 0000452F 5D                  <1>     pop rbp
  1476 00004530 5F                  <1>     pop rdi
  1477 00004531 5E                  <1>     pop rsi
  1478 00004532 5B                  <1>     pop rbx
  1479 00004533 58                  <1>     pop rax
