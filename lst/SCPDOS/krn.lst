    38                                  %include "./src/dos/Kernel/FileIO/devio.asm"
     1                              <1> ;This file contains the primitive dev io function, which will be called 
     2                              <1> ; from charFunc.asm, hdlFunc.asm and fcbFunc.asm as all three 
     3                              <1> ; make requests for device IO.
     4                              <1> 
     5                              <1> mainCharIO:
     6                              <1> ;This is the main IO clearing function for Char IO.
     7                              <1> ; Uses two tables, as per DOS 3.3 to store parts of the request header
     8                              <1> ; Uses only the secdReqPkt and the singleIObyt as the transfer buffer
     9                              <1> ;
    10                              <1> ;Input: rsi = SFT for the file the IO is being enacted on
    11                              <1> ;       ah = {0,..., 5}, a subfunction number
    12                              <1> ;       Function 0: Read Char (drvREAD)
    13                              <1> ;       Function 1: Non Destructive Read Char (drvNONDESTREAD)
    14                              <1> ;       Function 2: Write Char (drvWrite)
    15                              <1> ; In the case the below functions are called for Disk/Net files
    16                              <1> ;   this function will return with ZF=NZ, as if the device is ready (not busy).
    17                              <1> ;       Function 3: Output Status of Device (drvOUTSTATUS)
    18                              <1> ;       Function 4: Flush Input Buffers (drvFLUSHINBUF)
    19                              <1> ;       Function 5: Non Destructive Read Char, Busy Bit forcefully set.
    20                              <1> ;
    21                              <1> ; If and only if ah = 02h, al = Char to write to device
    22                              <1> ;
    23                              <1> ;
    24                              <1> ;Output:    If Read:                        AL = Char Read (ZF = NZ)
    25                              <1> ;           If ND Read or Output Status:    ZF = ZE => Device NOT ready (busy)
    26                              <1> ;                                           ZF = NZ => Device ready (not busy)
    27                              <1> ;                                               If ND read, AL = Next Char
    28                              <1> ; For Files/Net:
    29                              <1> ;           If ND Read, get char without advancing file pointer (sft.dCurntOff).
    30                              <1> ;           If Read, get char while advancing file pointer (sft.dCurntOff).
    31                              <1> ;           For Read and ND Read:
    32                              <1> ;               ZF = ZE when file pointer hits EOF. Else ZF = NZ.
    33                              <1> ;               Read returns ^Z on EOF.
    34                              <1> ;           If Write, char places at sft.dCurntOff and sft.dCurntOff advanced.
    35                              <1> ;   All other calls will return with ZF = NZ => Device ready (not busy)
    36                              <1> ;
    37                              <1> ;All registers preserved EXCEPT for ax and flags
    38                              <1> 
    39                              <1> ;Reference Request Header
    40                              <1> ;Common Section:
    41                              <1> ;    .hdrlen resb 1  ;Length of the request header
    42                              <1> ;    .unitnm resb 1  ;Unit number, meaningless for character devs
    43                              <1> ;    .cmdcde resb 1  ;Command code
    44                              <1> ;    .status resw 1  ;Status word
    45                              <1> ;    .devptr resq 1  ;Reserved. Unused
    46                              <1> ;Below used by calls 0,1,2,5
    47                              <1> ;    .medesc/.retbyt resb 1  ;ioReqPkt / ndInNoWaitPkt
    48                              <1> ;Below used by calls 0,2
    49                              <1> ;    .bufptr resq 1
    50                              <1> ;    .tfrlen resd 1
    51                              <1> ;Below never used, can reduce buffer size in SDA by 10h
    52                              <1> ;    .strtsc resq 1
    53                              <1> ;    .desptr resq 1
    54                              <1> 
    55                              <1>     ;Setup parts of the req ptr AS IF IT WERE FOR IO
    56 000025A0 53                  <1>     push rbx    ; PRESERVE THE STATE OF RBX OR GOD HELP YOU ALL!!!!!
    57 000025A1 488D1D(4E050000)    <1>     lea rbx, singleIObyt   ;Get lea of return byte pointer
    58 000025A8 48891D(D7040000)    <1>     mov qword [secdReqPkt + ioReqPkt.bufptr], rbx
    59 000025AF 5B                  <1>     pop rbx
    60 000025B0 C705(DF040000)0100- <1>     mov dword [secdReqPkt + ioReqPkt.tfrlen], 1 ;Request 1 byte if read/write
    60 000025B8 0000                <1>
    61 000025BA 668905(4E050000)    <1>     mov word [singleIObyt], ax  ;Save al for transfer and ah for preservation
    62 000025C1 66F746050080        <1>     test word [rsi + sft.wDeviceInfo], devRedir
    63 000025C7 0F85A1000000        <1>     jnz .notChar
    64 000025CD 66F746058000        <1>     test word [rsi + sft.wDeviceInfo], devCharDev
    65 000025D3 0F8495000000        <1>     jz .notChar
    66                              <1> ;Char devices only here
    67 000025D9 E8F7560000          <1>     call dosPushRegs    ;Save context here
    68 000025DE 488D1D40DAFFFF      <1>     lea rbx, ioRqCmdErrTbl  ;Get the table pointer in rbx
    69 000025E5 0FB6CC              <1>     movzx ecx, ah   ;Get the command code into ecx (zero xtnd rcx)
    70 000025E8 C1E102              <1>     shl ecx, 2  ;Multiply by four since DWORD entries
    71 000025EB 8B0C0B              <1>     mov ecx, dword [rbx + rcx]  ;Get entry
    72 000025EE 890D(C9040000)      <1>     mov dword [secdReqPkt], ecx ;First three entries map to first three entries
    73                              <1>     ;Now set up cx for status word
    74 000025F4 31C9                <1>     xor ecx, ecx
    75 000025F6 80FC05              <1>     cmp ah, 05h ;Did the caller request command 5?
    76 000025F9 7506                <1>     jne .skipBsySet
    77 000025FB 81C900020000        <1>     or ecx, drvBsyStatus
    78                              <1> .skipBsySet:
    79 00002601 66870D(CC040000)    <1>     xchg cx, word [secdReqPkt + drvReqPkt.status] ;Swap error flags with status
    80                              <1>     ;cl has flags, ch has garbage (status is zeroed by xchg)
    81 00002608 488D1D(C9040000)    <1>     lea rbx, secdReqPkt
    82 0000260F E8964D0000          <1>     call goDriverChar   ;GoDriver with an SFT in rsi
    83 00002614 668B3D(CC040000)    <1>     mov di, word [secdReqPkt + drvReqPkt.status]    ;Get status
    84 0000261B F7C700800000        <1>     test edi, drvErrStatus
    85 00002621 752D                <1>     jnz .error
    86                              <1> .ignoreRet:
    87 00002623 803D(CB040000)05    <1>     cmp byte [secdReqPkt + drvReqPkt.cmdcde], drvNONDESTREAD
    88 0000262A 750C                <1>     jne .notNDRead
    89 0000262C 8A05(D6040000)      <1>     mov al, byte [secdReqPkt + ndInNoWaitPkt.retbyt]    ;Get request byte
    90 00002632 8805(4E050000)      <1>     mov byte [singleIObyt], al  ;Store it here to make algorithm streamlined
    91                              <1> .notNDRead:
    92 00002638 8A25(CD040000)      <1>     mov ah, byte [secdReqPkt + drvReqPkt.status + 1]  ;Get hibyte of status word
    93 0000263E F6D4                <1>     not ah
    94 00002640 80E402              <1>     and ah, (drvBsyStatus >> 8) ;Set ZF=ZE if BSY set on for NDRead commands
    95 00002643 E876560000          <1>     call dosPopRegs ;Get back the context
    96 00002648 668B05(4E050000)    <1>     mov ax, word [singleIObyt]  ;Get back OG high byte and return char in al
    97                              <1>     return ;Return to caller
    13                              <2> %%_ret:
    14 0000264F C3                  <2>  ret
    15                              <2> %assign retOff %%_ret-$$
    98                              <1> .error:
    99                              <1>     ;cl has flags
   100 00002650 88CC                <1>     mov ah, cl
   101 00002652 E82B470000          <1>     call charDevErr
   102 00002657 3C01                <1>     cmp al, critRetry   ;Did the user request a retry
   103 00002659 750A                <1>     jne .errorIgnore
   104                              <1>     ;Fallthrough => Retry
   105 0000265B E85E560000          <1>     call dosPopRegs ;Pop context (return the regs as on entry)
   106 00002660 E93BFFFFFF          <1>     jmp mainCharIO  ;Retry operation
