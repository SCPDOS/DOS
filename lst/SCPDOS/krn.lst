  2913                              <1> setupVarsForTransfer:
  2914                              <1> ;Computes the actual bytes to be transferred and 
  2915                              <1> ; sets up internal variables for the transfer. 
  2916                              <1> ;Works for both reading and writing
  2917                              <1> ;Input: ecx = User desired Bytes to transfer
  2918                              <1> ;       rdi = SFT pointer for the file
  2919                              <1> ;Output: ecx = Actual Bytes that will be transferred 
  2920                              <1> ;Setup BOTH: tfrLen, tfrCntr, qPtr 
  2921                              <1> ;      DISK: workingDPB, workingDrv, currByteF/S, currSectF/C, currClustF
  2922                              <1> ;
  2923                              <1> ;Note: Does not account for a FULL disk. When writing,
  2924                              <1> ; if the disk will get full as a result of the write,
  2925                              <1> ; stop at the last byte before the transfer. If the 
  2926                              <1> ; file pointer is past the last free byte, write 0
  2927 000053BB 488B7707            <1>     mov rsi, qword [rdi + sft.qPtr] ;Get qPtr in rsi
  2928 000053BF 488935(3B070000)    <1>     mov qword [qPtr], rsi ;Save whatever pointer here (workingDD OR workingDPB)
  2929 000053C6 8B471B              <1>     mov eax, dword [rdi + sft.dCurntOff]    ;Get current offset into file
  2930 000053C9 8905(98070000)      <1>     mov dword [currByteF], eax  ;Save Current byte in the file
  2931 000053CF 890D(A4070000)      <1>     mov dword [tfrLen], ecx ;Save the number of bytes to transfer
  2932 000053D5 890D(A8070000)      <1>     mov dword [tfrCntr], ecx    ;Save the bytes left to transfer
  2933 000053DB 66F747058080        <1>     test word [rdi + sft.wDeviceInfo], devRedir | devCharDev
  2934                              <1>     retnz   ;Redir and char devices leave here
    45                              <2> cret nz
