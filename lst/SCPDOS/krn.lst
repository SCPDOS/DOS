   371                              <1> .rsRequest0:
   372 000009A3 BE03000000          <1>     mov esi, 3  ;Repeat attempt counter
   373 000009A8 F6470902            <1>     test byte [rdi + bufferHdr.bufferFlags], fatBuffer
