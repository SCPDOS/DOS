   845 0000184D 7320                <1>     jnc .notJoin ;Very valid disk
   846 0000184F F605(60060000)FF    <1>     test byte [skipDisk], -1    ;Are we a join drive in truename?
   847 00001856 7510                <1>     jnz .okJoin                 ;If not, proceed. If so, fail.    
   848 00001858 F9                  <1>     stc
   849 00001859 EB19                <1>     jmp short .critExit    ;If the drive number in al is too great or a join drive specified.
