   257 00003419 5E                  <1>     pop rsi                 ;Point rsi to the canonised path
   258 0000341A 0F82F7480000        <1>     jc fcbErrExit
   259 00003420 4889F7              <1>     mov rdi, rsi            ;Pass argument to rdi. rsi, rdi preserved
   260 00003423 E812460000          <1>     call checkPathspecOK    ;If the path has wildcards, fail!
   261 00003428 7239                <1>     jc .exitErr
   262 0000342A E8D7E1FFFF          <1>     call getFilePathNoCanon ;Get the file if it exists! Sets DPB too.
   263 0000342F 8B05(50050000)      <1>     mov eax, dword [buffer1]    ;Get the first four chars for comparison
   264 00003435 30C0                <1>     xor al, al
   265 00003437 3D003A5C00          <1>     cmp eax, 005C3A00h  ;Do null path check!
   266 0000343C 7425                <1>     je .exitErr
   267 0000343E 488D3D(500D0000)    <1>     lea rdi, scratchSFT     ;Set the working SFT to the scratch in the SDA
   268 00003445 E8251F0000          <1>     call setCurrentSFT
   269 0000344A 0FB605(2E070000)    <1>     movzx eax, byte [searchAttr]   ;Get the file attribute in al
   270 00003451 E828130000          <1>     call createMain
   271 00003456 720B                <1>     jc .exitErr
   272                              <1>     ;We close the sda sft since we dont have an explicit FCB close fn.
   273                              <1>     ;Necessary to close the associated share record when sharing.
   274 00003458 E885160000          <1>     call closeMain
