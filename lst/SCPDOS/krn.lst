   404 0000772D 8A4501              <1>     mov al, byte [rbp + dpb.bUnitNumber]    ;Get the unit number
   405 00007730 8805(F4040000)      <1>     mov byte [primReqPkt + ioReqPkt.unitnm], al ;Store the unit number
   406                              <1> primReqCommonExit:
