    33 0000859D 53                  <1>     push rbx
    34 0000859E FF15(07010000)      <1>     call qword [shCheckRegionLock]
    35 000085A4 5B                  <1>     pop rbx
    36                              <1>     retnc   ;Return if CF=NC (i.e. region not locked [anymore])
