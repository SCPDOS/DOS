   228                              <1> setDayofWeek:
   229                              <1> ;Sets in the variable the day of the week. 0 = Sunday, 6 = Saturday
   230 000030F7 0FB705(C3040000)    <1>     movzx eax, word [daysOffset]   ;Get the offset of days since 1/1/1980
