   370                              <1> ;Update the new cluster and sector information
   371 00000D1E 8905(85070000)      <1>     mov dword [currClustD], eax ;Update disk location of next cluster
   372 00000D24 FF05(81070000)      <1>     inc dword [currClustF]   ;Goto next file cluster
   373 00000D2A E8DFFDFFFF          <1>     call getStartSectorOfCluster    ;Get start sector of Cluster
   374 00000D2F 488905(8E070000)    <1>     mov qword [currSectD], rax  ;Save it
