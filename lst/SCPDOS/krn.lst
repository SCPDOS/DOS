   420                              <1> FCBToAsciiz:
   421                              <1> ;Converts a filename in the form FILENAMEEXT to FILENAME.EXT,0
   422                              <1> ;Name is space padded too
   423                              <1> ;Input: rsi = FCB name buffer
   424                              <1> ;       rdi = ASCIIZ string buffer
   425 0000146C B908000000          <1>     mov ecx, 8
   426 00001471 F3A4                <1>     rep movsb   ;Move the name over
   427                              <1> .scanNameSpace:
   428 00001473 807FFF20            <1>     cmp byte [rdi - 1], " " ;Is the previous char a space?
   429 00001477 750D                <1>     jne .ext
   430 00001479 48FFCF              <1>     dec rdi
   431 0000147C FFC1                <1>     inc ecx
   432 0000147E 81F908000000        <1>     cmp ecx, 8
   433 00001484 72ED                <1>     jb .scanNameSpace
   434                              <1> .ext:
   435 00001486 66813E2020          <1>     cmp word [rsi], "  "    ;Are the first two chars a space?
   436 0000148B 7506                <1>     jne .validExt
   437 0000148D 807E0220            <1>     cmp byte [rsi + 2], " " ;Is the final char a space?
   438 00001491 7415                <1>     je .exit
   439                              <1> .validExt:
   440 00001493 B02E                <1>     mov al, "." ;We have a valid extension, store a period
   441 00001495 AA                  <1>     stosb
   442 00001496 B903000000          <1>     mov ecx, 3
   443 0000149B F3A4                <1>     rep movsb   ;Move the three extension chars over
   444                              <1> .scanExtSpace:
   445 0000149D 807FFF20            <1>     cmp byte [rdi - 1], " " ;Is the previous char a space
   446 000014A1 7505                <1>     jne .exit
   447 000014A3 48FFCF              <1>     dec rdi
   448 000014A6 EBF5                <1>     jmp short .scanExtSpace
   449                              <1> .exit:
   450 000014A8 31C0                <1>     xor eax, eax
   451 000014AA AA                  <1>     stosb   ;Store a null at the end
   452                              <1>     return
