  1865 00004882 C7461B00000000      <1>     mov dword [rsi + sft.dCurntOff], 0  
  1866                              <1> ;Common fields set. Now check if creating or opening.
  1867 00004889 F605(38070000)FF    <1>     test byte [openCreate], -1  ;Create = -1
  1868 00004890 0F84F8010000        <1>     jz .openProc
