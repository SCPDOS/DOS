    29 0000319C 4889D6              <1>     mov rsi, rdx
    30 0000319F 803EFF              <1>     cmp byte [rsi], -1
    31 000031A2 7507                <1>     jne .notExt1
    32 000031A4 4881C607000000      <1>     add rsi, exFcb.driveNum
    33                              <1> .notExt1:
    34 000031AB 0FB606              <1>     movzx eax, byte [rsi]
    35 000031AE 50                  <1>     push rax    ;Push on stack the drive number
    36 000031AF 488D3D(50050000)    <1>     lea rdi, buffer1    ;Use buffer 1 to build path in
    37 000031B6 E837030000          <1>     call fcbInitRoutine ;Build path and canonicaliseFilename
    38 000031BB 7306                <1>     jnc .fcbOk
    39 000031BD 5B                  <1>     pop rbx ;Just pop into next reg to preserve error code
    40 000031BE E9544B0000          <1>     jmp fcbErrExit
    41                              <1> .fcbOk:
    42 000031C3 488D3D(50050000)    <1>     lea rdi, buffer1
    43 000031CA E837E4FFFF          <1>     call getFilePathNoCanon ;Now hit disk for this file
    44 000031CF 7306                <1>     jnc .fileFound
    45 000031D1 5B                  <1>     pop rbx
    46 000031D2 E9404B0000          <1>     jmp fcbErrExit
    47                              <1> .fileFound:
    48                              <1> ;Now we build an FFBlock internally
