   233 00006BDC 81F909000000        <1>     cmp ecx, 9  ;Is our buffer of minimum acceptable size?
   234 00006BE2 7250                <1>     jb .invFuncExit
   235 00006BE4 488D350F96FFFF      <1>     lea rsi, dosNLSPtr
