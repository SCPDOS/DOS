   979 00001959 0F848D000000        <1>     jz .cpsSkipPathseps ; and then exit with the final converted pathsep in al
   980 0000195F 3C2E                <1>     cmp al, "." ;Filename extension separator
   981 00001961 7420                <1>     je .cpsExtension
