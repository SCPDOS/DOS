    69 00006AF2 E8620D0000          <1>     call getUserRegs
    70 00006AF7 66895E08            <1>     mov word [rsi + callerFrame.rbx], bx    ;And store it in users bx
    71                              <1> .exitNoCountryCode: 
    72 00006AFB 89D8                <1>     mov eax, ebx    ;Move country code into eax for return (undocumented)
    73 00006AFD E927120000          <1>     jmp extGoodExit
