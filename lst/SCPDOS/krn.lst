   440                              <1> parseNameToFCB:
   441                              <1> ;rsi points to a command line to parse
   442                              <1> ;rdi points to a future unopened FCB
   443                              <1> ;al = parsing control bits. 
   444                              <1> ; al[0] = If set, leading filename separators are scanned off
   445                              <1> ; al[1] = If set, we set the drive ID byte if a drive letter was found
   446                              <1> ; al[2] = If set, will copy the filename to the FCB filename field
   447                              <1> ; al[3] = If set, will copy the extension to the FCB extension field
   448                              <1> ;
   449                              <1> ;Separators include : . ; , = + TAB SPACE
   450                              <1> ;Terminators include separators and , < > | / " [ ] and all ctrl chars
   451 00003592 C605(BF040000)00    <1>     mov byte [fcbSpaceOk], 0    ;Don't allow spaces in filename
   452 00003599 31D2                <1>     xor edx, edx    ;Use dl to keep drive name/state of operation
   453 0000359B A802                <1>     test al, 2  ;Set drive letter
   454 0000359D 7402                <1>     jz .skipDriveLetter
   455 0000359F 8817                <1>     mov byte [rdi + fcb.driveNum], dl   ;Clear this for usage
   456                              <1> .skipDriveLetter:
   457 000035A1 48FFC7              <1>     inc rdi ;Go past the drive letter field in the FCB
   458 000035A4 B908000000          <1>     mov ecx, 8  ;Copy Filename
   459 000035A9 A804                <1>     test al, 4  ;Do we copy the filename to the fcb field?
   460 000035AB 93                  <1>     xchg eax, ebx
   461 000035AC B020                <1>     mov al, " " ;Clear the field
   462 000035AE 7405                <1>     jz .clearFilenameField
   463 000035B0 4801CF              <1>     add rdi, rcx    ;Move to the extension field of the fcb
   464 000035B3 31C9                <1>     xor ecx, ecx
   465                              <1> .clearFilenameField:
   466 000035B5 F3AA                <1>     rep stosb
   467 000035B7 B903000000          <1>     mov ecx, 3
   468 000035BC F6C308              <1>     test bl, 8  ;Skip clearing extension field?
   469 000035BF 7405                <1>     jz .clearExtensionField
   470 000035C1 4801CF              <1>     add rdi, rcx
   471 000035C4 31C9                <1>     xor ecx, ecx
   472                              <1> .clearExtensionField:
   473 000035C6 F3AA                <1>     rep stosb
   474 000035C8 91                  <1>     xchg eax, ecx
   475 000035C9 AB                  <1>     stosd   ;Initialise curBlock and recordSize like DOS does in parseFilename
   476 000035CA 4881EF10000000      <1>     sub rdi, 10h    ;Go back to head of FCB
   477 000035D1 F6C301              <1>     test bl, 1  ;Skip scanning preceeding spaces
   478 000035D4 740F                <1>     jz .dontScanOffTerm
   479 000035D6 E89F000000          <1>     call skipSeparators ;Skip leading separators
   480 000035DB E8CD430000          <1>     call isCharTerminator   ;If first char is terminator, go past and keep skipping
   481 000035E0 7508                <1>     jnz .skipIfNotTerminator
   482 000035E2 48FFC6              <1>     inc rsi
   483                              <1> .dontScanOffTerm:
   484 000035E5 E890000000          <1>     call skipSeparators  ;Skip separators
   485                              <1> .skipIfNotTerminator:
   486 000035EA E896430000          <1>     call uppercaseCharAtPtr 
   487 000035EF 741E                <1>     jz .skipSettingDriveLetter  ;Skip if first char not a possible drive letter
   488 000035F1 803E3A              <1>     cmp byte [rsi], ":" ;Is the next char a drive separator?
   489 000035F4 7519                <1>     jne .skipSettingDriveLetter
   490 000035F6 48FFC6              <1>     inc rsi ;Goto next char
   491 000035F9 2C40                <1>     sub al, "@" ;Convert into a 1 based drive number
   492 000035FB 7609                <1>     jbe .invalidDriveLetter ;If less than 0 or 0, fail
   493 000035FD 50                  <1>     push rax    ;Save the 1 based drive letter
   494 000035FE E87A420000          <1>     call getCDSNotJoin   ;Verifies if this drive letter is valid
   495 00003603 58                  <1>     pop rax
