   765                              <1> ;Input:
   766                              <1> ;   rsi -> Source block to reallocate
   767                              <1> ;   ebx = Number of handles
   768                              <1> ;   rbp -> Current PSP
   769                              <1> ;Output: CF=NC => rsi -> Source block reallocated in size
