    79 00007847 48C1E310            <1>     shl rbx, 10h    ;Push the high dword high
    80 0000784B 668B5806            <1>     mov bx, word [rax + 6]      ;Get bits 31...16
    81 0000784F 48C1E310            <1>     shl rbx, 10h    ;Push word 2 into posiiton
    82 00007853 668B18              <1>     mov bx, word [rax]          ;Get bits 15...0
