   265 00006C4F B809000000          <1>     mov eax, 9  ;Number of bytes to save as having had been written
   266                              <1> .copyTable:
   267                              <1> ;Come here with eax = full copy len, ebx = codepage value, ecx = bytes to xfr
   268 00006C54 F3A4                <1>     rep movsb   ;Copy the rest of the bytes
   269 00006C56 E8FE0B0000          <1>     call getUserRegs
