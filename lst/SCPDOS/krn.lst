   682 00002578 721E                <1>     jc .exitBad
   683 0000257A 488D7B20            <1>     lea rdi, qword [rbx + bufferHdr.dataarea]
   684 0000257E 0FB74D02            <1>     movzx ecx, word [rbp + dpb.wBytesPerSector]
   685 00002582 31C0                <1>     xor eax, eax
   686 00002584 F3AA                <1>     rep stosb   ;Store one sectorful of zeros
   687 00002586 E897E3FFFF          <1>     call markBufferDirty ;We wrote to this buffer
   688                              <1> 
   689 0000258B FFCA                <1>     dec edx     ;One less sector in the cluster to sanitise!
   690 0000258D 740A                <1>     jz .exit    ;Jump if we done
   691 0000258F 488B430A            <1>     mov rax, qword [rbx + bufferHdr.bufferLBA] ;Get current sector number
   692 00002593 48FFC0              <1>     inc rax ;Goto next sector in cluster
   693 00002596 EBDB                <1>     jmp short .getSectorInCluster
   694                              <1> .exitBad:
   695 00002598 F9                  <1>     stc
   696                              <1> .exit:
   697 00002599 5D                  <1>     pop rbp
   698 0000259A 5E                  <1>     pop rsi
   699 0000259B 5A                  <1>     pop rdx
   700 0000259C 59                  <1>     pop rcx
   701 0000259D 5B                  <1>     pop rbx
   702 0000259E 58                  <1>     pop rax
   703                              <1>     return
