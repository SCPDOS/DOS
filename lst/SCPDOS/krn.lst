   240                              <1> 
   241                              <1> setDaysInFeb:   ;Int 2Fh AX = 121Bh, Set days in february
   242                              <1> ;Every fourth year has an extra day in feb (!! 2100 exception!!)
   243                              <1> ;Input: cl = Year - 1980
   244                              <1> ;Output: al = Number of days in February
   245 00003115 880D(C2040000)      <1>     mov byte [years], cl    ;Save this figure
   246 0000311B F6C103              <1>     test cl, 3   ;Every fourth year, the year is 0
   247 0000311E 51                  <1>     push rcx
   248 0000311F 57                  <1>     push rdi
   249 00003120 B81C000000          <1>     mov eax, 28  ;Usual days in february
   250 00003125 B91D000000          <1>     mov ecx, 29  ;Leap year days in february
   251 0000312A 0F44C1              <1>     cmovz eax, ecx  ;If this is the case move 29 into eax
   252 0000312D 488D3D35CFFFFF      <1>     lea rdi, qword [monthsTbl + 1]  ;Get second entry in table (Feb is month 2)
   253 00003134 AA                  <1>     stosb   ;Store the word in rdi
   254 00003135 5F                  <1>     pop rdi
   255 00003136 59                  <1>     pop rcx
   256                              <1>     return
