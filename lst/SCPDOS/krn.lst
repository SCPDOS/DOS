   858                              <1> xOpenHdl:    ;EAX = 6C00h, Extended open/create file
   859                              <1> ;Input: AL=0 (checked)
   860                              <1> ;       BL = Open mode (like AL for normal Open call)
   861                              <1> ;           BL[7] = Set if inherit file handle allowed
   862                              <1> ;           BL[4-6] = SHARE mode
   863                              <1> ;           BL[3] = Reserved, 0 
   864                              <1> ;           BL[0-2] = Access mode
   865                              <1> ;       BH = Extended Open Flags
   866                              <1> ;           BH[0-4] = Reserved, 0
   867                              <1> ;           BH[5] = Set means Fail all Int 24h calls by default
   868                              <1> ;           BH[6] = Set means Commit after each write operation
   869                              <1> ;           BH[7] = Reserved, 0 
   870                              <1> ;       CL = Create Attributes if creating
   871                              <1> ;           CL[0] = Sets Read-Only Bit in Directory Entry
   872                              <1> ;           CL[1] = Sets Hidden Bit in Directory Entry
   873                              <1> ;           CL[2] = Sets System Bit in Directory Entry
   874                              <1> ;           CL[3] = Sets Volume label in Directory Entry (becomes exclusive)
   875                              <1> ;           CL[4] = Reserved, 0
   876                              <1> ;           CL[5] = Sets Archive Bit in Directory Entry
   877                              <1> ;           CL[6-7] = Reserved, 0
   878                              <1> ;       CH = [SERVER CALL ONLY] Search attribute for file
   879                              <1> ;       DL = Actions if file exist or not during create/open
   880                              <1> ;           DL[4-7]: Action if file does not exist
   881                              <1> ;               0000b = Fail the call, file not found.
   882                              <1> ;               0001b = Create the file specified.
   883                              <1> ;           DL[0-3]: Action if file does exist
   884                              <1> ;               0000b = Fail the call, access denied.
   885                              <1> ;               0001b = Open the file if it exists
   886                              <1> ;               0010b = Truncate and Create file
   887                              <1> ;       Note, DL cannot be 0 as this is a fail if exist and doesnt exist
   888                              <1> ;       DH = 0
   889                              <1> ;       RSI -> ASCIIZ name of path to operate on
   890                              <1> ;Output: CF=NC: Call succeeded
   891                              <1> ;           EAX = File handle for filespec specified
   892                              <1> ;           ECX = Action undertaken by call
   893                              <1> ;               01h = File opened
   894                              <1> ;               02h = File created
   895                              <1> ;               03h = File truncated and created
   896                              <1> ;       CF=CY: Call failed.
   897                              <1> ;           AX = Error code
   898                              <1> ;Start by saving the input vars
   899 00003EFC 66891D(BE070000)    <1>     mov word [wEOOpenMode], bx  ;Save the open flags
   900 00003F03 66890D(C0070000)    <1>     mov word [wEOAttribs], cx   ;Save attribute bytes
   901 00003F0A 668915(BC070000)    <1>     mov word [wEOActions], dx   ;Save these bit for later
   902 00003F11 488935(C2070000)    <1>     mov qword [pszEOfile], rsi  ;Save filename ptr
   903                              <1> ;Now we sanity check that what we have is meaningful
   904 00003F18 84C0                <1>     test al, al
   905 00003F1A 740A                <1>     jz .okStart
   906                              <1> .badParmExit:
   907 00003F1C B857000000          <1>     mov eax, errBadParam
   908 00003F21 E9113E0000          <1>     jmp extErrExit
   909                              <1> .okStart:
   910 00003F26 84D2                <1>     test dl, dl                 ;Are we a fail if exist and dont exist?
   911 00003F28 74F2                <1>     jz .badParmExit
   912 00003F2A 66F7C2ECFF          <1>     test dx, ~(eoActCreate | eoActOpen | eoActTruncate)
   913 00003F2F 75EB                <1>     jnz .badParmExit    ;If set any bits we are not allowed to set, fail!
   914 00003F31 80E203              <1>     and dl, eoActOpen | eoActTruncate   ;Isolate the file exist bits
   915 00003F34 80FA03              <1>     cmp dl, eoActOpen | eoActTruncate   ;They cannot both be set
   916 00003F37 74E3                <1>     je .badParmExit     
   917                              <1> ;Test to check if the force fail bit is set
   918 00003F39 66F7C30020          <1>     test bx, openFailOnI24  ;Is the Int 24h Force Fail bit set?
   919 00003F3E 7509                <1>     jnz .noFailI24
   920 00003F40 66810D(BA070000)02- <1>     or word [wEOFlags], eoFailI24   ;Set corresponding bit in EO flags
   920 00003F48 00                  <1>
   921                              <1> .noFailI24:
   922 00003F49 66810D(BA070000)01- <1>     or word [wEOFlags], eoInExtOpen ;Entering Extended Open
   922 00003F51 00                  <1>
   923 00003F52 4889F2              <1>     mov rdx, rsi    ;Move the pointer into rdx as required
   924 00003F55 66813D(BC070000)10- <1>     cmp word [wEOActions], eoActCreate  ;Do we create if one doesnt exist?
   924 00003F5D 00                  <1>
   925 00003F5E 7524                <1>     jne .notCreateNew
   926                              <1> ;----DO NEW CREATE HERE----
   927                              <1> ;cx = File attributes (same as search attributes for find first)
   928                              <1> ;rdx = Ptr to ASCIZ filename to create
   929 00003F60 E8B3FDFFFF          <1>     call createNewFile
   930 00003F65 0F82CC3D0000        <1>     jc extErrExit
   931 00003F6B 66813D(BA070000)00- <1>     cmp word [wEOFlags], 0  ;Cleared by Network drives
   931 00003F73 00                  <1>
   932 00003F74 0F84AF3D0000        <1>     jz extGoodExit  ;Exit immediately, vars set by Network drive
   933 00003F7A B902000000          <1>     mov ecx, eoRetActCreate
   934 00003F7F E99D000000          <1>     jmp .localGoodExit
   935                              <1> .notCreateNew:
   936 00003F84 66F705(BC070000)01- <1>     test word [wEOActions], eoActOpen   ;If open bit set, open
   936 00003F8C 00                  <1>
   937 00003F8D 7531                <1>     jnz .openFile
   938                              <1> ;----DO TRUNCATE CREATE HERE----
   939                              <1> ;cx = File attributes (same as search attributes for find first)
   940                              <1> ;rdx = Ptr to ASCIZ filename to create
   941 00003F8F E8F2F6FFFF          <1>     call createFileHdl
   942 00003F94 0F829D3D0000        <1>     jc extErrExit
   943 00003F9A 66813D(BA070000)00- <1>     cmp word [wEOFlags], 0  ;Cleared by Network drives
   943 00003FA2 00                  <1>
   944 00003FA3 0F84803D0000        <1>     jz extGoodExit  ;Exit immediately, vars set by Network drive
   945                              <1> ;Now check if we created a new file or an existing file.
   946 00003FA9 B902000000          <1>     mov ecx, eoRetActCreate ;Anticipate new create
   947 00003FAE 66F705(BA070000)04- <1>     test word [wEOFlags], eoFileNoExist   ;Set if file was newly created
   947 00003FB6 00                  <1>
   948 00003FB7 7568                <1>     jnz .localGoodExit
   949 00003FB9 B903000000          <1>     mov ecx, eoRetActTruncate   ;Instead we truncated!
   950 00003FBE EB61                <1>     jmp short .localGoodExit
   951                              <1> .openFile:
   952                              <1> ;----DO OPEN HERE----
   953                              <1> ;al = Open mode, to open file with
   954                              <1> ;cl = Server call only, search mode for file to search for
   955                              <1> ;rdx = Ptr to ASCIZ filename to open if it exists
   956 00003FC0 89D8                <1>     mov eax, ebx    ;Move the normal open flags to al for opening
   957                              <1> ;CH has server search attribs if this is a server call.
   958                              <1> ;Else this is a harmless mov
   959 00003FC2 88E9                <1>     mov cl, ch
   960 00003FC4 E8CEF6FFFF          <1>     call openFileHdl
   961 00003FC9 7342                <1>     jnc .fileOpened
   962                              <1> ;Check if the file doesnt exist and if we are allowed to create one.
   963                              <1> ;Since we errored, CF is set on caller stack so we can just return
   964                              <1> ; if we dont create a file
   965 00003FCB 66813D(BA070000)00- <1>     cmp word [wEOFlags], 0  ;Cleared by Network drives.
   965 00003FD3 00                  <1>
   966                              <1>     retz
