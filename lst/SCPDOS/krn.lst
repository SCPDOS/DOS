   368                              <1> asciiToFCB:
   369                              <1> ;Converts a filename in the form FILENAME.EXT,0 to FILENAMEEXT
   370                              <1> ;Will uppercase any lowercase chars as this could be used with user buffers.
   371                              <1> ;Names such as SYS.COM get converted to "SYS     COM"
   372                              <1> ;Name is space padded.
   373                              <1> ;Input: rsi = ASCII string buffer
   374                              <1> ;       rdi = FCB name buffer
   375                              <1> ;Output: al = Char that terminated the source string 
   376 00001424 53                  <1>     push rbx    
   377 00001425 57                  <1>     push rdi
   378 00001426 B90B000000          <1>     mov ecx, 11
   379 0000142B B020                <1>     mov al, " "
   380 0000142D F3AA                <1>     rep stosb   ;Fill the buffer with spaces (so we don't need to fill later)
   381 0000142F 5F                  <1>     pop rdi
   382 00001430 4889FB              <1>     mov rbx, rdi    ;Use rbx as the base pointer of this buffer
   383                              <1> .processName:
   384 00001433 AC                  <1>     lodsb   ;Get the char in al
   385 00001434 E84D650000          <1>     call uppercaseChar  ;Just in ANY case, we will uppercase the cahar
   386 00001439 84C0                <1>     test al, al
   387 0000143B 742D                <1>     jz .exit
   388 0000143D 3C20                <1>     cmp al, " " ;If space or a period, go to extension field. If null, exit
   389 0000143F 740E                <1>     je .extSpace
   390 00001441 3C2E                <1>     cmp al, "."
   391 00001443 7413                <1>     je .ext
   392                              <1>     ;Test if the char is valid
   393 00001445 E8BE660000          <1>     call checkCharValid ;ZF=ZE => Invalid char
   394 0000144A 741E                <1>     jz .exit    ;If the char invalid, consider it a terminator
   395 0000144C AA                  <1>     stosb   ;Store the char
   396 0000144D EBE4                <1>     jmp short .processName
   397                              <1> .extSpace:
   398                              <1> ;Now we scan for a period in the name
   399 0000144F AC                  <1>     lodsb   ;Get a char and increase rsi
   400 00001450 84C0                <1>     test al, al
   401 00001452 7416                <1>     jz .exit
   402 00001454 3C2E                <1>     cmp al, "."     ;If al is not a period...
   403 00001456 75F7                <1>     jne .extSpace   ; keep searching
   404                              <1> .ext:
   405 00001458 488D7B08            <1>     lea rdi, qword [rbx + filename.fExt]    ;Put destination at the extension
   406                              <1> .processExt:
   407 0000145C AC                  <1>     lodsb
   408 0000145D 84C0                <1>     test al, al
   409 0000145F 7409                <1>     jz .exit
   410 00001461 3C20                <1>     cmp al, " "
   411 00001463 7405                <1>     je .exit
   412 00001465 AA                  <1>     stosb
   413 00001466 EBF4                <1>     jmp short .processExt
   414                              <1> .exitBadChar:
   415 00001468 30C0                <1>     xor al, al  ;Return a null terminator
   416                              <1> .exit:
   417 0000146A 5B                  <1>     pop rbx
   418                              <1>     return
    13                              <2> %%_ret:
    14 0000146B C3                  <2>  ret
    15                              <2> %assign retOff %%_ret-$$
