   372 00000000 ????????????????    <1>     .oldRBP         dq ?    ;Ptr to DOSSEG
   373 00000008 ????????????????    <1>     .newBuffers     dq ?    ;New buffers value
   374 00000010 ????????????????    <1>     .newSFTVal      dq ?
