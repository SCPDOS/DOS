   207 000030D2 AC                  <1>     lodsb   ;Get value in al and inc rsi
   208 000030D3 0FB6C0              <1>     movzx eax, al   ;Zero extend number of days in month
   209 000030D6 39C2                <1>     cmp edx, eax
   210 000030D8 7204                <1>     jb .monthFound
   211 000030DA 29C2                <1>     sub edx, eax  ;Reduce the number of days by the number of days in the month
   212 000030DC EBF2                <1>     jmp short .monthSearch
