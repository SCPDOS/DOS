    78 00006B09 0F8228120000        <1>     jc extErrExit   ;If CF=CY, exit error (error code in al)
    79 00006B0F 85ED                <1>     test ebp, ebp   ;If set, exit, else get, we may need to copy data
    80 00006B11 75E8                <1>     jnz .exitNoCountryCode 
    81 00006B13 85DB                <1>     test ebx, ebx   ;If ebx = 0, we entered NLS and data copied for us.
    82 00006B15 75C6                <1>     jnz .copyCountryTable   ; If not, we gotta copy from our internal copy.
    83 00006B17 89D3                <1>     mov ebx, edx    ;Move the country code into ebx
    84 00006B19 EBD7                <1>     jmp short .exitWithCountryCode
    85                              <1> .nlsWrap:
    86                              <1> ;Subroutine to wrap NLS functions. Should do nothing if we are looking
    87                              <1> ; for the current country (to avoid hitting NLSFUNC and erroring if
    88                              <1> ; not installed).
    89                              <1> ;Input: ebp = 0 -> Get country info
    90                              <1> ;           = 1 -> Set DOS country info
    91                              <1> ;        bx = Country code (bx <> 0 here)
    92                              <1> ;       rdi -> User buffer
    93                              <1> ;       rsi -> DOS internal NLS structure
    94                              <1> ;Output: CF = CY -> Error, al has error code (-1 is generic error)
    95                              <1> ;        CF = NC -> OK
    96                              <1> ;        bx = 0 => Entered NLS and data copied to user buffer.
    97                              <1> ;           > 0 => User requested current country code. Data NOT copied.
    98                              <1> ;All other registers remain the unaffected.
    99 00006B1B 663B1D5497FFFF      <1>     cmp bx, word [extCtryTbl.countryCode]   ;No NLS access if current ctry.
   100                              <1>     rete
    49                              <2> cret e
