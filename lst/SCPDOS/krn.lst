   123                              <1> getExtLocalInfo:    ;ah = 65h, Get Extended Country Info
   124                              <1> ;al = info ID or subfunction value
   125                              <1> ;al >= 20h:
   126                              <1> ;   If al[7] set, use filename table. Else, use normal table
   127                              <1> ;   al = 20h/A0h  country dependant character capitalisation
   128                              <1> ;       dl = Char to UC
   129                              <1> ;       dh = Reserved for second byte if DCBS
   130                              <1> ;   Returns:
   131                              <1> ;       dl = UC char
   132                              <1> ;       dh = Reserved for second byte if DCBS
   133                              <1> ;   al = 21h/A1h  country dependant string capitalisation
   134                              <1> ;       rdx -> Ptr to string of ecx characters to capitalise
   135                              <1> ;       ecx = String length
   136                              <1> ;   Returns: 
   137                              <1> ;       rdx -> Capitalised string
   138                              <1> ;   al = 22h/A2h  country dependant ASCIIZ string capitalisation
   139                              <1> ;       rdx -> Ptr to ASCIIZ string to capitalise
   140                              <1> ;   Returns:
   141                              <1> ;       rdx -> Capitalised ASCIIZ string
   142                              <1> ;   al = 23h/A3h  determine if character represents country relative
   143                              <1> ;                   Yes or No response 
   144                              <1> ;       dl = Char to test Y/N on
   145                              <1> ;       dh = Reserved for second byte if DCBS
   146                              <1> ;   Returns:
   147                              <1> ;       ax = 0 : (N)O
   148                              <1> ;       ax = 1 : (Y)ES 
   149                              <1> ;       ax = 2 : NEITHER
   150                              <1> ;al < 20h:
   151                              <1> ;   al = 01h get general internationalization info
   152                              <1> ;   al = 02h get pointer to uppercase table
   153                              <1> ;   xxx No 03h. Fails unknown function in this case xxx
   154                              <1> ;   al = 04h get pointer to filename uppercase table
   155                              <1> ;   al = 05h get pointer to filename terminator table
   156                              <1> ;   al = 06h get pointer to collating sequence table
   157                              <1> ;   al = 07h get pointer to DCBS table
   158                              <1> ;bx = code page (FFFFh=global code page)
   159                              <1> ;dx = country ID (FFFFh=current country)
   160                              <1> ;rdi -> country information buffer
   161                              <1> ;ecx = size of buffer (>= 9), fail if less! NOTE THE CHANGE FROM 5 to 9!!!!
   162                              <1> ;Return:
   163                              <1> ;CF=CY if error
   164                              <1> ;ax = error code
   165                              <1> ;CF=NC if successful
   166                              <1> ;ecx = size of country information returned
   167                              <1> ;rdi -> country information filled in
   168                              <1> ;Undocumented: ax = default Codepage if nls or requested codepage if internal
   169 00006B57 3C20                <1>     cmp al, 20h
   170 00006B59 0F827D000000        <1>     jb .getInterInfo
   171                              <1> ;Do string manipulation here
   172                              <1> ;Start by getting the correct table to use for translation
   173 00006B5F 488D1D3C97FFFF      <1>     lea rbx, ucTbl
   174 00006B66 488D35B797FFFF      <1>     lea rsi, fileUCTbl
   175 00006B6D A880                <1>     test al, 80h    ;Check bit 7.
   176 00006B6F 480F45DE            <1>     cmovnz rbx, rsi ;If set, use fileUC table
   177 00006B73 247F                <1>     and al, ~80h    ;Now clear the checking bit
   178 00006B75 3C24                <1>     cmp al, 24h     ;Check the function number is valid
   179 00006B77 0F83B7000000        <1>     jae .invFuncExit
   180 00006B7D 3C23                <1>     cmp al, 23h     ;Does the user want a Y/N check?
   181 00006B7F 7422                <1>     je .doYn
   182 00006B81 3C20                <1>     cmp al, 20h     ;Does the user want a char conversion?
   183 00006B83 7438                <1>     je .doOne
   184                              <1> ;String functions here
   185 00006B85 4889D6              <1>     mov rsi, rdx    ;Move source string ptr to rsi
   186 00006B88 4889D7              <1>     mov rdi, rdx    ;Move destination ptr to rdi too
   187 00006B8B 3C21                <1>     cmp al, 21h     ;Do we have the count in ecx?
   188 00006B8D 7507                <1>     jne .doString   ;Yes, go straight to conversion
   189 00006B8F E8420E0000          <1>     call strlen     ;Else, get length of string to convert 
   190 00006B94 FFC9                <1>     dec ecx         ;Drop the terminating null from conversion
   191                              <1> .doString:
   192                              <1> ;rsi -> Next char to convert
   193                              <1> ;rdi -> Position to store the converted char
   194                              <1> ;ecx = Number of chars to convert
   195 00006B96 AC                  <1>     lodsb
   196 00006B97 E83A000000          <1>     call .doChar    ;Converts the char in al
   197 00006B9C AA                  <1>     stosb
   198 00006B9D FFC9                <1>     dec ecx         ;One less char to convert
   199 00006B9F 75F5                <1>     jnz .doString
   200 00006BA1 EB15                <1>     jmp short .ynExit
   201                              <1> .doYn:
   202 00006BA3 E824000000          <1>     call .convChar  ;Uppercase char in dl.
   203 00006BA8 31C0                <1>     xor eax, eax    ;Else in Y/N check. Setup retcode in al
   204 00006BAA 80FA4E              <1>     cmp dl, "N"
   205 00006BAD 7409                <1>     je .ynExit
   206 00006BAF FFC0                <1>     inc eax         ;Inc for yes
   207 00006BB1 80FA59              <1>     cmp dl, "Y"
   208 00006BB4 7402                <1>     je .ynExit
   209 00006BB6 FFC0                <1>     inc eax         ;Inc for unknown
   210                              <1> .ynExit:
   211 00006BB8 E96C110000          <1>     jmp extGoodExit ;Return value in ax
   212                              <1> .doOne:
   213 00006BBD E80A000000          <1>     call .convChar  ;Get converted char in dl
   214 00006BC2 E8920C0000          <1>     call getUserRegs
   215 00006BC7 885618              <1>     mov byte [rsi + callerFrame.rdx], dl    ;Put dl into its place
   216 00006BCA EBEC                <1>     jmp short .ynExit
   217                              <1> .convChar:
   218                              <1> ;Input: dl = Char to uppercase
   219                              <1> ;       rbx -> Table to use for conversion
   220                              <1> ;Output: dl = Uppercased char
   221 00006BCC 88D0                <1>     mov al, dl  ;Move the char into al to uppercase
   222 00006BCE E803000000          <1>     call .doChar
   223 00006BD3 88C2                <1>     mov dl, al
   224                              <1>     return
    13                              <2> %%_ret:
