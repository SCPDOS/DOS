   662                              <1> sanitiseCluster:
   663                              <1> ;Sanitises the cluster in eax to all zeros
   664                              <1> ;Does not move file pointers
   665                              <1> ;Currently, is only called to sanitise subdirectory clusters
   666                              <1> ;Input: eax = Cluster number
   667                              <1> ;       qword [workingDPB] = DPB of drive whose cluster we are sanitising
   668                              <1> ;Output: If CF=NC => eax = Sanitised Cluster number
   669                              <1> ;        If CF=CY => Error, exit
   670 0000255B 50                  <1>     push rax
   671 0000255C 53                  <1>     push rbx
   672 0000255D 51                  <1>     push rcx
   673 0000255E 52                  <1>     push rdx
   674 0000255F 56                  <1>     push rsi
   675 00002560 55                  <1>     push rbp
   676 00002561 488B2D(3B070000)    <1>     mov rbp, qword [workingDPB]
   677 00002568 E8A1E5FFFF          <1>     call getStartSectorOfCluster    ;Needs DPB in rbp
   678 0000256D 0FB65504            <1>     movzx edx, byte [rbp + dpb.bMaxSectorInCluster] 
   679 00002571 FFC2                <1>     inc edx ;Make it a count of sectors
   680                              <1> .getSectorInCluster:
