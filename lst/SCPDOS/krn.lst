  3241                              <1> ;rdx -> Packet to work on
  3242 0000561C 488D7A06            <1>     lea rdi, qword [rdx + idParamBlk.volLab]    ;Point rdi here
  3243 00005620 B90B000000          <1>     mov ecx, 11
  3244 00005625 F3A4                <1>     rep movsb
  3245 00005627 B946080000          <1>     mov ecx, 0846h  ;IOCTL SET LABEL PACKET
  3246 0000562C B80D000000          <1>     mov eax, 0Dh    ;IOCTL Function code
  3247 00005631 E805000000          <1>     call ioctrl
  3248                              <1> .exit:
  3249 00005636 5F                  <1>     pop rdi
  3250 00005637 5E                  <1>     pop rsi
  3251 00005638 5A                  <1>     pop rdx
  3252 00005639 59                  <1>     pop rcx
