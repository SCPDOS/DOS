    50 000031DE 57                  <1>     push rdi
    51 000031DF E8C8E2FFFF          <1>     call setupFFBlock
    52 000031E4 5E                  <1>     pop rsi
    53                              <1> ;Now we use the provided FCB to store the created FFblock, to be used by us only
    54 000031E5 488B3D(4B070000)    <1>     mov rdi, qword [workingFCB]
    55 000031EC F605(2D070000)FF    <1>     test byte [extFCBFlag], -1
    56 000031F3 7407                <1>     jz .notExt2
    57 000031F5 4881C707000000      <1>     add rdi, exFcb.driveNum ;Go to the drive number 
    58                              <1> .notExt2:
