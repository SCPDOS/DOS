    34                              <1> getsetCountryInfo: ;ah = 38h, localisation info
    35                              <1> ;---------------------------------------------------------
    36                              <1> ;Common input registers
    37                              <1> ;al = Country code, 0 means current country info.
    38                              <1> ;bx = Country code if al = -1.
    39                              <1> ;Get country info:
    40                              <1> ;   rdx -> Buffer for the country table (not extended table)
    41                              <1> ;Set country info:
    42                              <1> ;   rdx = -1
    43                              <1> ;---------------------------------------------------------
    44                              <1> ;Return:
    45                              <1> ;Get country info:
    46                              <1> ;   CF=CY -> Error, ax = Error code
    47                              <1> ;   CF=NC -> OK, ax=bx=Country code, buffer @ rdx filled
    48                              <1> ;Set country info:
    49                              <1> ;   CF=CY -> Error, ax = Error code
    50                              <1> ;   CF=NC -> OK
    51                              <1> ;---------------------------------------------------------
    52 00006ABE 4889D7              <1>     mov rdi, rdx    ;Move the pointer/set indicator to rdi
    53 00006AC1 0FB6D0              <1>     movzx edx, al   ;Move potential partial country code, zx to edx
    54 00006AC4 3CFF                <1>     cmp al, -1      ;Does bx have the country code?
    55 00006AC6 0F45DA              <1>     cmovne ebx, edx ;If not, move it there
    56 00006AC9 31ED                <1>     xor ebp, ebp    ;Get country table
    57 00006ACB B901000000          <1>     mov ecx, 1      ;Set country table
    58 00006AD0 4881FFFFFFFFFF      <1>     cmp rdi, -1     ;Set or Get?
    59 00006AD7 7429                <1>     je .goToNlsFuncSet ;If set, immediately goto nls func
    60 00006AD9 85DB                <1>     test ebx, ebx   ;Else, in get, are we looking for current country?
    61 00006ADB 7527                <1>     jnz .goToNlsFunc    ;If not zero, goto nls func
    62                              <1>     ;Get current country info here, works w/o NLSFUNC
