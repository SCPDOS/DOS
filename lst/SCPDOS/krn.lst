   325 000034A0 7518                <1>     jnz .okToGo ;If the file is a char dev, its always ok for FileIO
   326 000034A2 E81E430000          <1>     call testCDSNet ;If CF=CY => Net CDS (with and without CDS)
   327 000034A7 7218                <1>     jc .exit
   328                              <1>     ;rdi has cds ptr now
   329 000034A9 488B6F45            <1>     mov rbp, qword [rdi + cds.qDPBPtr]  ;Get dpb ptr in rbp
   330 000034AD E8F1D5FFFF          <1>     call getFATtype
   331 000034B2 81F901000000        <1>     cmp ecx, 1  ;0 = FAT12, 1 = FAT16
   332 000034B8 7707                <1>     ja .exit
   333                              <1> .okToGo:
   334 000034BA C605(2B070000)00    <1>     mov byte [volIncmpFCB], 0   ;Clear this to permit usage
   335                              <1> .exit:
   336 000034C1 9D                  <1>     popfq
   337 000034C2 5D                  <1>     pop rbp
   338 000034C3 5F                  <1>     pop rdi
   339 000034C4 59                  <1>     pop rcx
