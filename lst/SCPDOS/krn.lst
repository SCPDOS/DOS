  3203                              <1> syncVolLabel:
  3204                              <1> ;Used to sync volume labels when a new vol label made in DOS.
  3205                              <1> ;If the device doesn't support this function we just ignore it.
  3206                              <1> ;Fails therefore are ignored.
  3207                              <1> ;Input: fcbName = Volume Label name in FCB format
  3208                              <1> ;       bl = 0 : Create label
  3209                              <1> ;       bl = 1 : Delete label (reset to NO NAME and 0 time)
  3210                              <1> ;       al = 0 based drive to work on
  3211                              <1> ;Preserves all registers except rax and rbx (rbx saved externally)
  3212 000055DF 51                  <1>     push rcx
  3213 000055E0 52                  <1>     push rdx
  3214 000055E1 56                  <1>     push rsi
  3215 000055E2 57                  <1>     push rdi
  3216                              <1>     
  3217 000055E3 0FB6C0              <1>     movzx eax, al   ;Zero extend the rest code to rest of the register
  3218 000055E6 FFC0                <1>     inc eax     ;Convert the 0 based drive number to a 1 based number
  3219 000055E8 50                  <1>     push rax    ;Save the 1 based drive number on the stack
  3220 000055E9 53                  <1>     push rbx    ;Save subfunction code
  3221                              <1> 
  3222 000055EA 89C3                <1>     mov ebx, eax    ;Save this number into eax
  3223 000055EC B80D000000          <1>     mov eax, 0Dh    ;IOCTL Function code
  3224 000055F1 B966080000          <1>     mov ecx, 0866h  ;IOCTL GET LABEL PACKET
  3225 000055F6 488D15(691A0000)    <1>     lea rdx, labelPkt
  3226 000055FD 52                  <1>     push rdx    ;Save the ptr to the xfr packet
  3227 000055FE E838000000          <1>     call ioctrl ;This call sets the working drive again to drive in bx
  3228 00005603 5A                  <1>     pop rdx     ;Get xfr packet ptr back
  3229 00005604 58                  <1>     pop rax     ;Get the subfunction code back in eax
  3230 00005605 5B                  <1>     pop rbx     ;Get the 1 based drive number back into bl (ebl)
  3231 00005606 722E                <1>     jc .exit
  3232 00005608 85C0                <1>     test eax, eax   ;Check subfunction to do 
  3233 0000560A 7509                <1>     jnz .defaultLbl
  3234 0000560C 488D35(0B070000)    <1>     lea rsi, fcbName
  3235 00005613 EB07                <1>     jmp short .makePkt
  3236                              <1> .defaultLbl:
  3237 00005615 488D35FEA9FFFF      <1>     lea rsi, dosDfltLbl
  3238                              <1> .makePkt:
  3239                              <1> ;rsi -> Source of 11 chars to copy over
