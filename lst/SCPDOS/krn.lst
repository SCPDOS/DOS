   225                              <1> .fbFail:
   226                              <1> ;Enter here only if the request failed esi times or bad change
   227 000008BC 3C0F                <1>     cmp al, drvBadDskChnge  ;If error code is bad change, prompt immediately
   228 000008BE 7407                <1>     je .fbHardError
