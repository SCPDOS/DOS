    40 000084A6 B801000000          <1>     mov eax, errInvFnc
    41 000084AB C605(3A040000)01    <1>     mov byte [errorLocus], eLocUnk
    42 000084B2 804C241001          <1>     or byte [rsp + 8h*2], 1 ;Set CF
