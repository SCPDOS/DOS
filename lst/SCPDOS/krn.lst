   959 0000192F F3AB                <1>     rep stosd   ;Store 12 spaces
   960 00001931 5F                  <1>     pop rdi ;Point rdi back to fcb name head
   961                              <1> 
   962 00001932 488D1D(16070000)    <1>     lea rbx, fcbName + 11   ;Use rbx as the end of fcb name marker address
   963 00001939 AC                  <1>     lodsb   ;Get first char from user path in al
   964 0000193A 3C2E                <1>     cmp al, "."   ;Handle starting dot separately
   965 0000193C 746B                <1>     je .cpsDots
