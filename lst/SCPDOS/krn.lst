  2961                              <1> findFreeSFT:
  2962                              <1> ;Returns a pointer to a free SFT if CF=NC. Else, no free SFTs.
  2963                              <1> ;Modifies an SFT entry. Must be called in a critical section.
  2964                              <1> ;Output: CF=NC => rdi = Points to a free SFT entry, bx = SFTndx
  2965                              <1> ;        CF=CY => eax = errNhl, error exit
  2966 00005437 31DB                <1>     xor ebx, ebx
