   102                              <1>     ;rsi points to drive letter
   103 00003282 488D3D(61060000)    <1>     lea rdi, dosffblock ;Set rdi to point to the dosffblock
   104 00003289 31C0                <1>     xor eax, eax
   105 0000328B AC                  <1>     lodsb   ;Get the FCB drive letter
