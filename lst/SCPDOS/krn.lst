    64 00006ADD 488D359697FFFF      <1>     lea rsi, ctryTbl
    65 00006AE4 B926000000          <1>     mov ecx, countryStruc_size
    66 00006AE9 F3A4                <1>     rep movsb
    67 00006AEB 0FB71D8497FFFF      <1>     movzx ebx, word [extCtryTbl.countryCode]    ;Get current country code
