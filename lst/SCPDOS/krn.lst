   109 00003291 B905000000          <1>     mov ecx, 5
   110 00003296 F3A5                <1>     rep movsd   ;Copy 20 bytes now to the ffblock
   111 00003298 FF35(47040000)      <1>     push qword [currentDTA] ;Save original currentDTA
   112 0000329E 488D3D(61060000)    <1>     lea rdi, dosffblock
