   405                              <1> checkPathspecOK:
   406                              <1> ;Input:
   407                              <1> ;rsi -> points to a path to verify if it is ok.
   408                              <1> ;Output:
   409                              <1> ;CF=NC => The path is totally clean and ok to use.
   410                              <1> ;CF=CY => the path is malformed or longer than 64 chars.
   411                              <1> ; If CF=CY and ZF=ZE then wildcards were found in the last portion
   412                              <1> ; and depending on method of invokation and caller, may be permissable.
   413                              <1> ;We accept lc and uc characters in this check function.
   414 00007A3A 50                  <1>     push rax
   415 00007A3B 53                  <1>     push rbx    ;Use rbx as the return flag status
   416 00007A3C 56                  <1>     push rsi
   417 00007A3D 31DB                <1>     xor ebx, ebx    ;Clear the return status flags
   418                              <1>     ;Start by getting the length of the ASCIIZ string.
   419 00007A3F 51                  <1>     push rcx
   420 00007A40 57                  <1>     push rdi
   421 00007A41 4889F7              <1>     mov rdi, rsi
   422 00007A44 E88DFFFFFF          <1>     call strlen
   423 00007A49 89C8                <1>     mov eax, ecx    ;Save the length in eax
   424 00007A4B 5F                  <1>     pop rdi
   425 00007A4C 59                  <1>     pop rcx
   426 00007A4D 3D40000000          <1>     cmp eax, MAX_FSPEC    ;Check
   427 00007A52 0F8792000000        <1>     ja .badExit ;Above 64 only as the count includes the terminating null
   428 00007A58 85C0                <1>     test eax, eax   ;If the path is empty, also error out!
   429 00007A5A 0F848A000000        <1>     jz .badExit
   430                              <1>     ;First we verify if our path is relative or canonical (absolute)
   431 00007A60 668B06              <1>     mov ax, word [rsi]  ;Get the first two chars
   432 00007A63 663D5C5C            <1>     cmp ax, "\\"    ;UNC network start
   433 00007A67 7416                <1>     je .netName
   434 00007A69 663D2F2F            <1>     cmp ax, "//"    ;Also acceptable UNC network start
   435 00007A6D 7410                <1>     je .netName
   436 00007A6F 80FC3A              <1>     cmp ah, ":" ;Is this a full or CWD of drive letter relative disk path?
   437 00007A72 7419                <1>     je .diskPath    ;Need to check if the char preceeding is an ASCII drive char
   438                              <1>     ;Here if relative
   439 00007A74 F605(33070000)FF    <1>     test byte [dosInvoke], -1
   440 00007A7B 756D                <1>     jnz .badExit    ;If this is -1, server invoke.
   441 00007A7D EB3B                <1>     jmp short .okToScan
   442                              <1> .netName:
   443 00007A7F 4881C602000000      <1>     add rsi, 2  ;Goto the first char after the UNC start symbol
   444 00007A86 803E00              <1>     cmp byte [rsi], 0   ;If this is an empty path, error!
   445 00007A89 745F                <1>     je .badExit
   446 00007A8B EB2D                <1>     jmp short .okToScan
   447                              <1> .diskPath:
   448 00007A8D 4881C602000000      <1>     add rsi, 2  ;Go past the X:
   449 00007A94 803E00              <1>     cmp byte [rsi], 0   ;Cannot have an empty relative path!
   450 00007A97 7451                <1>     je .badExit
   451 00007A99 F605(33070000)FF    <1>     test byte [dosInvoke], -1    ;If this is minus 1, this is a server invoke
   452 00007AA0 740F                <1>     jz .localAbsCheck
   453                              <1> .absMain:
   454 00007AA2 AC                  <1>     lodsb   ;Get the third byte. It MUST be a pathsep if server invokation.
   455 00007AA3 E8D2FEFFFF          <1>     call swapPathSeparator
   456 00007AA8 7540                <1>     jnz .badExit    ;If ZF=NZ => Not a pathsep, bad path
   457 00007AAA 803E00              <1>     cmp byte [rsi], 0   ;Is the char after the slash null?
   458 00007AAD 743B                <1>     je .badExit ;Error if so!
   459 00007AAF EB09                <1>     jmp short .okToScan
   460                              <1> .localAbsCheck:
   461 00007AB1 8A06                <1>     mov al, byte [rsi]  ;Get the char we are pointing at
   462 00007AB3 E8C2FEFFFF          <1>     call swapPathSeparator  ;Is it a pathsep?
   463 00007AB8 74E8                <1>     jz .absMain ;If it is, we do the absolute check
   464                              <1>     ;Else we are relative and begin wildcard search
   465                              <1> .okToScan:
   466 00007ABA AC                  <1>     lodsb   
   467 00007ABB 84C0                <1>     test al, al ;End of path char?
   468 00007ABD 7430                <1>     jz .exit
   469 00007ABF E8B6FEFFFF          <1>     call swapPathSeparator
   470 00007AC4 741C                <1>     jz .wcCheck ;If it was a pathsep, ensure no WC's have been detected
   471 00007AC6 3C2A                <1>     cmp al, "*" ;Was al a big wildcard?
   472 00007AC8 7411                <1>     je .wcFound
   473 00007ACA 3C3F                <1>     cmp al, "?" ;Was al a small wildcard?
   474 00007ACC 740D                <1>     je .wcFound ;If al was a wildcard, proceed as for wildcard
   475                              <1>     ;Else we check that the char in al is an acceptable char
   476 00007ACE 3C2E                <1>     cmp al, "." ;Ensure that dots are allowed through this part check
   477 00007AD0 74E8                <1>     je .okToScan
