    68                              <1> ;        ZF=ZE => No unreferenced buffer found
    69 00000793 4881FFFFFFFFFF      <1>     cmp rdi, -1 ;Start by checking rdi is not at the end of the list already :)
    70                              <1>     rete    ;Return preserving ZF is so
