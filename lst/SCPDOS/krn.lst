   103 0000861C FFC9                <1>     dec ecx
   104 0000861E 75E3                <1>     jnz .keepLooping
   105 00008620 E842000000          <1>     call shareCriticalError
   106 00008625 73D5                <1>     jnc .reloadCounter  ;If user selected retry, we retry
   107                              <1> .exit:
   108 00008627 59                  <1>     pop rcx
   109                              <1>     return
